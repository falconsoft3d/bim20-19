<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="report_bim_especificacion_producto">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="doc">
            <t t-call="web.external_layout">
                <div class="page">

                    <!-- Título -->
                    <div class="row mb-4">
                        <div class="col-12 text-center">
                            <h2>Especificación de Producto</h2>
                            <h3 t-esc="doc.name"/>
                        </div>
                    </div>

                    <!-- Cabecera -->
                    <div class="row mb-3">
                        <div class="col-6">
                            <table class="table table-sm table-bordered">
                                <tbody>
                                    <tr>
                                        <th class="bg-light" style="width:40%">Proyecto</th>
                                        <td><t t-esc="doc.project_id.name or ''"/></td>
                                    </tr>
                                    <tr>
                                        <th class="bg-light">Producto</th>
                                        <td><t t-esc="doc.product_id.name or ''"/></td>
                                    </tr>
                                    <tr>
                                        <th class="bg-light">Usuario</th>
                                        <td><t t-esc="doc.user_id.name or ''"/></td>
                                    </tr>
                                    <tr>
                                        <th class="bg-light">Fecha</th>
                                        <td><t t-esc="doc.fecha" t-options='{"widget": "date"}'/></td>
                                    </tr>
                                    <tr>
                                        <th class="bg-light">Estado</th>
                                        <td>
                                            <t t-if="doc.state == 'borrador'">Borrador</t>
                                            <t t-elif="doc.state == 'en_tramite'">En Trámite</t>
                                            <t t-elif="doc.state == 'cerrada'">Cerrada</t>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="col-6">
                            <table class="table table-sm table-bordered">
                                <tbody>
                                    <tr>
                                        <th class="bg-light" style="width:40%">Proveedor 1</th>
                                        <td><t t-esc="doc.proveedor1_id.name or ''"/></td>
                                    </tr>
                                    <tr>
                                        <th class="bg-light">Proveedor 2</th>
                                        <td><t t-esc="doc.proveedor2_id.name or ''"/></td>
                                    </tr>
                                    <tr>
                                        <th class="bg-light">Proveedor 3</th>
                                        <td><t t-esc="doc.proveedor3_id.name or ''"/></td>
                                    </tr>
                                    <tr>
                                        <th class="bg-light">Prov. Adjudicado</th>
                                        <td>
                                            <strong>
                                                <t t-esc="doc.proveedor_adjudicado_id.name or ''"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Líneas de características -->
                    <t t-if="doc.line_ids">
                        <h4 class="mt-3">Características</h4>
                        <table class="table table-sm table-bordered">
                            <thead class="bg-light">
                                <tr>
                                    <th style="width:28%">Característica</th>
                                    <th style="width:24%">Propuesta 1</th>
                                    <th style="width:24%">Propuesta 2</th>
                                    <th style="width:24%">Propuesta 3</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.line_ids" t-as="line">
                                    <tr>
                                        <td><t t-esc="line.caracteristica or ''"/></td>
                                        <td><t t-esc="line.propuesta1 or ''"/></td>
                                        <td><t t-esc="line.propuesta2 or ''"/></td>
                                        <td><t t-esc="line.propuesta3 or ''"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>

                    <!-- Notas -->
                    <t t-if="doc.notas">
                        <h4 class="mt-3">Notas</h4>
                        <p><t t-esc="doc.notas"/></p>
                    </t>

                    <!-- Firmas -->
                    <div class="row mt-5">
                        <div class="col-4 text-center">
                            <div style="border-top: 1px solid #000; margin-top: 40px; padding-top: 4px;">
                                <small>Responsable</small>
                            </div>
                        </div>
                        <div class="col-4 text-center">
                            <div style="border-top: 1px solid #000; margin-top: 40px; padding-top: 4px;">
                                <small>Proveedor Adjudicado</small>
                            </div>
                        </div>
                        <div class="col-4 text-center">
                            <div style="border-top: 1px solid #000; margin-top: 40px; padding-top: 4px;">
                                <small>Aprobado por</small>
                            </div>
                        </div>
                    </div>

                </div>
            </t>
        </t>
    </t>
</template>
</odoo>
