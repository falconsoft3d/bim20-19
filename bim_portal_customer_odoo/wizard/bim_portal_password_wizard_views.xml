<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════════════════
         Wizard: Establecer Contraseña Portal BIM
    ══════════════════════════════════════════════════════════════════ -->

    <record id="bim_portal_password_wizard_view_form" model="ir.ui.view">
        <field name="name">bim.portal.password.wizard.form</field>
        <field name="model">bim.portal.password.wizard</field>
        <field name="arch" type="xml">
            <form string="Establecer Contraseña Portal">
                <sheet>
                    <group string="Acceso del contacto">
                        <field name="partner_id" readonly="1"/>
                        <field name="partner_login" readonly="1"/>
                    </group>

                    <group string="Nueva contraseña">
                        <field name="new_password" password="True"/>
                        <field name="confirm_password" password="True"/>
                        <field name="password_strength" widget="badge"
                               decoration-danger="password_strength == 'weak'"
                               decoration-warning="password_strength == 'medium'"
                               decoration-success="password_strength == 'strong'"/>
                    </group>

                    <div class="alert alert-info" role="alert">
                        <strong>Requisitos:</strong> mínimo 8 caracteres, con mayúsculas,
                        minúsculas, números y símbolos (!@#$%^&amp;*).
                    </div>
                </sheet>
                <footer>
                    <button name="action_generate_password" type="object"
                            string="Generar contraseña segura"
                            class="btn-secondary"/>
                    <button name="action_set_password" type="object"
                            string="Guardar contraseña"
                            class="btn-primary"
                            data-hotkey="s"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
