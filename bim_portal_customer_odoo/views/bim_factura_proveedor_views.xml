<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════
         HERENCIA DEL FORMULARIO account.move
         Añade pestaña "Portal BIM" cuando la factura viene del portal
    ══════════════════════════════════════════════════════════ -->
    <record id="view_account_move_form_bim_portal" model="ir.ui.view">
        <field name="name">account.move.form.bim.portal</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Portal BIM" invisible="not bim_submitted_by">
                    <group>
                        <group>
                            <field name="bim_project_id" options="{'no_create': True}"/>
                            <field name="bim_importe" string="Importe referencia"/>
                            <field name="bim_portal_state" widget="badge"
                                   decoration-success="bim_portal_state == 'approved'"
                                   decoration-danger="bim_portal_state == 'rejected'"
                                   decoration-warning="bim_portal_state == 'submitted'"/>
                        </group>
                        <group>
                            <field name="bim_submitted_by" readonly="1" options="{'no_create': True}"/>
                            <field name="bim_notas" readonly="1"/>
                        </group>
                    </group>
                    <div class="mt-3">
                        <button name="bim_action_approve" string="Aprobar"
                                type="object" class="btn btn-success"
                                invisible="bim_portal_state == 'approved'"/>
                        <button name="bim_action_reject" string="Rechazar"
                                type="object" class="btn btn-danger ms-2"
                                invisible="bim_portal_state == 'rejected'"/>
                    </div>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         VISTA LIST — Facturas del Portal BIM
    ══════════════════════════════════════════════════════════ -->
    <record id="view_account_move_list_bim_portal" model="ir.ui.view">
        <field name="name">account.move.list.bim.portal</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <list string="Facturas Portal BIM"
                  decoration-success="bim_portal_state == 'approved'"
                  decoration-danger="bim_portal_state == 'rejected'"
                  decoration-info="bim_portal_state == 'submitted'">
                <field name="name" string="Número"/>
                <field name="invoice_date" string="Fecha"/>
                <field name="partner_id" string="Proveedor"/>
                <field name="bim_project_id" string="Proyecto"/>
                <field name="bim_importe" string="Importe ref." optional="show"/>
                <field name="amount_total" widget="monetary" string="Total contable"/>
                <field name="bim_submitted_by" string="Enviado por" optional="show"/>
                <field name="bim_portal_state" widget="badge"
                       decoration-success="bim_portal_state == 'approved'"
                       decoration-danger="bim_portal_state == 'rejected'"
                       decoration-warning="bim_portal_state == 'submitted'"
                       string="Estado portal"/>
                <field name="state" widget="badge" optional="show" string="Estado contable"/>
                <button name="bim_action_approve" string="Aprobar" type="object"
                        icon="fa-check" invisible="bim_portal_state != 'submitted'"
                        class="text-success"/>
                <button name="bim_action_reject" string="Rechazar" type="object"
                        icon="fa-times" invisible="bim_portal_state != 'submitted'"
                        class="text-danger"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         ACCIÓN — filtra solo las facturas del portal
    ══════════════════════════════════════════════════════════ -->
    <record id="action_bim_facturas_portal" model="ir.actions.act_window">
        <field name="name">Facturas de Proveedor (Portal)</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_account_move_list_bim_portal')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('account.view_move_form')})]"/>
        <field name="domain">[('bim_submitted_by', '!=', False), ('move_type', '=', 'in_invoice')]</field>
        <field name="context">{'default_move_type': 'in_invoice'}</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         MENÚ bajo BIM Documentación
    ══════════════════════════════════════════════════════════ -->
    <menuitem id="menu_bim_factura_proveedor"
              name="Facturas de Proveedor"
              parent="base_bim_2.menu_bim_documentation_categ"
              action="action_bim_facturas_portal"
              sequence="70"/>

</odoo>
