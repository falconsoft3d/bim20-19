<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">
        <!-- bim.expense -->
        <record id="bim_follower_category" model="ir.module.category">
            <field name="name">Bim Follower</field>
            <field name="description">Bim Follower</field>
            <field name="sequence" eval="90"/>
        </record>

        <record id="group_bim_follower" model="res.groups">
            <field name="name">Bim Only Follower</field>
            <field name="category_id" ref="bim_follower_category"/>
            <field name="users" eval="[(4, ref('base.user_root'))]"/>
        </record>

        <record id="group_bim_follower_all" model="res.groups">
            <field name="name">Bim All Follower</field>
            <field name="category_id" ref="bim_follower_category"/>
        </record>


        <!-- Solo seguidores o creador -->
        <!-- para bim.project -->
        <record id="rule_bim_project_followers_only" model="ir.rule">
            <field name="name">bim.project - ver solo si soy seguidor</field>
            <field name="model_id" ref="base_bim_2.model_bim_project"/>
            <field name="domain_force">
                ['|', ('message_partner_ids', 'in', [user.partner_id.id]), ('create_uid', '=', user.id)]
            </field>
            <!-- limita a usuarios normales; ajusta el grupo a tu caso -->
            <field name="groups" eval="[(4, ref('bim_followers.group_bim_follower'))]"/>
            <!-- que todos los usuarios lo agreguen a sus grupos de seguridad -->

        </record>

        <!-- Todos los seguidores -->
        <record id="rule_bim_project_followers_all" model="ir.rule">
            <field name="name">bim.project - ver todos sin importar que sea seguidor</field>
            <field name="model_id" ref="base_bim_2.model_bim_project"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <!-- limita a usuarios normales; ajusta el grupo a tu caso -->
            <field name="groups" eval="[(4, ref('bim_followers.group_bim_follower_all'))]"/>
        </record>



