<odoo>
    <data>
        <!-- Heredando el informe de órdenes de compra -->
        <template id="report_purchaseorder_document_inherited" inherit_id="purchase.report_purchaseorder_document">
            <xpath expr="//div[@id='informations']" position="replace">
                <div id="informations" class="row mt-4 mb32">
                    <!-- place_of_delivery_id -->
                    <!--  <t t-if="o.dest_address_id"> -->
                    <t t-if="o.place_of_delivery_id">
                        <t t-set="information_block">
                            <strong>Lugar Entrega:</strong>
                            <div t-field="o.place_of_delivery_id"
                                 t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'/>
                        </t>
                    </t>
                    <t t-if="not o.place_of_delivery_id">
                        <t t-set="information_block">
                            <strong>Lugar Entrega:</strong>
                            <div t-field="o.company_id"
                                 t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'/>
                        </t>
                    </t>

                </div>
            </xpath>
        </template>
    </data>
</odoo>