<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_tree_bim_typology" model="ir.ui.view">
        <field name="name">view.tree.bim.typology</field>
        <field name="model">bim.typology</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="code"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_bim_typology" model="ir.actions.act_window">
        <field name="name">Typologies</field>
        <field name="res_model">bim.typology</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
