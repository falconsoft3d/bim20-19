<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="crm_budget_request_form_bim_view" model="ir.ui.view">
            <field name="name">crm.budget.request.form.bim.view</field>
            <field name="model">budget.request</field>
            <field name="inherit_id" ref="base_bim_2.budget_request_view_form"/>
            <field name="arch" type="xml">
                <field name="department_id" position="before">
                    <field name="opportunity_id" readonly="state != 'draft'"/>
                </field>
            </field>
        </record>

     <record id="crm_budget_request_tree_bim_view" model="ir.ui.view">
            <field name="name">crm.budget.request.tree.bim.view</field>
            <field name="model">budget.request</field>
            <field name="inherit_id" ref="base_bim_2.budget_request_view_tree"/>
            <field name="arch" type="xml">
                <field name="name" position="before">
                    <field name="opportunity_id"/>
                </field>
            </field>
        </record>
</odoo>