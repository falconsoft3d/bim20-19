<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_tree_bim_project_unit_typology_price" model="ir.ui.view">
        <field name="name">view.tree.bim.project.unit.typology.price</field>
        <field name="model">bim.project.unit.typology.price</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="unit_id"/>
                <field name="typology_id"/>
                <field name="surface"/>
                <field name="price" widget="monetary"/>
                <field name="currency_id" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_bim_project_unit_typology_price" model="ir.actions.act_window">
        <field name="name">Unit typology prices</field>
        <field name="res_model">bim.project.unit.typology.price</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
