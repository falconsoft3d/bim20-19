<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="bim_import_limit_parameter" model="ir.config_parameter">
        <field name="key">bim.import.temp.limit</field>
        <field name="value">5000</field>
    </record>
    <record id="bim_import_csv_url_parameter_raw" model="ir.config_parameter">
        <field name="key">bim.import.csv.url.parameter.raw</field>
        <field name="value">https://raw.githubusercontent.com/falconsoft3d/preciosconstruccion/main/public/data/apus/spain/apus.csv</field>
    </record>
    <record id="tools_inventory_movement" model="ir.config_parameter">
        <field name="key">tools.inventory.movement</field>
        <field name="value">True</field>
    </record>

    <record id="stock_picking_in" model="ir.config_parameter">
        <field name="key">stock.picking.in</field>
        <field name="value">False</field>
    </record>

    <record id="stock_picking_out" model="ir.config_parameter">
        <field name="key">stock.picking.out</field>
        <field name="value">False</field>
    </record>

</odoo>
