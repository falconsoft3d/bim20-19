<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="bim_apu_wizard_form" model="ir.ui.view">
        <field name="name">bim.apu.wizard.form</field>
        <field name="model">bim.apu.wizard</field>
        <field name="arch" type="xml">
            <form string="Insert apus">
                <group name="main">
                    <group name="left">
                        <field name="template_id" required="1" options="{'no_open':True, 'no_quick_create': True, 'no_create_edit': True}"/>
                        <field name="project_id" invisible="True"/>
                        <field name="obs" readonly="1"/>
                    </group>
                    <group>
                        <field name="val_n" required="1"/>
                        <field name="val_x" required="1"/>
                        <field name="val_y" required="1"/>
                        <field name="val_z" required="1"/>
                    </group>
                </group>
                <separator string="Paremeters" colspan="4"/>
                <field name="variable_ids">
                    <list editable="bottom" create="0" delete="0">
                        <field name="variable" force_save="1"/>
                        <field name="name" force_save="1"/>
                        <field name="product_uom" force_save="1"/>
                        <field name="value"/>
                    </list>
                </field>
                <footer>
                    <button string="Continue" name="do_action"  type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-default"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="bim_wizard_apu_action" model="ir.actions.act_window">
        <field name="name">Insert apu</field>
        <field name="res_model">bim.apu.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_project_id': active_id}</field>
    </record>

</odoo>
