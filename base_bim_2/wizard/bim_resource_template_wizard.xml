<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="bim_resource_template_wizard_form" model="ir.ui.view">
        <field name="name">bim.resource.template.wizard.form</field>
        <field name="model">bim.resource.template.wizard</field>
        <field name="arch" type="xml">
            <form string="Resource Template Wizard">
                <group name="main">
                    <group name="left">
                        <field name="bim_resource_template_id" options='{"no_create": 1, "no_open": 1}'/>
                    </group>
                    <group>
                        <field name="concept_id" invisible="True"/>
                    </group>
                </group>

                <footer>
                    <button string="Insert"
                            name="do_action"  type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-default"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="bim_resource_template_wizard_action" model="ir.actions.act_window">
        <field name="name">Resource Template Wizard</field>
        <field name="res_model">bim.resource.template.wizard</field>
        <field name="view_mode">form</field>
       <field name="target">new</field>
    </record>

</odoo>