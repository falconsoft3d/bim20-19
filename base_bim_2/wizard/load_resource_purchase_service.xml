<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="resource_purchase_service_wizard_view_form" model="ir.ui.view">
        <field name="name">load.resource.purchase.service</field>
        <field name="model">resource.purchase.service.wzd</field>
        <field name="arch" type="xml">
            <form>
                <group name="bim_req">
                    <group>
                        <field name="project_id" invisible="True"/>
                        <field name="service_type"/>
                        <field
                                name="concept_ids"
                                placeholder="Concepts" widget="many2many_tags"
                                domain="[
                                           ('budget_id', 'in', budget_ids),
                                           ('type', '=', 'departure'),
                                        ]"

                                options='{"no_create": 1, "no_open": 1, "no_quick_create": 1, "no_create_edit": 1}'
                        />
                    </group>
                    <group>
                        <field name="budget_ids" domain="[('project_id', '=', project_id)]" widget="many2many_checkboxes"/>
                    </group>
                </group>
                <footer>
                    <button string="Load" name="load_resources" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_purchase_service_wizard" model="ir.actions.act_window">
        <field name="name">Load Service Request</field>
        <field name="res_model">resource.purchase.service.wzd</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="resource_purchase_service_wizard_view_form"/>
        <field name="target">new</field>
    </record>
</odoo>
