<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_income_statement_import_wizard" model="ir.ui.view">
        <field name="name">income.statement.import.wizard.form</field>
        <field name="model">income.statement.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Lines from Excel">
                <sheet>
                    <div class="oe_title">
                        <h1>Import Lines from Excel</h1>
                        <h2>
                            Summary: <field name="summary_id" readonly="1" class="oe_inline"/>
                        </h2>
                    </div>
                    <group>
                        <field name="excel_file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                        <field name="replace_existing"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <h4>Instructions:</h4>
                        <ul>
                            <li>Upload an Excel file (.xls format) exported from another Income Statement Summary</li>
                            <li>The file should contain columns: Sequence, Description, Technical Name, Formula, etc.</li>
                            <li>Check "Replace Existing Lines" to remove current lines before importing</li>
                            <li>Leave unchecked to add new lines to existing ones</li>
                            <li><strong>Note:</strong> Only .xls files are supported for import (not .xlsx)</li>
                        </ul>
                    </div>
                </sheet>
                <footer>
                    <button string="Import" name="import_lines" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>