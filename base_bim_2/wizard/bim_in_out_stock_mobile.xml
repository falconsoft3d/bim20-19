<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="bim_io_stock_mobile_form" model="ir.ui.view">
        <field name="name">bim.stock.mobile.wizard.form</field>
        <field name="model">bim.stock.mobile.wizard</field>
        <field name="arch" type="xml">
            <form string="Exit Mov.">
                <group>
                    <group>
                        <field name="type" widget="radio"/>
                    </group>
                    <group>
                        <field invisible="type == 'out'" name="location_id" options="{'no_open':True, 'no_quick_create': True, 'no_create_edit': True}" required="type == 'in'"/>
                        <field invisible="type == 'in'" name="project_id" options="{'no_open':True, 'no_quick_create': True, 'no_create_edit': True}" required="type == 'out'"/>
                        <field invisible="True" name="warehouse_id"/>
                        <field invisible="True" name="mobile_id"/>
                    </group>
                </group>
                <separator string="Lines with Materials to Move"/>
                <field name="bim_stock_lines" nolabel="1">
                    <list editable="bottom">
                        <field domain="[('type','!=','service'),('resource_type','in',['M'])]" name="product_id" options="{'no_open':True,'no_quick_create':True,'no_create_edit':True}"/>
                        <field name="qty_available"/>
                        <field name="qty_add"/>
                        <field optional="hide"  name="wizard_id"/>
                    </list></field>
                <footer>
                    <button class="btn-primary" name="action_load" string="Confirm" type="object"/>
                    <button class="btn-default" special="cancel" string="Cancel"/>
                </footer>
            </form></field>
    </record>
    <record id="bim_io_stock_mobile_action" model="ir.actions.act_window">
        <field name="name">Inbound and Outbound Movement Creation</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">bim.stock.mobile.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
