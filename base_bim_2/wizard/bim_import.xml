<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="bim_import_wizard_view_form" model="ir.ui.view">
        <field name="name">bim.import.wizard.view.form</field>
        <field name="model">bim.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Budget">
                <group name="main">
                    <group name="left">
                        <field invisible="True" name="filename"/>
                        <field name="version"/>
                        <field name="enconding"/>
                        <field filename="filename" invisible="version != '8.8'" name="excel_file" string="Excel File"/>
                        <field filename="filename" invisible="version != 'bc3'" name="excel_file" string="BC3 File"/>
                        <field filename="filename" invisible="version != 'ms_xml'" name="excel_file" string="Project File"/>
                        <field invisible="create_all_products == False" name="category_id" options='{"no_create": 1, "no_open": 1}'/>

                    </group>
                    <group name="right">
                        <field name="project_id" options="{'no_create': 1, 'no_open': 1}"/>
                        <field invisible="version not in ['bc3', '8.8']" name="create_all_products"/>
                        <field invisible="version not in ['bc3', '8.8'] or create_all_products == False" name="product_cost_or_price" required="version not in ['bc3', '8.8'] and create_all_products == True"/>
                        <field invisible="version not in ['bc3', '8.8'] or create_all_products == True" name="product_id" options="{'no_create': 1, 'no_open': 1}" required="version not in ['bc3', '8.8'] and create_all_products == False"/>
                        <field invisible="version != 'ms_xml'" name="import_stages"/>
                    </group>
                </group>
                <footer>
                    <button class="btn-secondary" name="cancel" special="cancel" string="Cancel"/>
                    <button class="btn-primary" name="import_data" string="Import" type="object"/>
                </footer>
            </form></field>
    </record>

    <record id="bim_import_wizard_action" model="ir.actions.act_window">
        <field name="name">Import Budget</field>
        <field name="res_model">bim.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!--  <menuitem action="bim_import_wizard_action" id="bim_import_wizard_menu" name="Import" parent="menu_bim_import_bc3" sequence="20"/> -->
    <record id="bim_import_temp_view_form" model="ir.ui.view">
        <field name="name">bim.import.temp.view.form</field>
        <field name="model">bim.import.temp</field>
        <field name="arch" type="xml">
            <form string="Import budget">
                <field invisible="True" name="state"/>
                <header>
                    <button invisible="state not in ['error']"
                            name="back_draft" string="Try again" type="object"/>
                    <button class="oe_highlight"
                            invisible="state not in ['to_execute','ongoing']"
                            name="action_import"
                            icon="fa-arrow-down"
                            string="Import" type="object"/>

                    <button
                            invisible="state not in ['done']"
                            name="action_to_execute"
                            icon="fa-arrow-down"
                            string="Regresar" type="object"/>



                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <widget bg_color="bg-danger" invisible="state != 'error'" name="web_ribbon" text="Error"/>
                    <widget bg_color="bg-warning" invisible="state != 'ongoing'" name="web_ribbon" text="Procesando"/>
                    <widget bg_color="bg-success" invisible="state != 'done'" name="web_ribbon" text="Hecho"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group name="main" readonly="state == 'done'">
                        <group name="left">
                            <field invisible="True" name="filename"/>
                            <field name="version" readonly="state == 'done'"/>
                            <field name="enconding" readonly="state == 'done'"/>
                            <field name="limit" readonly="state == 'done'"/>
                            <field name="update" readonly="state == 'done'" invisible="version != 'ms_xml'"/>
                            <field filename="filename" name="excel_file" readonly="state == 'done'"/>
                            <field invisible="create_all_products == False"  name="category_id" options='{"no_create": 1, "no_open": 1}'/>
                            <field name="default_uom_id" options="{'no_create': 1}" readonly="state == 'done'"/>
                        
                        </group>
                        <group name="right">
                            <field name="project_id"
                                   readonly="state == 'done'"
                                   options="{'no_create': 1, 'no_open': 1}"/>
                            <field name="budget_id"
                                   domain="[('project_id','=',project_id)]"
                                   readonly="state == 'done'"/>
                            
                            <field invisible="version not in ['bc3', '8.8']" name="create_all_products" readonly="state == 'done'"/>
                            <field invisible="version not in ['bc3', '8.8'] or create_all_products == False" name="product_cost_or_price" required="version not in ['bc3', '8.8'] and create_all_products == True"/>
                            <field invisible="version not in ['bc3', '8.8'] or create_all_products == True" name="product_id" readonly="state == 'done'" options="{'no_create': 1, 'no_open': 1}" required="version not in ['bc3', '8.8'] and create_all_products == False"/>
                            <field invisible="version != 'ms_xml'" name="import_stages"/>
                            
                            <field force_save="1" name="user_id" options="{'no_open': True}"/>
                            
                            <field name="company_id" invisible="True" options="{'no_create': 1, 'no_open': 1}"/>
                        </group>
                    </group>
                    <notebook>
                        <page invisible="state not in ['error']" name="error" string="Error">
                            <field name="error"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form></field>
    </record>
    <record id="bim_import_temp_view_tree" model="ir.ui.view">
        <field name="name">bim.import.temp.view.tree</field>
        <field name="model">bim.import.temp</field>
        <field name="arch" type="xml">
            <list decoration-danger="state=='error'" decoration-success="state=='done'">
                <field name="name"/>
                <field name="filename"/>
                <field name="project_id" optional="show"/>
                <field name="version" optional="show"/>
                <field name="create_all_products" optional="hide"/>
                <field name="product_id" optional="hide"/>
                <field name="user_id" optional="show"/>
                <field name="budget_id" optional="show"/>
                <field name="company_id" optional="hide"/>
                <field name="state"/>
            </list></field>
    </record>
    <record id="bim_import_temp_view_search" model="ir.ui.view">
        <field name="name">bim.import.temp.view.search</field>
        <field name="model">bim.import.temp</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="filename" string="File"/>
                <field name="project_id"/>
                <field name="version"/>
                <field name="user_id"/>
                <field name="budget_id"/>
                <field name="state"/>
                <filter domain="[('state', '=', 'to_execute')]" name="state_to_execute" string="To execute"/>
                <filter domain="[('state', '=', 'ongoing')]" name="state_ongoing" string="In process"/>
                <filter domain="[('state', '=', 'done')]" name="state_done" string="Done"/>
                <filter domain="[('state', '=', 'error')]" name="state_error" string="Error"/>
                <filter context="{'group_by': 'state'}" name="groupby_state" string="Status"/>
                <filter context="{'group_by': 'user_id'}" name="groupby_user" string="Responsable"/>
                <filter context="{'group_by': 'project_id'}" name="groupby_project" string="Project"/>
            </search></field>
    </record>
    <record id="bim_import_temp_action" model="ir.actions.act_window">
        <field name="name">Importation job</field>
        <field name="res_model">bim.import.temp</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_state_to_execute': 1, 'search_default_state_ongoing': 1, 'search_default_state_error': 1}</field>
    </record>

    <menuitem action="bim_import_temp_action" id="bim_import_temp_menu" name="Importation job" parent="menu_bim_import_bc3" sequence="10"/>

</odoo>
