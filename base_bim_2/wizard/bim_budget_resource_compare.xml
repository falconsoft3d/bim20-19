<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="bim_resource_compare_wizard_form" model="ir.ui.view">
        <field name="name">bim.resource.compare.wizard.form</field>
        <field name="model">bim.budget.resource.compare.wizard</field>
        <field name="arch" type="xml">
            <form string="Resource Balance">
                <group name="main">
                    <field name="budget_ids" invisible="True"/>
                    <group>
                        <field name="date_from"/>
                    </group>
                     <group>
                        <field name="date_to"/>
                    </group>
                </group>
                <footer>
                    <button string="Cancel" special="cancel" class="btn-default"/>
                    <button name="print_compare" string="Print" type="object" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="bim_resource_compare_wizard_action" model="ir.actions.act_window">
        <field name="name">Resource Balance</field>
        <field name="res_model">bim.budget.resource.compare.wizard</field>
        <field name="binding_model_id" ref="model_bim_budget"/>
        <field name="view_mode">form</field>
       <field name="target">new</field>
    </record>
</odoo>
