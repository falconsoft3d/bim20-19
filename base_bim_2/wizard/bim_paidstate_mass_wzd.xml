<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="bim_paidstate_mass_wzd" model="ir.ui.view">
            <field name="name">bim.paidstate.mass.wzd</field>
            <field name="model">bim.paidstate.mass</field>
            <field name="arch" type="xml">
                <form string="Mass billing of states">
                    <sheet>
                        <field name="paidstates_ids"/>
                        <footer>
                            <button string='Done' name="action_done" type="object" class="btn-primary"/>
                            <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_bim_paidstate_mass" model="ir.actions.act_window">
            <field name="name">Mass billing of states</field>
            <field name="res_model">bim.paidstate.mass</field>
            <field name="binding_model_id" ref="model_bim_paidstate"/>
            <field name="binding_view_types">list</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="bim_paidstate_mass_wzd"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>