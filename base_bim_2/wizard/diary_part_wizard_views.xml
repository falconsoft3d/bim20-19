<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="diary_part_wizard_from" model="ir.ui.view">
            <field name="name">diary.part.wizard.form</field>
            <field name="model">diary.part.wizard</field>
            <field name="arch" type="xml">
                <form string="Diary Part Wizard">
                    <group>
                        <group>
                            <field name="diary_part_id" readonly="1"/>
                            <field name="hr_employee_id"
                                   domain="[('id', 'in', hr_employee_ids)]"
                                   options='{"no_create": 1, "no_open": 1}'/>
                        </group>
                        <group>
                             <field name="hr_employee_ids"
                                    widget="many2many_tags"
                                    invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                    <page string="Employee" name="lines">
                        <field name="lines_ids"  nolabel="1">
                                <list editable="bottom"
                                      create="false"
                                      decoration-muted="hh == 0">
                                     <field name="bim_pcp_id"
                                            required="1"
                                            options='{"no_create": 1, "no_open": 1}'/>
                                     <field name="hh" required="1" sum="sum"/>
                                </list>
                        </field>
                    </page>
                    </notebook>

                    <footer>
                        <button class="btn-primary" name="action_done" string="Done" type="object"/>
                        <button class="btn-default" special="cancel" string="Cancel"/>
                    </footer>
                </form></field>
        </record>

        <record id="action_diary_part_wizard" model="ir.actions.act_window">
            <field name="name">Diary Part Wizard</field>
            <field name="res_model">diary.part.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="diary_part_wizard_from"/>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
