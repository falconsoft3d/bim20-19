<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="concept_from_database_wizard" model="ir.ui.view">
        <field name="name">concept.from.database.wizard</field>
        <field name="model">concept.from.database.wizard</field>
        <field name="arch" type="xml">
            <form string="Real Cost Report">
                <group>
                    <group>
                        <field invisible="True" name="budget_id"/>
                        <field name="price_type" required="1" widget="radio"/>
                    </group>
                    <group>
                        <field name="replace_concepts"/>
                        <field invisible="True" name="use_cost_list"/>
                        <field invisible="use_cost_list == False" name="budget_cost_list_id" options="{'no_create': True}"/>
                    </group>
                </group>
                <footer>
                    <button class="btn-primary" name="action_process_database" string="Process Concepts" type="object"/>
                    <button class="btn-default" special="cancel" string="Cancel"/>
                </footer>
            </form></field>
    </record>
    <record id="action_concept_from_database_wizard" model="ir.actions.act_window">
        <field name="name">Concepts From Database</field>
        <field name="res_model">concept.from.database.wizard</field>
        <field name="binding_model_id" ref="base_bim_2.model_bim_budget"/>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_view_types">form</field>
        <field name="context">{'default_budget_id': active_id}</field>
    </record>
</odoo>
