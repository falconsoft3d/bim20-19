<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="bim_stock_report_wizard_form" model="ir.ui.view">
        <field name="name">bim.stock.report.wizard.form</field>
        <field name="model">bim.stock.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Real Cost Report">
                <group>
                    <group>
                        <field invisible="True" name="project_id"/>
                        <field invisible="True" name="budget_ids"/>
                        <field name="display_type" required="1" widget="radio"/>
                        <field name="resource_all"/>
                    </group>
                    <group>
                        <field invisible="True" name="doc_type" required="1"/>
                        <field name="material"/>
                        <field name="equipment"/>
                        <field name="labor"/>
                        <field invisible="True" name="invoice"/>
                        <field invisible="True" name="attendance"/>
                        <field invisible="True" name="tools"/>
                        <field
                               name="date_beg"/>
                        <field
                               name="date_end"/>
                        <field name="user_id" invisible="1" />
                        <field name="create_date" invisible="1" />
                        <field name="currency_id" invisible="1" />
                    </group>
                </group>
                <footer>
                    <button class="btn-primary" name="print_xls" string="Print" type="object"/>
                    <button class="btn-default" special="cancel" string="Cancel"/>
                </footer>
            </form></field>
    </record>
    <record id="bim_stock_report_wizard_action" model="ir.actions.act_window">
        <field name="name">Real Cost Report</field>
        <field name="res_model">bim.stock.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    <record id="bim_stock_report_budget_action" model="ir.actions.act_window">
        <field name="name">Reporte de Salida</field>
        <field name="res_model">bim.stock.report.wizard</field>
        <field name="binding_model_id" ref="model_bim_budget"/>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
