<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="bim_delete_concept_wzd_form" model="ir.ui.view">
            <field name="name">bim.delete.concept.wzd</field>
            <field name="model">bim.delete.concept.wzd</field>
            <field name="arch" type="xml">
                <form string="Bim delete concept wzd">
                    <sheet>
                        <group>
                            <group>
                                <field name="budget_id"
                                       force_save="1"
                                       options='{"no_create": 1, "no_open": 1}'
                                       required="1"
                                />
                            </group>
                            <group>
                                <field name="product_id"
                                       options='{"no_create": 1, "no_open": 1}'
                                       required="1"/>
                            </group>
                        </group>
                        <footer>
                            <button string='Delete' name="action_delete_concept" type="object" class="btn-primary"/>
                            <button string="Cancel" class="btn-default" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_bim_delete_concept_wzd" model="ir.actions.act_window">
            <field name="name">Delete concept</field>
            <field name="res_model">bim.delete.concept.wzd</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="bim_delete_concept_wzd_form"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>