<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="bim_virtual_product_wizard_form" model="ir.ui.view">
        <field name="name">bim.virtual.product.wizard.form</field>
        <field name="model">bim.virtual.product.wizard</field>
        <field name="arch" type="xml">
            <form string="Virtual Product Wizard">
                <group name="main">
                    <group name="left">
                        <field name="name"/>
                        <field name="reference"/>

                        <field name="concept_id" invisible="True"/>
                    </group>
                    <group>
                        <field name="calc" widget="boolean_toggle"/>
                    </group>
                </group>

                <notebook>
                    <page string="Productos Virtuales" name="lines">
                        <field name="lines_ids"  nolabel="1">
                                <list editable="bottom"
                                      decoration-muted="qty == 0">
                                     <field name="name"
                                            required="1"
                                            options='{"no_create": 1, "no_open": 1}'/>
                                     <field name="reference" />
                                     <field name="pp"  widget="toggle_button" string="P"/>
                                     <field name="qty" required="1" sum="sum"/>

                                </list>
                        </field>
                    </page>
                    <page string="Consulta de Atributos" name="Attributes">
                        <field name="attribute_ids"  nolabel="1">
                                <list editable="bottom">
                                     <field name="name"
                                            options='{"no_create": 1, "no_open": 1}'
                                            domain="[('show', '=', True)]"
                                            required="1"
                                     />
                                     <field name="value_id"
                                            required="1"
                                            domain="[('attribute_id', '=', name)]"
                                            options='{"no_create": 1, "no_open": 1}'
                                     />
                                </list>
                        </field>
                    </page>
                </notebook>

                <footer>
                    <button string="Insert"
                            name="do_action"  type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-default"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="bim_virtual_product_wizard_action" model="ir.actions.act_window">
        <field name="name">Insert Virtual Product</field>
        <field name="res_model">bim.virtual.product.wizard</field>
        <field name="view_mode">form</field>
       <field name="target">new</field>
    </record>

</odoo>