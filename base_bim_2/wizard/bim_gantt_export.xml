<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- bim.gantt.export form view -->
    <record id="bim_gantt_export_view_form" model="ir.ui.view">
        <field name="name">bim.gantt.export.view.form</field>
        <field name="model">bim.gantt.export</field>
        <field name="arch" type="xml">
            <form string="Gantt Export">
                <group>
                    <group>
                        <field name="budget_id" invisible="True"/>
                        <field name="gantt_type" widget="radio"/>
                    </group>
                </group>
                <footer>
                    <button name="cancel" string="Cancel" special="cancel" class="btn-secondary"/>
                    <button name="print_xml" type="object" string="Export" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="bim_gantt_export_action" model="ir.actions.act_window">
        <field name="name">Export Gantt</field>
        <field name="res_model">bim.gantt.export</field>
        <field name="binding_model_id" ref="model_bim_budget"/>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_view_types">form</field>
        <field name="context">{'default_budget_id': active_id}</field>
    </record>

</odoo>
