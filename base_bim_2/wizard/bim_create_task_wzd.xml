<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="bim_create_task_view_form" model="ir.ui.view">
        <field name="name">bim.create.task.view.form</field>
        <field name="model">bim.create.task</field>
        <field name="arch" type="xml">
            <form string="Bim create task">
                <group>
                    <field name="budget_id" options="{'no_create': 1, 'no_open': 1}"/>
                    <field name="company_id" invisible="True"/>
                </group>
                <footer>
                    <button name="cancel" string="Cancel" special="cancel" class="btn-secondary"/>
                    <button name="create_task" string="Create" type="object" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="bim_budget_create_task_action" model="ir.actions.act_window">
        <field name="name">Create tasks</field>
        <field name="res_model">bim.create.task</field>
        <field name="binding_model_id" ref="model_bim_budget"/>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_view_types">form</field>
    </record>



</odoo>