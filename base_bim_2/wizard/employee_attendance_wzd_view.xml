<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="employee_attendance_wzd_from" model="ir.ui.view">
            <field name="name">employee.attendance.wzd.from</field>
            <field name="model">employee.attendance.wzd</field>
            <field name="arch" type="xml">
                <form string="Load Weekly Hours">
                    <group>
                        <group>
                            <field name="employee_id" readonly="1"/>
                            <field name="project_id" options="{'no_open': True, 'no_create': True}"/>
                            <field groups="base_bim_2.group_budget_concept_documents" name="budget_id" options="{'no_open': True, 'no_create': True}"/>
                            <field groups="base_bim_2.group_budget_concept_documents" name="concept_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="bim_extra_hour_id" options="{'no_open': True, 'no_create': True}"/>
                        </group>
                        <group>
                            <field name="date_attendance"/>
                            <field name="hour_start_job"/>
                            <field name="minute_start_job"/>
                            <field name="in_out"/>
                            <field invisible="in_out == False" name="working_hours" required="in_out == True"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" nolabel="1" placeholder="Description..."/>
                    </group>
                    <footer>
                        <button class="btn-primary" name="action_register_attendance" string="Register Attendance" type="object"/>
                        <button class="btn-default" special="cancel" string="Cancel"/>
                    </footer>
                </form></field>
        </record>
        <record id="action_employee_attendance" model="ir.actions.act_window">
            <field name="name">Employee Attendance</field>
            <field name="res_model">employee.attendance.wzd</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="employee_attendance_wzd_from"/>
            <field name="target">new</field>
        </record>
        <!-- view_employee_form_attendance removed: causes combined-view validation
             against stale inherited views already in the DB (version_id, plan_wizard_action).
             The "Register Attendance" action is accessible directly from the attendance menu. -->
    </data>
</odoo>
