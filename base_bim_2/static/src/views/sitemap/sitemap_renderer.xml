<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="base_bim_2.SitemapRenderer" t-inherit="sitemap_view.SitemapRenderer" t-inherit-mode="primary">
        <div t-ref="sidePanel">
            <SitemapContextmenu t-if="this.contextmenuState.item"
                t-on-click="() => this.contextmenuState.item = false"
                item="this.contextmenuState.item"
                position="this.contextmenuState.position"/>
        </div>
        <div t-ref="root">
            <div t-ref="measures" class="bim-sitemap-measures" t-if="this.measureState.record">
                <div class="card">
                    <div class="card-header d-flex" id="bimSitemapMeasuresHeader">
                        <button class="btn btn-link text-reset o_bim_measures_visible" type="button" t-on-click.stop.prevent="setMeasureOpen">
                            <i t-attf-class="fa fa-{{this.measureState.open ? 'check-' : ''}}square-o"/>
                        </button>
                        <button class="btn btn-link text-reset" type="button" data-bs-toggle="collapse" data-bs-target="#bimSitemapMeasures" aria-expanded="true" aria-controls="bimSitemapMeasures">
                            Measurement
                        </button>
                    </div>
                    <div id="bimSitemapMeasures" t-attf-class="collapse{{this.measureState.open ? ' show' : ''}}" aria-labelledby="bimSitemapMeasuresHeader" data-parent="#bimHierarchyMeasuresContainer">
                        <div class="card-body p-0 d-flex align-items-center">
                            <Field
                                id="'measuring_ids_0'"
                                name="'measuring_ids'"
                                context="this.measureState.context"
                                fieldInfo="this.measureState.fieldInfo"
                                record="this.measureState.record"/>
                        </div>
                        <div t-if="note" class="card-footer" t-out="note"/>
                    </div>
                </div>
            </div>
        </div>
    </t>

    <t t-name="base_bim_2.SitemapView.Buttons" t-inherit="web.ListView.Buttons" t-inherit-mode="primary">
        <div t-if="props.showButtons" position="after">
            <button t-if="budgetId" class="btn btn-primary" title="Back to budget" t-on-click="backHome">
                <i class="fa fa-home fa-fw"/>
            </button>
            <div t-if="budgetType" class="dropdown d-inline">
                <button class="btn btn-primary dropdown-toggle"
                    type="button" id="bim_budget_type_dropdown" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    Change type
                </button>
                <div class="dropdown-menu" aria-labelledby="bim_budget_type_dropdown">
                    <button t-attf-class="dropdown-item{{budgetType === 'budget' ? ' active' : ''}}" type="button" t-on-click="() => this.changeBudgetType('budget')">Budget</button>
                    <button t-attf-class="dropdown-item{{budgetType === 'certification' ? ' active' : ''}}" type="button" t-on-click="() => this.changeBudgetType('certification')">Certification</button>
                    <button t-attf-class="dropdown-item{{budgetType === 'execution' ? ' active' : ''}}" type="button" t-on-click="() => this.changeBudgetType('execution')">Execution</button>
                    <button t-attf-class="dropdown-item{{budgetType === 'gantt' ? ' active' : ''}}" type="button" t-on-click="() => this.changeBudgetType('gantt')">Programming</button>
                </div>
            </div>
        </div>
    </t>
</templates>
