<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <record id="development_security_rules_category" model="ir.module.category">
            <field name="name">Development</field>
            <field name="description">Bim Development Access Rules</field>
            <field name="sequence" eval="91"/>
    </record>

    <record id="group_development_products_user" model="res.groups">
            <field name="name">Development User</field>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="category_id" ref="development_security_rules_category"/>
            <field name="comment">User</field>
    </record>


    <record id="rule_multicompany_real_estate_development" model="ir.rule">
            <field name="name">Multi Company Real Estate Development</field>
            <field ref="model_real_estate_development" name="model_id"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id','in', company_ids)]</field>
            <field name="global" eval="1"/>
   </record>


</odoo>