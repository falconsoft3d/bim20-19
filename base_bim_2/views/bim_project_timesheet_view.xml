<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="bim_project_timesheet_form" model="ir.ui.view">
            <field name="name">bim.project.timesheet.form</field>
            <field name="model">bim.project.employee.timesheet</field>
            <field name="arch" type="xml">
                <form string="Time Sheet">
                    <header>
                        <button invisible="state not in ['draft','approved']" name="action_cancel" string="Cancel" type="object"/>
                        <button class="oe_highlight" invisible="state not in ['draft']" name="action_validate" string="Set to Validate" type="object"/>
                        <button class="oe_highlight" invisible="state not in ['ready']" name="action_approved" string="Set to Approved" type="object"/>
                        <button class="oe_highlight" invisible="state not in ['cancelled']" name="action_draft" string="Set to Draft" type="object"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" required="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="employee_id" options='{"no_create": 1, "no_open": 1, "no_create_edit":True}' readonly="state != 'draft'" required="1"/>
                                <field name="project_id" options='{"no_create": 1, "no_open": 1, "no_create_edit":True}' readonly="state != 'draft'" required="1"/>
                                <field name="partner_id" readonly="1"/>
                                <field domain="[('project_id','=',project_id),                                                ('state','not in',['done','cancelled'])                                                 ]" name="task_id" options='{"no_create": 1, "no_open": 1, "no_create_edit":True}' readonly="state != 'draft'"/>
                                <field name="budget_id" readonly="state != 'draft'"/>
                                <field name="concept_id" readonly="state != 'draft'"/>
                                <field name="date" readonly="state != 'draft'" required="1"/>
                                <field name="bim_extra_hour" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="total_hours" readonly="state != 'draft'" required="1"/>
                                <field name="work_cost" readonly="state != 'draft'"/>
                                <field name="work_price" readonly="state != 'draft'"/>
                                <field groups="base.group_multi_company" name="company_id"/>
                                <field invisible="True" name="company_id"/>
                                <field name="bim_massive_certification_by_line_id" readonly="1"/>
                                <field name="bim_project_employee_timesheet_summary" readonly="1"/>
                            </group>
                        </group>
                        <field name="comment" widget="html"/>
                    </sheet>
                    <chatter/>
                </form></field>
        </record>
        <record id="bim_obra_timesheet_filter" model="ir.ui.view">
            <field name="name">bim.project.timesheet.filter</field>
            <field name="model">bim.project.employee.timesheet</field>
            <field name="arch" type="xml">
                <search string="Search">
                    <field name="employee_id"/>
                    <field name="project_id"/>
                    <!--                    <field name="capitulo_id"/>-->
                    <group>
                        <filter context="{'group_by':'employee_id'}" name="group_by_employee_id" string="Employee"/>
                        <filter context="{'group_by':'project_id'}" name="group_by_project_id" string="Project"/>
                        <filter context="{'group_by':'partner_id'}" name="partner_id" string="Partner"/>
                        <separator/>
                        <filter context="{'group_by':'date'}" name="group_date" string="Date"/>
                    </group>
                </search></field>
        </record>
        <record id="bim_project_timesheet_tree" model="ir.ui.view">
            <field name="name">bim.project.timesheet.tree</field>
            <field name="model">bim.project.employee.timesheet</field>
            <field name="arch" type="xml">
                <list decoration-danger="state == 'draft'" decoration-muted="state == 'cancelled'" decoration-primary="state=='done'" delete="0">
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="date"/>
                    <field name="project_id"/>
                    <field name="partner_id"/>
                    <field name="budget_id" optional="show"/>
                    <field name="concept_id" optional="show"/>
                    <!--  <field name="capitulo_id"/>-->
                    <field name="task_id"/>
                    <!-- <field name="week_start"/> -->
                    <field name="bim_extra_hour" optional="show"/>
                    <field name="total_hours" sum="Total Hours"/>
                    <!-- <field name="total_extra_hours" sum="Total HE"/> -->
                    <field name="bim_massive_certification_by_line_id" readonly="1"/>
                    <field name="work_cost" sum="Total Cost"/>
                    <field name="work_price" sum="Total Price"/>
                    <!-- <field name="extra_work_cost" sum="Total Cost HE"/> -->
                    <field name="bim_project_employee_timesheet_summary"/>
                    <field name="state"/>
                </list></field>
        </record>
        <record id="action_bim_project_timesheet" model="ir.actions.act_window">
            <field name="name">Time sheet</field>
            <field name="res_model">bim.project.employee.timesheet</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create a new Project Employee!
                </p></field>
        </record>
        <menuitem action="action_bim_project_timesheet" groups="base_bim_2.group_employee_bim" id="menu_bim_project_timesheet" name="Timesheet employee" parent="base_bim_2.menu_bim_task" sequence="2"/>
    </data>
</odoo>
