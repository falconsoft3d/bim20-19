<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_real_equota_quota" model="ir.ui.view">
        <field name="name">view.form.real.equota.quota</field>
        <field name="model">real.estate.quota</field>
        <field name="arch" type="xml">
            <form string="Quota">
                <header>

                        <button class="oe_highlight" name="action_to_done" string="To Done" type="object"
                                invisible="state != 'draft'"/>

                        <button class="oe_highlight" name="action_to_draft" string="To Draft" type="object"
                                invisible="state in ('draft')"/>

                        <field name="state" widget="statusbar"/>
                    </header>
                <sheet>

                    <div class="oe_title">
                       <h1>
                           <field name="name"/>
                       </h1>
                    </div>
                    <group>
                             <group>
                                 <field name="partner_id"/>
                                 <field name="date"
                                    required="1"
                                 />
                                 <field name="amount"/>
                                 <field name="account_journal_id"
                                        required="1"
                                        domain="[('type', 'in', ('bank', 'cash'))]"/>
                                <field name="account_payment_ids" widget="many2many_tags"/>
                             </group>
                            <group>

                                <field name="real_state_sale_order_id"/>
                                <field name="currency_id"/>
                                <field name="company_id"/>
                                <field name="user_id"/>
                            </group>
                    </group>
                 </sheet>
            </form>
        </field>
    </record>

    <record id="view_tree_real_estate_quota" model="ir.ui.view">
        <field name="name">view.tree.real.estate.quota</field>
        <field name="model">real.estate.quota</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="account_journal_id"/>
                <field name="account_payment_ids"/>
                <field name="amount" sum="sum"/>
                <field name="currency_id"/>
                <field name="company_id"/>
                <field name="user_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_real_estate_quota" model="ir.actions.act_window">
        <field name="name">Quota</field>
        <field name="res_model">real.estate.quota</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new quota!
            </p>
        </field>
    </record>

    </data>


</odoo>