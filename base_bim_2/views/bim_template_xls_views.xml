<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bim_template_xls_form" model="ir.ui.view">
        <field name="name">bim.template.xls.form</field>
        <field name="model">bim.template.xls</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bim_template_xls_tree" model="ir.ui.view">
        <field name="name">bim.template.xls.tree</field>
        <field name="model">bim.template.xls</field>
        <field name="arch" type="xml">
           <list>
               <field name="name" />
               <field name="code" optional="show"/>
           </list>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_bim_template_xls">
        <field name="name">Bim Template Xls</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">bim.template.xls</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem action="action_bim_template_xls" id="bim_template_xls_menu" name="Bim Template Xls" parent="base_bim_2.menu_bim_import_concept" sequence="11"/>

</odoo>