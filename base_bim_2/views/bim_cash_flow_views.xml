<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_bim_cash_flow" model="ir.ui.view">
        <field name="name">view.form.bim.cash.flow</field>
        <field name="model">bim.cash.flow</field>
        <field name="arch" type="xml">
            <form string="Bim Cash Flow" delete="0" >
                <sheet>
                    <div class="oe_title">
                       <h1>
                           <field name="name"/>
                       </h1>
                    </div>
                    <group>
                         <group>
                            <field name="type"/>
                            <field name="budgeted"/>
                            <field name="real"/>
                            <field name="variation"/>
                            <field name="payments_ids" widget="many2many_tags"/>
                            <field name="real_state_sale_order_id" invisible="1"/>
                            <field name="date"/>
                            <field name="bim_cash_flow_category_id"/>
                            <field name="note"/>
                            <field name="bim_cash_flow_generator_id"
                                   options="{'no_create': True, 'no_edit': True}"/>
                        </group>
                        <group>
                            <field name="contact_id" options="{'no_create': True, 'no_edit': True}"/>
                            <field name="bim_project_id"
                                   options="{'no_create': True, 'no_edit': True}"/>
                            <field name="bim_budget_id"
                                   domain="[('project_id', '=', bim_project_id)]"
                                   options="{'no_create': True, 'no_edit': True}"/>
                            <field name="bim_concept_id"
                                   domain="[('budget_id', '=', bim_budget_id),('type', '=', 'departure')]"
                                   options="{'no_create': True, 'no_edit': True}"/>
                            <field name="bim_budget_stage_id"
                                   options="{'no_create': True, 'no_edit': True}"/>

                            <field name="company_id" options="{'no_create': True, 'no_edit': True}"/>
                            <field name="currency_id" options="{'no_create': True, 'no_edit': True}"/>
                            <field name="journal_id" options="{'no_create': True, 'no_edit': True}"/>

                        </group>
                    </group>
                 </sheet>
            </form>
        </field>
    </record>

    <record id="view_tree_bim_cash_flow" model="ir.ui.view">
        <field name="name">view.tree.bim.cash.flow</field>
        <field name="model">bim.cash.flow</field>
        <field name="arch" type="xml">
            <list decoration-primary="type == 'expense'">
                <field name="name"/>
                <field name="currency_id" optional="hide"/>
                <field name="date" optional="show"/>
                <field name="budgeted" optional="hide" widget="monetary" options="{'currency_field': 'currency_id'}"
                       sum="sum"
                />
                <field name="real"
                        widget="monetary" options="{'currency_field': 'currency_id'}"
                        sum="sum"
                        optional="hide"/>

                <field name="budgeted_signed"
                       widget="monetary" options="{'currency_field': 'currency_id'}"
                       sum="sum"
                       optional="show"/>

                <field name="real_signed"
                       widget="monetary" options="{'currency_field': 'currency_id'}"
                       sum="sum"
                       optional="show"/>

                <field name="variation"
                       widget="monetary" options="{'currency_field': 'currency_id'}"
                       sum="sum"
                       optional="show"/>

                <field name="variation_signed"
                       widget="monetary" options="{'currency_field': 'currency_id'}"
                       sum="sum"
                       optional="hide"/>

                <field name="note"/>
                <field name="contact_id" optional="show"/>
                <field name="bim_project_id" optional="show"/>
                <field name="bim_budget_id" optional="show"/>
                <field name="bim_concept_id"
                       optional="show"/>
                <field name="bim_budget_stage_id"
                       optional="show"/>
                <field name="journal_id" optional="show"/>
                <field name="bim_cash_flow_category_id" optional="hide"/>
                <field name="company_id" optional="show"/>
                <field name="bim_cash_flow_generator_id" optional="hide"/>

                <field name="type"/>

            </list>
        </field>
    </record>

     <record id="bim_cash_flow_view_pivot" model="ir.ui.view">
        <field name="name">bim.cash.flow.pivot</field>
        <field name="model">bim.cash.flow</field>
        <field name="arch" type="xml">
            <pivot string="Cash Flow">
               <field name="bim_project_id" type="row"/>
                <field name="type" type="col"/>
                <field name="budgeted" type="measure" operator="sum"/>
                <field name="real" type="measure" operator="sum"/>
                <field name="variation" type="measure" operator="sum"/>
            </pivot>
        </field>
     </record>


    <record id="action_bim_cash_flow" model="ir.actions.act_window">
        <field name="name">Cash Flow</field>
        <field name="res_model">bim.cash.flow</field>
        <field name="view_mode">list,form,pivot</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new checklist state!
            </p>
        </field>
    </record>


    </data>


</odoo>