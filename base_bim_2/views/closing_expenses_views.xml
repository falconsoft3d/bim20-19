<?xml version="1.0" encoding="UTF-8"?>
 <odoo>
    <data>
    <record id="view_form_closing_expenses" model="ir.ui.view">
         <field name="name">view.form.closing.expenses</field>
         <field name="model">closing.expenses</field>
         <field name="arch" type="xml">
            <form string="Closing Expenses">
              <header>

                   <button name="action_validate" string="Validate" type="object" invisible="state != 'draft'"/>
                   <button name="action_draft" string="To Draft" type="object" invisible="state == 'draft'"/>

                   <field name="state" widget="statusbar" />
              </header>
              <sheet>
                  <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                  </div>
                  <group>
                      <group>
                          <field name="project_ids" widget="many2many_tags" required="1" readonly="state != 'draft'"/>
                          <field name="date_closing"  readonly="state != 'draft'"  required="1"/>
                       </group>
                      <group>
                          <field name="user_id"  readonly="state != 'draft'" />
                          <field name="create_date" readonly="state != 'draft'"/>
                          <field name="company_id" readonly="state != 'draft'"/>
                       </group>
                  </group>
               </sheet>
                <chatter/>
            </form>
        </field>
    </record>

        <record id="view_tree_closing_expenses" model="ir.ui.view">
         <field name="name">view.tree.closing.expenses</field>
         <field name="model">closing.expenses</field>
         <field name="arch" type="xml">
            <list delete="0">
                <field name="name" optional="show"/>
                <field name="project_ids" widget="many2many_tags"/>
                <field name="date_closing" optional="show"/>
                <field name="company_id" optional="show"/>
                <field name="state" optional="show"/>
            </list>
        </field>
        </record>

        <record id="action_closing_expenses" model="ir.actions.act_window">
            <field name="name">Closing Expenses</field>
            <field name="res_model">closing.expenses</field>
            <field name="view_id" ref="view_tree_closing_expenses"/>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Create a new Closing Expenses!
              </p>
           </field>
        </record>

     </data>
</odoo>