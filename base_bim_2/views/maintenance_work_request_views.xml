<?xml version="1.0" encoding="UTF-8"?>
 <odoo>
      <record id="view_form_maintenance_work_request" model="ir.ui.view">
         <field name="name">view.form.maintenance.work.request</field>
         <field name="model">maintenance.work.request</field>
         <field name="arch" type="xml">
            <form>
              <header>
                  <button class="btn btn-primary"
                                   invisible="maintenance_task_id"
                                   name="create_work_order" string="Create Work Order" type="object"/>
                        <field name="state" widget="statusbar" options="{'clickable': '1'}" />
                    </header>

              <sheet>
                    <group>
                        <group>
                            <field name="name" required="1"/>
                            <field name="description" />
                            <field name="observation" widget="html"/>
                            <field name="maintenance_task_id"  widget="many2one" />
                            <field name="maintenance_location_id"/>
                            <field name="maintenance_part_id"/>
                            <field name="maintenance_category_1"/>
                            <field name="maintenance_category_2"/>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="priority"/>
                            <field name="maintenance_asset_id"/>
                            <field name="requested_by"/>
                            <field name="requested_email"/>
                            <field name="reference"/>
                            <field name="company_id"/>
                        </group>
                    </group>
               </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tree_maintenance_work_request" model="ir.ui.view">
         <field name="name">view.tree.maintenance.work.request</field>
         <field name="model">maintenance.work.request</field>
         <field name="arch" type="xml">
             <list>
                <field name="name" required="1"/>
                 <field name="description" optional="show"/>
                <field name="maintenance_task_id" optional="show"/>
                <field name="date" optional="show"/>
                <field name="priority" optional="show"/>

                <field name="maintenance_location_id" optional="show"/>
                <field name="maintenance_part_id" optional="show"/>
                <field name="maintenance_category_1" optional="show"/>
                <field name="maintenance_category_2" optional="show"/>
                <field name="maintenance_asset_id" optional="show"/>
                <field name="requested_by" optional="show"/>
                <field name="requested_email" optional="show"/>
                <field name="company_id" optional="show"/>
                <field name="partner_id" optional="show"/>
                <field name="user_id" optional="show"/>
                <field name="reference" optional="show"/>
            </list>
        </field>
    </record>

    <record id="action_maintenance_work_request" model="ir.actions.act_window">
        <field name="name">Work Request</field>
        <field name="res_model">maintenance.work.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>