<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="bi_week_view_tree" model="ir.ui.view">
            <field name="name">bi.week.view.tree</field>
            <field name="model">bi.week</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </list>
            </field>
        </record>

        <record id="bi_week_view_form" model="ir.ui.view">
            <field name="name">bi.week.view.form</field>
            <field name="model">bi.week</field>
            <field name="arch" type="xml">
                <form string="Bi Week">
                    <sheet>
                     <group>
                            <group>
                                <field name="name" required="1"/>
                            </group>
                            <group>
                                <field name="date_from" required="1"/>
                                <field name="date_to" required="1"/>
                            </group>
                     </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="bi_week_action" model="ir.actions.act_window">
            <field name="name">Bi Week</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">bi.week</field>
            <field name="view_mode">list,form</field>
        </record>

         <menuitem action="bi_week_action"
                   id="submenu_bi_week" name="Bi Weeks"
                   parent="menu_employee" sequence="1"/>
    </data>
</odoo>