<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_form_hr_attendance_mass_summary" model="ir.ui.view">
        <field name="name">view.form.hr.attendance.mass.summary</field>
        <field name="model">hr.attendance.mass.summary</field>
        <field name="arch" type="xml">
            <form delete="0" string="Report">
                <header>
                    <button class="oe_highlight" confirm="Are you sure you want to set to done?" invisible="state not in ['draft']" name="action_load" string="Load" type="object"/>
                    <button invisible="state not in ['draft']" name="action_clear_line" string="Clear lines" type="object"/>
                    <button confirm="Are you sure you want to set to draft?" invisible="state not in ['cancel']" name="action_draft" string="Set to Draft" type="object"/>
                    <button class="oe_highlight" confirm="Are you sure you want to set to approve?" invisible="state not in ['done']" name="action_approve" string="Set to approved" type="object"/>
                    <button class="oe_highlight" confirm="Are you sure you want to create invoice?" invisible="state not in ['approved']" name="action_create_invoice" string="Create invoice" type="object"/>
                    <button invisible="state not in ['draft','done']" name="action_send_email" string="Send by Email" type="object"/>
                    <button confirm="Are you sure you want to cancel?" invisible="state not in ['draft','done','approved']" name="action_cancel" string="Cancel" type="object"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-check" invisible="attendance_count == 0" name="action_view_attendances" string="Attendances" type="object">
                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_value">
                                    <field name="attendance_count" nolabel="1" widget="statinfo"/>
                                </span>
                                <span class="o_stat_text">
                                    Attendances
                                </span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="customer_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="invoice_id"/>
                        </group>
                        <group>
                            <field name="total_hours" readonly="1"/>
                            <field name="total_price" readonly="1"/>
                            <field name="date_create" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                    </group>
                    <field name="attendance_line_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="employee_id" options="{'no_open': True, 'no_create': True}" widget="many2one_avatar_user"/>
                            <field name="customer_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="employee_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="check_in"/>
                            <field name="check_out"/>
                            <field name="worked_hours" sum="sum"/>
                            <field name="price" sum="sum"/>
                            <field name="total" sum="sum"/>
                        </list></field>
                </sheet>
                <chatter/>
            </form></field>
    </record>
    <record id="view_tree_hr_attendance_mass_summary" model="ir.ui.view">
        <field name="name">view.tree.hr.attendance.mass.summary</field>
        <field name="model">hr.attendance.mass.summary</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'draft'" decoration-muted="state == 'cancel'" decoration-primary="state=='approved'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="customer_id"/>
                <field name="invoice_id"/>
                <field name="date_create"/>
                <field name="total_hours" sum="sum"/>
                <field name="total_price" sum="sum"/>
                <field name="state"/>
            </list></field>
    </record>
    <record id="action_hr_attendance_mass_summary" model="ir.actions.act_window">
        <field name="name">Attendance summary</field>
        <field name="res_model">hr.attendance.mass.summary</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new attendance massive summary!
            </p></field>
    </record>
    <record id="actions_server_attendance_mass_summary_confirm" model="ir.actions.server">
        <field name="name">Approve Attendance</field>
        <field name="model_id" ref="base_bim_2.model_hr_attendance_mass_summary"/>
        <field name="binding_model_id" ref="base_bim_2.model_hr_attendance_mass_summary"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_approve()</field>
    </record>
</odoo>
