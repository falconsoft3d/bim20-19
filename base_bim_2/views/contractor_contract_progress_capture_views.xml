<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_contractor_contract_progress_capture" model="ir.ui.view">
        <field name="name">view.form.contractor.contract.progress.capture</field>
        <field name="model">contractor.contract.progress.capture</field>
        <field name="arch" type="xml">
            <form string="Progress Capture" delete="0" >
                <header>
                        <button class="oe_highlight" invisible="state not in ['draft']" name="to_load" string="Load" type="object"/>
                        <button class="oe_highlight" invisible="state not in ['loaded']" name="to_approved" string="To approve" type="object"/>
                        <button class="oe_highlight" invisible="state not in ['approved','certificate']" name="to_done" string="Done" type="object"/>
                        <button class="oe_highlight" invisible="state not in ['done']" name="to_certify" string="Certify" type="object"/>

                         <button invisible="state not in ['done','loaded','done']" name="to_draft" string="Draft" type="object"/>

                        <field name="state" widget="statusbar"/>
                    </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-home" name="action_view_certifications" string="Certifications" type="object">
                            <field name="count_certifications" string="Certifications" widget="statinfo"/>
                        </button>
                    </div>

                    <div class="oe_title">
                       <h1>
                           <field name="name"/>
                       </h1>
                    </div>
                    <group>
                         <group>
                             <field name="partner_id"  readonly="state not in ['draft']"/>
                             <field name="contractor_contract_id"
                                    domain="[('partner_id', '=', partner_id)]"
                                    readonly="state not in ['draft']"/>
                             <field name="date" readonly="state not in ['draft']"/>
                             <field name="create_oc" />
                             <field name="purchase_order_id"
                                    invisible="not purchase_order_id"
                                    readonly="1"/>
                        </group>
                        <group>
                            <field name="total"/>
                            <field name="currency_id" readonly="state not in ['draft']"/>
                            <field name="company_id" readonly="state not in ['draft']"/>
                            <field name="user_id" readonly="state not in ['draft']"/>
                        </group>
                    </group>



                    <notebook>

                        <page name="line_ids" string="Lines">
                            <field name="line_ids" widget="one2many_list" readonly="state in ['done']">
                                <list editable="bottom">
                                    <field name="project_id"
                                           optional="show"
                                           widget="many2onebutton"/>
                                    <field name="budget_id"
                                           optional="show"
                                           widget="many2onebutton"
                                           options='{"no_create": true}'
                                           domain="[('project_id', '=', project_id)]" />
                                    <field name="concept_id"
                                           optional="show"
                                           widget="many2onebutton"
                                           options='{"no_create": true}'
                                           domain="[
                                                    ('budget_id', '=', budget_id),
                                                    ('type', '=', 'departure'),
                                           ]" />
                                     <field name="bim_pcp_id"
                                           optional="show"
                                           options='{"no_create": true}'/>
                                     <field name="qty_budget" sum="sum" optional="show"/>
                                     <field name="qty_last" sum="sum" optional="show"/>
                                     <field name="qty" sum="sum" optional="show"/>
                                     <field name="qty_accumulated" sum="sum" optional="show"/>
                                     <field name="price_unit" optional="show"/>
                                     <field name="amount" sum="sum" optional="show"/>
                                </list>
                            </field>
                        </page>

                    </notebook>


                 </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tree_contractor_contract_progress_capture" model="ir.ui.view">
        <field name="name">view.tree.contractor.contract.progress.capture</field>
        <field name="model">contractor.contract.progress.capture</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="purchase_order_id" readonly="1"/>
                <field name="currency_id" optional="hide"/>
                <field name="company_id" optional="hide"/>
                <field name="user_id" optional="hide"/>
                <field name="partner_id"  optional="show"/>
                <field name="contractor_contract_id" optional="show"/>
                <field name="total" sum="sum"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_contractor_contract_progress_capture" model="ir.actions.act_window">
        <field name="name">Progress Capture</field>
        <field name="res_model">contractor.contract.progress.capture</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new Contractor Contract Generator!
            </p>
        </field>
    </record>
    </data>
</odoo>