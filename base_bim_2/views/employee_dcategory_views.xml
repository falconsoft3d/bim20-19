<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_employee_dcategory" model="ir.ui.view">
        <field name="name">view.form.employee.dcategory</field>
        <field name="model">employee.dcategory</field>
        <field name="arch" type="xml">
            <form string="Employee Category">
                <header>
                </header>
                <sheet>
                    <div class="oe_title">
                       <h1>
                           <field name="name" />
                       </h1>
                    </div>
                    <group>
                         <group>
                             <field name="tag_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="company_id" />
                        </group>
                    </group>
                 </sheet>

                <chatter/>

            </form>
        </field>
    </record>

    <record id="view_tree_employee_dcategory" model="ir.ui.view">
        <field name="name">view.tree.employee.dcategory</field>
        <field name="model">employee.dcategory</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="tag_ids" widget="many2many_tags" options="{'no_create': True, 'no_edit': True}"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>



    <record id="action_employee_dcategory" model="ir.actions.act_window">
        <field name="name">Category</field>
        <field name="res_model">employee.dcategory</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new employee documentation!
            </p>
        </field>
    </record>

    <!-- Solo muestra los gastos del usuario logueado -->
    <record id="action_my_employee_dcategory" model="ir.actions.act_window">
        <field name="name">Category</field>
        <field name="res_model">employee.dcategory</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new category!
            </p>
        </field>
    </record>


    </data>
</odoo>