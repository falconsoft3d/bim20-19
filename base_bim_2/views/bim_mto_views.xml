<?xml version="1.0" encoding="UTF-8"?>
 <odoo>
      <record id="view_form_bim_mto" model="ir.ui.view">
         <field name="name">view.form.bim.mto</field>
         <field name="model">bim.mto</field>
         <field name="arch" type="xml">
            <form>
                <header>
                      <button name="to_review"
                              invisible="state != 'draft'"
                              class="oe_highlight"
                              string="To review" type="object"/>

                     <button name="released_for_production"
                              class="oe_highlight"
                              invisible="state != 'revision'"
                              string="Released for production" type="object"/>

                    <button name="to_done"
                              class="oe_highlight"
                              invisible="state != 'released_for_production'"
                              string="To Done" type="object"/>

                    <button name="to_draft"
                              invisible="state == 'draft'"
                              string="To Draft" type="object"/>

                      <field name="state" widget="statusbar"/>
                  </header>
              <sheet>


                  <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                   </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="customer_id"/>
                            <field name="budget_id"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="reviewed_by"/>
                            <field name="company_id"/>
                        </group>
                    </group>

                  <notebook>
                      <page name="lines_ids" string="Lines">
                            <field name="lines_ids" widget="one2many_list">
                                <list editable="bottom">
                                    <field name="dwg"/>
                                    <field name="revision_number"/>
                                    <field name="element_id"
                                            optional="show"
                                           widget="many2onebutton"
                                           options='{"no_create": true}'
                                           />

                                    <field name="qty"
                                           optional="show"
                                           sum="sum"/>

                                    <field name="thickness" optional="show" />
                                    <field name="length" optional="show" />
                                    <field name="width" optional="show" />
                                    <field name="unit_weight" optional="show" />

                                    <field name="material_id"
                                           optional="show"
                                           />

                                    <field name="uom_id"
                                           optional="hide"
                                           widget="many2onebutton"
                                           options='{"no_create": true}'/>

                                    <field name="budget_id"
                                           widget="many2onebutton"
                                           optional="hide"
                                           options='{"no_create": true}'/>

                                    <field name="bim_concepts_id"
                                            optional="show"
                                           widget="many2onebutton"
                                           options='{"no_create": true}'
                                           domain="[
                                                    ('budget_id', '=', budget_id),
                                                    ('type', '=', 'departure'),
                                           ]" />




                                    <field name="bim_concept_template_group_id"
                                            optional="show"
                                            widget="many2onebutton" options='{"no_create": true}'/>


                                    <field name="name"
                                           optional="hide"
                                    />

                                    <field name="note"
                                           optional="hide"
                                    />


                                </list>
                            </field>
                        </page>


                      <page string="Text">
                           <field name="observation" placeholder="Observation..."/>
                      </page>
                  </notebook>

               </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tree_bim_mto" model="ir.ui.view">
         <field name="name">view.tree.bim.mto</field>
         <field name="model">bim.mto</field>
         <field name="arch" type="xml">
             <list>
                 <field name="name"/>
                 <field name="project_id"/>
                 <field name="customer_id"/>
                 <field name="budget_id"/>
                 <field name="user_id"/>
                 <field name="company_id"/>
                 <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_bim_mto" model="ir.actions.act_window">
        <field name="name">Bim MTO</field>
        <field name="res_model">bim.mto</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>