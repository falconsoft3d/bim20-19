<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_form_bim_update" model="ir.ui.view">
            <field name="name">view.form.bim.update</field>
            <field name="model">bim.update</field>
            <field name="arch" type="xml">
                <form string="Bim Update" create="0" delete="0" edit="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" required="1"/>
                                <field name="type" required="1"/>
                                <field name="developed" required="1"/>
                            </group>
                            <group>
                                <field name="date" required="1"/>
                                <field name="sequence" required="1"/>
                            </group>
                        </group>
                        <field name="description" required="1"/>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tree_bim_update" model="ir.ui.view">
            <field name="name">view.tree.bim.update</field>
            <field name="model">bim.update</field>
            <field name="arch" type="xml">
                <list create="0" delete="0" edit="0">
                    <field name="sequence" optional="show"/>
                    <field name="name" optional="show"/>
                    <field name="date" optional="show"/>
                    <field name="type" optional="show"/>
                    <field name="description" optional="show"/>
                    <field name="developed" optional="show"/>
                </list>
            </field>
        </record>

        <record id="action_bim_update" model="ir.actions.act_window">
            <field name="name">Updates</field>
            <field name="res_model">bim.update</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create a new Update!
                </p>
            </field>
        </record>

    </data>
</odoo>