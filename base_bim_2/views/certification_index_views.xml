<?xml version="1.0" encoding="UTF-8"?>
<odoo>

        <record id="view_form_certification_index" model="ir.ui.view">
            <field name="name">view.form.certification.index</field>
            <field name="model">certification.index</field>
            <field name="arch" type="xml">
                <form string="Certification Index">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" required="1"/>
                                <field name="index" required="1"/>
                            </group>
                            <group>
                                <field name="budget_id" required="1"/>
                                <field name="value" required="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tree_certification_index" model="ir.ui.view">
            <field name="name">view.tree.certification.index</field>
            <field name="model">certification.index</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="budget_id"/>
                    <field name="index" sum="sum"/>
                    <field name="value" sum="sum"/>
                </list>
            </field>
        </record>

        <record id="action_certification_index" model="ir.actions.act_window">
            <field name="name">Certification Index</field>
            <field name="res_model">certification.index</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create a new Certification Index!
                </p>
            </field>
        </record>


</odoo>