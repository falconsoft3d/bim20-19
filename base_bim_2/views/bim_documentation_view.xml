<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_form_bim_documentation" model="ir.ui.view">
            <field name="name">view.form.bim.documentation</field>
            <field name="model">bim.documentation</field>
            <field name="arch" type="xml">
                <form string="Documents">
                    <header>
                        <button name="print_document_notes" string="Print Notes" type="object"/>
                        <field name="costumer_state" widget="statusbar" />
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <group string="General">
                                <field name="code_doc"/>
                                <field name="desc" required="1"/>
                                <field name="rev" required="1"/>
                                <field name="bim_documentation_format_id" options='{"no_create": 1, "no_open": 1}'/>
                                <field name="producer_by_id" options='{"no_create": 1, "no_open": 1}'/>
                                <field name="producer_date"/>
                                <field name="partner_id" options='{"no_create": 1, "no_open": 1}'/>
                                <field name="state"/>
                                <field name="punctuation"/>
                            </group>
                            <group string="Document">


                                <field name="share" widget="boolean_toggle"/>
                                <field invisible="share == False" name="share_url" widget="url"/>

                                <field invisible="share == False" name="number_open"/>
                                <field invisible="share == False" name="open_date" readonly="1"/>
                                <field filename="file_name" name="file_01"/>
                                <field name="url" widget="url" string="URL para compartir"/>


                                <field invisible="True" name="file_name"/>
                                <field name="specialty_id" options='{"no_create": 1, "no_open": 1}'/>
                                <field name="project_id" options='{"no_create": 1, "no_open": 1}'/>
                                <field domain="[('project_id','=',project_id)]" invisible="project_id == False"
                                       name="budget_id" options='{"no_create": 1, "no_open": 1}'/>
                                <field domain="[('budget_id','=',budget_id)]" invisible="budget_id == False" name="bim_concepts" options='{"no_create": 1, "no_open": 1}'/>
                                <field invisible="bim_concepts == False" name="budget_cost"/>
                                <field name="real_cost"/>
                                <field name="benefit"/>
                                <field name="type"/>
                                <field name="delivery_date"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Note">
                                <field name="obs" widget="html"/>
                            </page>
                            <page string="Reviews">
                                <field name="lines_ids"><list decoration-danger="state == 'draft'" decoration-success="state == 'approved'" editable="bottom" string="Reviews">
                                        <field name="name" options='{"no_create": 1, "no_open": 1}' required="1"/>
                                        <field name="date" required="1"/>
                                        <field name="state" required="1"/>
                                        <field name="obs"/>
                                        <field name="punctuation"/>
                                    </list></field>
                            </page>
                            <page string="Partner Obs">
                                <field name="partner_obs"/>
                            </page>
                            <page string="Public Obs">
                                <field name="public_obs"/>
                            </page>
                            <page string="Other Info">
                                <group>
                                    <group>
                                        <field name="amount"/>
                                        <field name="balance" string="Balance"/>
                                        <field name="pending"/>
                                        <field name="chat_bim_id" options='{"no_create": 1, "no_open": 1}'/>
                                    </group>
                                    <group>
                                        <field name="date"/>
                                        <field name="expiration_date"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Other">
                                <group>
                                    <field name="user_id" readonly="1"/>
                                    <field name="company_id" readonly="1"/>
                                    <field name="key"/>
                                    <field name="punctuation"/>
                                    <field name="maintenance_task_id"/>
                                    <field name="url_file" invisible="share == False" widget="url" readonly="1"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form></field>
        </record>
        <record id="view_tree_bim_documentation" model="ir.ui.view">
            <field name="name">view.tree.bim.documentation</field>
            <field name="model">bim.documentation</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" string="Seq."/>
                    <field name="specialty_id" optional="show"/>
                    <field name="code_doc" optional="show"/>
                    <field name="desc" optional="show"/>
                    <field name="bim_documentation_format_id" optional="hide"/>
                    <field name="producer_by_id" optional="hide"/>
                    <field name="producer_date" optional="hide"/>
                    <field name="url" optional="hide" widget="url"/>
                    <field name="user_id" optional="hide"/>
                    <field name="project_id" optional="show"/>
                    <field name="budget_id" optional="hide"/>
                    <field name="bim_concepts" optional="hide"/>
                    <field name="amount" optional="hide" sum="sum"/>
                    <field name="balance" optional="hide" sum="sum"/>
                    <field name="pending" optional="hide" sum="sum"/>
                    <field name="date" optional="show"/>
                    <field name="expiration_date" optional="hide"/>
                    <field name="type" optional="show"/>
                    <field name="company_id" optional="hide"/>
                    <field name="partner_id" optional="hide"/>
                    <field name="delivery_date" optional="hide"/>
                    <field name="open_date" optional="hide"/>
                    <field name="budget_cost" optional="show" sum="sum"/>
                    <field name="real_cost" optional="show" sum="sum"/>
                    <field name="benefit" optional="show" sum="sum"/>
                    <field name="share" optional="hide" widget="boolean_toggle"/>
                    <field name="punctuation" optional="hide"/>
                    <field name="state" optional="show"/>
                </list></field>
        </record>
        <record id="action_bim_documentation" model="ir.actions.act_window">
            <field name="name">Documents</field>
            <field name="res_model">bim.documentation</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create a new document!
                </p></field>
        </record>

        <menuitem id="menu_bim_documentation_categ" name="Documentation" parent="base_bim_2.main_base_menu_bim" sequence="20">
            <menuitem id="menu_bim_documentation2" name="Document" sequence="1">
                <menuitem action="action_bim_documentation" id="menu_bim_documentation3" name="Document" sequence="1"/>
            </menuitem>

            <menuitem id="menu_bim_mkt" name="Forms"
                  groups="base_bim_2.group_bim_mkt"
                  sequence="2">
                <menuitem id="menu_bim_mkt_camp" name="Campaign"  sequence="1" action="action_bim_marketing_campaign" />
            </menuitem>


            <menuitem id="menu_bim_task" name="Tasks" sequence="20" >
                <menuitem action="action_bim_task" id="menu_bim_task_action" name="Tasks" sequence="1"/>
                <menuitem action="action_bim_project_employee_timesheet_summary" id="menu_bim_project_employee_timesheet_summary"
                           name="Timesheet summary" sequence="3"/>
            </menuitem>

        </menuitem>


    </data>
</odoo>
