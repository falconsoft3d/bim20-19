<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_form_bim_client_hour" model="ir.ui.view">
        <field name="name">view.form.bim.client.hour</field>
        <field name="model">bim.client.hour</field>
        <field name="arch" type="xml">
            <form string="Client hour" delete="0" >
                <sheet>
                    <div class="oe_title">
                       <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                       <group>
                            <field name="partner_id"/>
                       </group>
                        <group>
                            <field name="price"/>
                       </group>
                    </group>

                    <field name="lines_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="name"  widget="many2one_avatar_user" options="{'no_open': True, 'no_create': True}"/>
                            <field name="bim_extra_hour_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="price" />
                        </list>
                    </field>


                 </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tree_bim_client_hour" model="ir.ui.view">
        <field name="name">bim.client.hour</field>
        <field name="model">bim.client.hour</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="price"/>
            </list>
        </field>
    </record>

    <record id="action_bim_client_hour" model="ir.actions.act_window">
        <field name="name">Bim client hour</field>
        <field name="res_model">bim.client.hour</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new hour!
            </p>
        </field>
    </record>


</odoo>