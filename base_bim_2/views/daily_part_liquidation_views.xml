<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="daily_part_liquidation_view_tree" model="ir.ui.view">
            <field name="name">daily.part.liquidation.view.tree</field>
            <field name="model">daily.part.liquidation</field>
            <field name="arch" type="xml">
                <list decoration-danger="state == 'draft'" decoration-muted="state == 'cancel'">
                    <field name="name"/>
                    <field name="user_id" optional="show"/>
                    <field name="project_id" optional="show"/>
                    <field name="budget_id" optional="show"/>
                    <field name="create_date" optional="show"/>
                    <field name="company_id" optional="show"/>
                    <field name="stage_id" optional="show"/>
                    <field name="state" optional="show"/>
                </list></field>
        </record>

        <record id="daily_part_liquidation_view_form" model="ir.ui.view">
            <field name="name">daily.part.liquidation.view.form</field>
            <field name="model">daily.part.liquidation</field>
            <field name="arch" type="xml">
                <form string="Cost Settlement">
                    <header>

                        <button class="oe_highlight" invisible="state not in ['draft']" name="action_read" string="Read" type="object"/>

                        <button confirm="Are you sure you want to set this survey to draft?"
                                invisible="state in ['draft']"
                                name="action_draft" string="Draft" type="object"/>


                        <button class="oe_highlight" invisible="state not in ['read']" name="action_done" string="To Done" type="object"/>

                         <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="project_id"
                                       options='{"no_create": 1}'
                                       readonly="state in 'done'"
                                       widget="many2one"/>
                                <field domain="[('project_id','=',project_id)]"
                                       name="budget_id" options='{"no_create": 1}'
                                       readonly="state in 'done'"
                                       widget="many2one"/>

                                <field name="diary_part_ids"
                                       widget="many2many_tags"
                                       domain="[('project_id','=',project_id),
                                                ('budget_id','=',budget_id),
                                                ('state','=','done'),
                                                ('daily_part_liquidation_id','=',False)]"  options='{"no_create": 1}'
                                       readonly="state in 'done'"/>
                            </group>
                            <group>
                                <field name="user_id" readonly="state in 'done'"/>
                                <field name="create_date" readonly="state in 'done'"/>
                                <field name="company_id" readonly="state in 'done'"/>
                                <field name="stage_id"
                                       readonly="state in 'done'"
                                       domain="[('budget_id','=',budget_id)]"/>
                            </group>
                        </group>


                        <notebook>
                            <page name="lines" string="Lines">
                                <field name="line_ids" nolabel="1" readonly="state in 'done'">
                                    <list editable="bottom">
                                        <field name="budget_id" optional="hide"/>
                                        <field name="bim_pcp_id" optional="show"/>
                                        <field name="concepts_id"
                                               domain="[
                                                             ('budget_id','=', budget_id),
                                                             ('type', '=' , 'departure'),
                                                            ]"
                                               optional="show"/>
                                        <field name="qty" optional="show" sum="sum"/>
                                        <field name="qty_certif" optional="show" sum="sum"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                        -
                    </sheet>
                    <chatter/>
                </form></field>
        </record>

        <record id="daily_part_liquidation_action" model="ir.actions.act_window">
            <field name="name">Daily Part Liquidation</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">daily.part.liquidation</field>
            <field name="view_mode">list,form</field>
        </record>



    </data>
</odoo>