<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_bim_server" model="ir.ui.view">
        <field name="name">view.form.bim.server</field>
        <field name="model">bim.server</field>
        <field name="arch" type="xml">
            <form string="Server" delete="0" >
                <header>
                        <button name="create_token" string="Create Token" type="object"/>
                 </header>
                <sheet>
                    <div class="oe_title">
                       <h1>
                           <field name="name"/>
                       </h1>
                    </div>
                    <group>

                        <group>
                            <field name="url"/>
                            <field name="client_id"/>
                            <field name="client_secret" password="1"/>
                            <field name="date_token" readonly="1"/>
                            <field name="date_expiration" readonly="1"/>
                            <field name="save_model"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="token" readonly="1"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                 </sheet>
            </form>
        </field>
    </record>

    <record id="view_tree_bim_server" model="ir.ui.view">
        <field name="name">view.tree.bim.server</field>
        <field name="model">bim.server</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="client_id"/>
                <field name="date_token"/>
                <field name="date_expiration"/>
                <field name="user_id"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="action_bim_server" model="ir.actions.act_window">
        <field name="name">Bim Server</field>
        <field name="res_model">bim.server</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new bim server!
            </p>
        </field>
    </record>

    </data>

</odoo>