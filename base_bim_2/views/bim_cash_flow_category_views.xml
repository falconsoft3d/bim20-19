<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_bim_cash_flow_category" model="ir.ui.view">
        <field name="name">view.form.bim.cash.flow.category</field>
        <field name="model">bim.cash.flow.category</field>
        <field name="arch" type="xml">
            <form string="Bim Cash Flow Category" delete="0" >
                <sheet>
                    <group>
                         <group>
                            <field name="name"/>
                        </group>
                            <field name="company_id"/>
                        <group>
                        </group>
                    </group>
                 </sheet>
            </form>
        </field>
    </record>

    <record id="view_tree_bim_cash_flow_category" model="ir.ui.view">
        <field name="name">view.tree.bim.cash.flow.category</field>
        <field name="model">bim.cash.flow.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>



    <record id="action_bim_cash_flow_category" model="ir.actions.act_window">
        <field name="name">Cash Flow Category</field>
        <field name="res_model">bim.cash.flow.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new Cash Flow Category!
            </p>
        </field>
    </record>

    </data>
</odoo>