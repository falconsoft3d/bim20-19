<?xml version="1.0" encoding="UTF-8"?>
 <odoo>
      <record id="view_form_maintenance_type_task" model="ir.ui.view">
         <field name="name">view.form.maintenance.type.task</field>
         <field name="model">maintenance.type.task</field>
         <field name="arch" type="xml">
            <form>
              <sheet>
                    <group>
                        <group>
                            <field name="name" required="1"/>
                        </group>
                    </group>
               </sheet>
            </form>
        </field>
    </record>

    <record id="view_tree_maintenance_type_task" model="ir.ui.view">
         <field name="name">view.tree.maintenance.type.task</field>
         <field name="model">maintenance.type.task</field>
         <field name="arch" type="xml">
             <list>
                 <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_maintenance_type_task" model="ir.actions.act_window">
        <field name="name">Type Task</field>
        <field name="res_model">maintenance.type.task</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>