<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_bim_rfi" model="ir.ui.view">
        <field name="name">view.form.bim.rfi</field>
        <field name="model">bim.rfi</field>
        <field name="arch" type="xml">
            <form string="Bim Rfi" delete="0">
                <header>
                       <button class="oe_highlight"
                            name="to_working" string="To Working" type="object" invisible="state != 'draft'"/>

                        <button class="oe_highlight"
                            name="submit_review" string="Submit Review" type="object" invisible="state != 'working'"/>

                        <button class="oe_highlight"
                            name="review_1" string="Review 1" type="object" invisible="state != 'submitted_review'"/>

                        <button class="oe_highlight"
                            name="send_to_client" string="Send to Client" type="object" invisible="state != 'rev1'"/>

                        <button class="oe_highlight"
                            name="review_2" string="Review 2" type="object" invisible="state != 'sent_to_customer'"/>

                        <button class="oe_highlight"
                            name="to_done" string="To Done" type="object" invisible="state != 'rev2'"/>

                        <button
                            name="to_draft" string="To Draft" type="object" invisible="state == 'draft'"/>

                    <button name="send_report_by_email" string="Send for Email" type="object" />

                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                       <h1>
                           <field name="name" />
                       </h1>
                    </div>
                    <group>
                         <group>
                            <field name="project_id" options="{'no_create': True, 'no_edit': True}"/>
                            <field name="partner_id" options="{'no_create': True, 'no_edit': True}"/>
                            <field name="contact_id" options="{'no_create': True, 'no_edit': True}"/>
                            <field name="origin_request"/>
                            <field name="type"/>
                            <field name="internal_approval_state"/>
                            <field name="external_approval_state"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="user_id" options="{'no_create': True, 'no_edit': True}"/>
                            <field name="company_id" options="{'no_create': True, 'no_edit': True}"/>
                            <field name="bim_rfi_id"/>
                            <field name="reference_plans"/>
                            <field name="response_plans"/>
                            <field name="impact_cost"/>
                            <field name="impact_schedule"/>
                        </group>
                    </group>
                     <notebook>
                          <page name="description" string="Description">
                              <field name="description" widget="html"/>
                          </page>
                         <page name="response" string="Response">
                              <field name="response" widget="html"/>
                          </page>
                         <page name="attachments" string="Attachments">
                            <!-- widget de lista de adjuntos -->
                             <field name="line_ids"  widget="one2many_list">
                                <list editable="bottom">
                                     <field filename="file_name" name="file" optional="show"/>
                                     <field name="file_name" optional="hide"/>
                                </list>
                            </field>
                        </page>
                     </notebook>

                    <!--
                    <notebook>
                      <page name="lines_ids" string="Lines">
                            <field name="lines_ids"
                                   widget="one2many_list">
                                <list editable="bottom">

                                    <field name="bim_budget_stage_id"
                                            optional="show"
                                            widget="many2onebutton" options='{"no_create": true}'/>

                                    <field name="date"
                                           optional="show"
                                           />

                                    <field name="value"
                                           optional="show"
                                           sum="sum"/>

                                    <field name="value_r"
                                           optional="show"
                                           sum="sum"/>
                                </list>
                            </field>
                        </page>
                        <page name="analysis_graph" string="Graph">
                            <div class="text-center">
                                <field name="analysis_graph" widget="image"/>
                            </div>
                        </page>
                    </notebook>
                    -->

                 </sheet>

                <chatter/>

            </form>
        </field>
    </record>

    <record id="view_tree_bim_rfi" model="ir.ui.view">
        <field name="name">view.tree.bim.rfi</field>
        <field name="model">bim.rfi</field>
        <field name="arch" type="xml">
            <list   delete="0"
                    decoration-danger="state == 'draft'"
                    decoration-info="state == 'working'"
                    decoration-success="state == 'approved'"
                    decoration-warning="state == 'decline'">
                <field name="name"/>
                <field name="project_id" optional="show"/>
                <field name="partner_id" optional="show"/>
                <field name="contact_id" optional="show"/>
                <field name="origin_request" optional="show"/>
                <field name="bim_rfi_id" optional="show"/>
                <field name="type" optional="show"/>
                <field name="user_id" optional="show"/>
                <field name="company_id" optional="show"/>
                <field name="date" optional="show"/>
                <field name="internal_approval_state" optional="show"/>
                <field name="external_approval_state" optional="show"/>
                <field name="impact_cost" optional="show"/>
                <field name="impact_schedule" optional="show"/>
                <field name="state"
                        decoration-danger="state == 'draft'"
                        decoration-info="state == 'working'"
                        widget="badge" optional="show"/>
            </list>
        </field>
    </record>

    <record id="action_bim_rfi" model="ir.actions.act_window">
        <field name="name">Bim Rfi</field>
        <field name="res_model">bim.rfi</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new Bim Rfi!
            </p>
        </field>
    </record>
    </data>
</odoo>