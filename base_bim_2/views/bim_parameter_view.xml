<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_form_bim_parameter" model="ir.ui.view">
            <field name="name">view.form.bim.parameter</field>
            <field name="model">bim.parameter</field>
            <field name="arch" type="xml">
                <form string="Attribute">
                    <sheet>
                        <widget bg_color="bg-danger" invisible="active == True" name="web_ribbon" title="Archived"/>
                        <div class="oe_title">
                            <h5>
                                <label for="description"/>
                                <field class="ml-1" name="description"/>
                            </h5>
                        </div>
                        <group name="main">
                            <group name="left">
                                <field name="attribute_id" options="{'no_create': True}"/>
                            </group>
                            <group name="right">
                                <field name="template_id" options="{'no_create': True}"/>
                            </group>
                        </group>
                        <field invisible="True" name="active"/>
                        <notebook>
                            <page name="values" string="Values">
                                <field name="value_ids" nolabel="1">
                                    <list editable="bottom">
                                        <control>
                                            <create string="Add line"/>
                                        </control>
                                        <field name="sequence" widget="handle"/>
                                        <field invisible="True" name="attribute_id"/>
                                        <field name="attribute_value_id"/>
                                        <field name="price_factor"/>
                                        <field name="qty_factor"/>
                                    </list></field>
                            </page>
                            <page name="products" string="Products">
                                <field name="product_ids"><list editable="bottom">
                                        <field name="default_code"/>
                                        <field name="name"/>
                                        <field name="type"/>
                                        <field name="lst_price"/>
                                        <field name="standard_price"/>
                                        <field name="uom_id"/>
                                        <field name="uom_po_id"/>
                                    </list></field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form></field>
        </record>
        <record id="view_tree_bim_parameter" model="ir.ui.view">
            <field name="name">view.tree.bim.parameter</field>
            <field name="model">bim.parameter</field>
            <field name="arch" type="xml">
                <list>
                    <field name="description"/>
                    <field name="attribute_id"/>
                    <field name="template_id"/>
                    <field name="product_ids"/>
                </list></field>
        </record>
        <record id="action_bim_parameter" model="ir.actions.act_window">
            <field name="name">BIM Parameters</field>
            <field name="res_model">bim.parameter</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create a new BIM Parameter!
                </p></field>
        </record>
        <record id="view_tree_bim_concept_parameter" model="ir.ui.view">
            <field name="name">view.tree.bim.concept.parameter</field>
            <field name="model">bim.concepts.parameter.attribute</field>
            <field name="arch" type="xml">
                <list create="0" delete="0">
                    <field name="concept_id"/>
                    <field name="parameter_id"/>
                    <field name="parameter_value_id"/>
                </list></field>
        </record>
        <record id="action_bim_concept_parameter" model="ir.actions.act_window">
            <field name="name">BIM Concept Parameters</field>
            <field name="res_model">bim.concepts.parameter.attribute</field>
            <field name="view_mode">list</field>
        </record>
        <menuitem action="action_bim_parameter" id="menu_bim_parameter" name="BIM Parameters" parent="base_bim_2.menu_bim_concept_templates" sequence="11"/>
    </data>
</odoo>
