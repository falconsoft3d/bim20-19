<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_contractor_contract_generator" model="ir.ui.view">
        <field name="name">view.form.contractor.contract.generator</field>
        <field name="model">contractor.contract.generator</field>
        <field name="arch" type="xml">
            <form string="Contractor Contract Generator" delete="0" >
                <header>
                        <button class="oe_highlight" invisible="state not in ['draft']" name="to_load" string="Load" type="object"/>
                        <button class="oe_highlight" invisible="state not in ['loaded']" name="to_approved" string="Approve" type="object"/>
                        <button class="oe_highlight" invisible="state not in ['approved']" name="to_done" string="Done" type="object"/>

                        <button invisible="state not in ['done','loaded','approved','done']" name="to_draft" string="Draft" type="object"/>

                        <field name="state" widget="statusbar"/>
                    </header>
                <sheet>
                    <div class="oe_title">
                       <h1>
                           <field name="name"/>
                       </h1>
                    </div>
                    <group>
                         <group>
                             <field name="project_id"  readonly="state not in ['draft']"/>
                             <field name="budget_id"
                                    domain="[('project_id','=',project_id)]"
                                    readonly="state not in ['draft']"/>
                             <field name="date" readonly="state not in ['draft']"/>
                        </group>
                        <group>
                            <field name="currency_id" readonly="state not in ['draft']"/>
                            <field name="company_id" readonly="state not in ['draft']"/>
                            <field name="user_id" readonly="state not in ['draft']"/>
                        </group>
                    </group>


                    <notebook>

                        <page name="line_ids" string="Lines">
                            <field name="line_ids" widget="one2many_list" readonly="state in ['done']">
                                <list editable="bottom">
                                    <field name="concept_id"
                                           widget="many2onebutton"
                                           options='{"no_create": true}'
                                           domain="[
                                                    ('type', '=', 'departure'),
                                           ]" />
                                    <field name="partner_id"
                                           widget="many2onebutton"
                                           options='{"no_create": true}'/>
                                    <field name="qty" sum="sum"/>
                                    <field name="price_unit" />
                                    <field name="currency_id" optional="hide"/>
                                    <field name="amount"
                                           sum="sum"/>
                                    <field name="contractor_contract_id"
                                           widget="many2onebutton"
                                           options='{"no_create": true}'/>
                                </list>
                            </field>
                        </page>

                    </notebook>

                 </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tree_contractor_contract_generator" model="ir.ui.view">
        <field name="name">view.tree.contractor.contract.generator</field>
        <field name="model">contractor.contract.generator</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="currency_id" optional="hide"/>
                <field name="company_id" optional="hide"/>
                <field name="user_id" optional="hide"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_contractor_contract_generator" model="ir.actions.act_window">
        <field name="name">Contractor Contract Generator</field>
        <field name="res_model">contractor.contract.generator</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new Contractor Contract Generator!
            </p>
        </field>
    </record>
    </data>
</odoo>