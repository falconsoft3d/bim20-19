<?xml version="1.0" encoding="UTF-8"?>
 <odoo>
      <record id="view_form_maintenance_asset" model="ir.ui.view">
         <field name="name">view.form.maintenance.asset</field>
         <field name="model">maintenance.asset</field>
         <field name="arch" type="xml">
            <form>
              <sheet>
                  <div class="oe_button_box" name="button_box">
                      <button class="oe_stat_button" icon="fa-road"
                                name="action_view_maintenance_measure"
                                string="Measures" type="object">
                            <field name="count_maintenance_measure" string="Measures" widget="statinfo"/>
                        </button>
                    </div>

                    <group>
                        <group>
                            <field name="name" required="1"/>
                            <field name="product_id"/>
                            <field name="code"/>
                            <field name="date_last_services"/>
                            <field name="date_next_services"/>
                            <field name="cost"/>
                        </group>
                        <group>
                            <field name="maintenance_task_plan_id"/>
                            <field name="desc"/>
                            <field name="serial"/>
                            <field name="maintenance_location_id"/>
                            <field name="currency_id"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                <notebook>
                      <page string="QR Code">
                        <group>
                            <group>
                                <field name="qr_code" string=""
                                       widget="image"
                                       options='{"size": [200, 200]}'/>
                            </group>
                        </group>
                    </page>
                    <page string="URL">
                        <group>
                            <group>
                                <field name="url" widget="url"/>
                                <field name="url_qr_code" string=""
                                       widget="image"
                                       options='{"size": [200, 200]}'/>
                            </group>
                        </group>
                    </page>
                </notebook>
               </sheet>


                <chatter/>

            </form>



        </field>
    </record>

    <record id="view_tree_maintenance_asset" model="ir.ui.view">
         <field name="name">view.tree.maintenance.asset</field>
         <field name="model">maintenance.asset</field>
         <field name="arch" type="xml">
             <list>
                 <field name="name"/>
                 <field name="product_id"/>
                 <field name="code"/>
                 <field name="date_last_services"/>
                 <field name="date_next_services"/>
                 <field name="desc"/>
                 <field name="serial"/>
                 <field name="maintenance_location_id"/>
                 <field name="maintenance_task_plan_id"/>
                 <field name="cost" sum="sum"/>
                 <field name="currency_id"/>
                 <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="action_maintenance_asset" model="ir.actions.act_window">
        <field name="name">Asset</field>
        <field name="res_model">maintenance.asset</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>