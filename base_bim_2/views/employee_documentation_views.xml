<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_employee_documentation" model="ir.ui.view">
        <field name="name">view.form.employee.documentation</field>
        <field name="model">employee.documentation</field>
        <field name="arch" type="xml">
            <form string="Employee Documentation">
                <header>
                    <!--
                    <button class="oe_highlight" invisible="not state in ('draft')"
                            name="to_required"
                            string="To Required" type="object"/>

                    <button  invisible="state != 'cancel'"
                            name="to_draft" string="To Draft" type="object"/>
                    -->
                <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                       <h1>
                           <field name="name" />
                       </h1>
                    </div>
                    <group>
                         <group>
                             <field name="title"/>
                             <field name="hr_employee_id" options="{'no_create': True, 'no_edit': True}"/>
                        </group>
                        <group>
                            <field name="expiration_date"/>
                            <field name="file" filename="file_name"/>
                            <field name="file_name" invisible="1"/>
                            <field name="company_id" options="{'no_create': True, 'no_edit': True}" />
                            <field name="user_id" options="{'no_create': True, 'no_edit': True}" />
                        </group>
                    </group>
                 </sheet>

                <chatter/>

            </form>
        </field>
    </record>

    <record id="view_tree_employee_documentation" model="ir.ui.view">
        <field name="name">view.tree.employee.documentation</field>
        <field name="model">employee.documentation</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'expired'" >
                <field name="name"/>
                <field name="title" optional="show"/>
                <field name="user_id" optional="show"/>
                <field name="hr_employee_id" optional="show"/>
                <field name="company_id" optional="show"/>
               <field name="expiration_date" optional="show"/>
                <field name="state" optional="show"/>
            </list>
        </field>
    </record>



    <record id="action_employee_documentation" model="ir.actions.act_window">
        <field name="name">E. Documentation</field>
        <field name="res_model">employee.documentation</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new employee documentation!
            </p>
        </field>
    </record>

    <!-- Solo muestra los gastos del usuario logueado -->
    <record id="action_my_employee_documentation" model="ir.actions.act_window">
        <field name="name">E. Documentation</field>
        <field name="res_model">employee.documentation</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new employee documentation!
            </p>
        </field>
    </record>


    </data>
</odoo>