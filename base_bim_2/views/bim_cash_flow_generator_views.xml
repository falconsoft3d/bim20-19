<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_bim_cash_flow_generator" model="ir.ui.view">
        <field name="name">view.form.bim.cash.flow.generator</field>
        <field name="model">bim.cash.flow.generator</field>
        <field name="arch" type="xml">
            <form string="Bim Cash Flow Generator" delete="0" >
                <header>
                    <button class="oe_highlight" invisible="state != 'draft'" name="exe_done" string="To Done" type="object"/>
                    <button class="oe_highlight" invisible="state != 'done'" name="exe_draft" string="To Draft" type="object"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button"
                                icon="fa-dollar" name="action_view_bim_cash_flow" string="Cash Flow" type="object">
                            <field name="bim_cash_flow_count" string="Cash Flow" widget="statinfo"/>
                            <field invisible="True" name="bim_cash_flow_ids"/>
                        </button>
                    </div>

                    <div class="oe_title">
                       <h1>
                           <field name="name" />
                       </h1>
                    </div>
                    <group>
                         <group>
                            <field name="type" readonly="state != 'draft'"/>
                            <field name="contact_id" options="{'no_create': True, 'no_edit': True}"
                                   readonly="state != 'draft'"/>
                            <field name="calculation_factor"/>
                            <field name="initial_balance"/>
                            <field name="bim_cash_flow_category_id"/>
                            <field name="note"/>
                        </group>
                        <group>
                            <field name="bim_project_id" options="{'no_create': True, 'no_edit': True}"
                                   readonly="state != 'draft'"/>
                            <field name="bim_budget_id"
                                   readonly="state != 'draft'"
                                   domain="[('project_id', '=', bim_project_id)]"
                                   options="{'no_create': True, 'no_edit': True}"/>

                            <field name="company_id" options="{'no_create': True, 'no_edit': True}"
                                   readonly="state != 'draft'"/>
                            <field name="currency_id" options="{'no_create': True, 'no_edit': True}"
                                   readonly="state != 'draft'"/>
                            <field name="journal_id" options="{'no_create': True, 'no_edit': True}"
                                   readonly="state != 'draft'"/>


                        </group>
                    </group>
                 </sheet>

                <chatter/>

            </form>
        </field>
    </record>

    <record id="view_tree_bim_cash_flow_generator" model="ir.ui.view">
        <field name="name">view.tree.bim.cash.flow.generator</field>
        <field name="model">bim.cash.flow.generator</field>
        <field name="arch" type="xml">
            <list
                decoration-info="state == 'draft'"
                decoration-muted="state == 'done'"
            >
                <field name="name"/>
                <field name="currency_id" optional="hide"/>
                <field name="contact_id" optional="show"/>
                <field name="bim_project_id" optional="show"/>
                <field name="bim_budget_id" optional="show"/>
                <field name="calculation_factor" optional="show"/>
                <field name="journal_id" optional="show"/>
                <field name="initial_balance"  optional="hide"/>
                <field name="bim_cash_flow_category_id" optional="hide"/>
                <field name="company_id" optional="show"/>
                <field name="type" optional="show"/>
                <field name="state" optional="show"/>
            </list>
        </field>
    </record>



    <record id="action_bim_cash_flow_generator" model="ir.actions.act_window">
        <field name="name">Cash Flow Generator</field>
        <field name="res_model">bim.cash.flow.generator</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new checklist state!
            </p>
        </field>
    </record>

    </data>
</odoo>