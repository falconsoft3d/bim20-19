<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_resource_analysis" model="ir.ui.view">
        <field name="name">view.form.resource.analysis</field>
        <field name="model">resource.analysis</field>
        <field name="arch" type="xml">
            <form string="Resource Analysis">
                <header>
                     <button class="oe_highlight"
                            name="load_data" string="Load Data" type="object"/>
                    <button
                            name="update_budget_graph" string="Graph" type="object"/>
                </header>
                <sheet>
                    <div class="oe_title">
                       <h1>
                           <field name="name" />
                       </h1>
                    </div>
                    <group>
                         <group>
                            <field name="title" />
                            <field name="project_id"
                                   options="{'no_create': True, 'no_edit': True}"/>
                            <field name="budget_id"
                                   domain="[('project_id', '=', project_id)]"
                                   options="{'no_create': True, 'no_edit': True}"/>

                        </group>
                        <group>
                            <field name="type" />
                            <field name="user_id" options="{'no_create': True, 'no_edit': True}"/>
                            <field name="company_id" options="{'no_create': True, 'no_edit': True}"/>
                        </group>
                    </group>

                    <notebook>
                      <page name="lines_ids" string="Lines">
                            <field name="lines_ids"
                                   widget="one2many_list">
                                <list editable="bottom">

                                    <field name="bim_budget_stage_id"
                                            optional="show"
                                            widget="many2onebutton" options='{"no_create": true}'/>

                                    <field name="date"
                                           optional="show"
                                           />

                                    <field name="value"
                                           optional="show"
                                           sum="sum"/>

                                    <field name="value_r"
                                           optional="show"
                                           sum="sum"/>
                                </list>
                            </field>
                        </page>
                        <page name="analysis_graph" string="Graph">
                            <div class="text-center">
                                <field name="analysis_graph" widget="image"/>
                            </div>
                        </page>
                    </notebook>

                 </sheet>

                <chatter/>

            </form>
        </field>
    </record>

    <record id="view_tree_resource_analysis" model="ir.ui.view">
        <field name="name">view.tree.resource.analysis</field>
        <field name="model">resource.analysis</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="title" />
                <field name="type" />
                <field name="project_id" />
                <field name="budget_id" />
                <field name="user_id" />
                <field name="company_id" />
            </list>
        </field>
    </record>

    <record id="action_resource_analysis" model="ir.actions.act_window">
        <field name="name">Resource Analysis</field>
        <field name="res_model">resource.analysis</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new Resource Analysis!
            </p>
        </field>
    </record>

    </data>
</odoo>