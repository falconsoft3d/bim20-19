<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_form_bim_tms_expense_record" model="ir.ui.view">
        <field name="name">view.form.bim.tms.expense.record</field>
        <field name="model">tms.expense.record</field>
        <field name="arch" type="xml">
            <form string="Expense record">
                <header>
                    <button class="btn btn-primary" invisible="state != 'draft'" name="action_confirm" string="Confirm" type="object"/>
                    <button invisible="state != 'cancel'" name="action_draft" string="Draft" type="object"/>
                    <button confirm="Are you sure you want to cancel this expense record?" invisible="state != 'confirmed'" name="action_cancel" string="Cancel" type="object"/>
                    <button class="btn btn-primary" groups="account.group_account_invoice" invisible="state != 'confirmed'" name="action_invoice" string="Invoice" type="object"/>
                    <field name="state" statusbar_visible="draft,confirmed,invoiced,cancelled" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-usd" invisible="invoice_id == False" name="action_view_invoice" type="object">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">
                                    Invoice
                                </span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field class="oe_inline" colspan="1" name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="transportation_expenses_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="bim_transport_equipment_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="driver_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="bim_project_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="supplier_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field invisible="True" name="invoice_id"/>
                        </group>
                        <group>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="amount" readonly="state != 'draft'"/>
                            <field name="user_id"/>
                            <field name="kilometers" readonly="state != 'draft'"/>
                            <field filename="file_name" name="file" readonly="state != 'draft'"/>
                            <field invisible="True" name="file_name"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form></field>
    </record>
    <record id="view_tree_bim_tms_expense_record" model="ir.ui.view">
        <field name="name">view.tree.bim.tms.expense.record</field>
        <field name="model">tms.expense.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="bim_transport_equipment_id" optional="show"/>
                <field name="date" optional="show"/>
                <field name="transportation_expenses_id" optional="show"/>
                <field name="amount" optional="show" sum="sum"/>
                <field name="user_id" optional="show"/>
                <field name="driver_id" optional="show"/>
                <field name="bim_project_id" optional="show"/>
                <field name="kilometers"/>
                <field name="company_id" optional="show"/>
            </list></field>
    </record>
    <record id="action_tms_expense_record" model="ir.actions.act_window">
        <field name="name">Tms expense record</field>
        <field name="res_model">tms.expense.record</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new expense record
            </p></field>
    </record>
</odoo>
