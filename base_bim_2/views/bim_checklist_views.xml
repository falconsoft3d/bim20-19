<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <!-- Plantillas de Checklist -->
        <record id="bim_master_checklist_view_form" model="ir.ui.view">
            <field name="name">bim.master.checklist.view.form</field>
            <field name="model">bim.master.checklist</field>
            <field name="arch" type="xml">
                <form string="Checklist Template">
                    <sheet>
                        <group>
                            <group>
                                <field name="code"/>

                            </group>
                            <group>
                                <field name="name"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Checklist List">
                                <field name="checklist_line_ids">
                                    <list editable="bottom" excel_export="1">
                                        <field name="sequence" widget="handle" />
                                        <field name="item_id"/>
                                        <field name="type"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="bim_master_checklist_view_tree" model="ir.ui.view">
            <field name="name">bim.master.checklist.view.tree</field>
            <field name="model">bim.master.checklist</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="bim_master_checklist_action" model="ir.actions.act_window">
            <field name="name">BIM Checklist Template</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">bim.master.checklist</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create a new Checklist Template
                </p>
            </field>
        </record>


        <!-- Checklist -->
        <record id="bim_checklist_view_form" model="ir.ui.view">
            <field name="name">bim.checklist.view.form</field>
            <field name="model">bim.checklist</field>
            <field name="arch" type="xml">
                <form string="Checklist Template">
                    <header>
                        <!-- <button name="action_checklist_send" string="Send Checklist" type="object" class="oe_highlight" /> -->
                        <field name="state_id" widget="statusbar" options="{'clickable': '1'}"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="code" readonly="1"/>
                                <field name="user_id"/>
                                <field name="company_id"/>
                            </group>
                            <group>
                                <field name="date"/>
                                <field name="name"/>
                                <field name="project_id" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Checklist">
                                <field name="checklist_line_ids">
                                    <list editable="bottom">
                                        <field name="sequence" optional="hide"/> <!-- Reemplazado widget="handle" POR "invisible" daba error -->
                                        <field name="item_id"/>
                                        <field name="type" optional="hide"/>
                                        <field name="is_ready_c" invisible="type in ('check', 'yesno')"/>
                                        <field name="is_ready" invisible="type not in ('check', 'yesno')"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Checklist Images">
                                <field name="checklist_image_ids" mode="kanban">
                                    <kanban>
                                        <field name="id"/>
                                        <field name="name"/>
                                        <field name="image_128"/>
                                        <templates>
                                            <t t-name="card">
                                                <div class="oe_kanban_global_click">
                                                    <div class="o_kanban_image" style="margin:5px;">
                                                        <img t-if="record.image_128.raw_value" t-att-alt="record.name.value" t-attf-src="/web/image/bim.checklist.images/{{ record.id.raw_value }}/image_128"/>
                                                    </div>
                                                    <div class="oe_kanban_details">
                                                        <strong><field name="name"/></strong>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                    <form string="Checklist Images">
                                        <field name="image_1920" widget='image' class="oe_avatar" options='{"preview_image": "image_128"}'/>
                                        <div class="oe_title">
                                            <h1>
                                                <field name="name"/>
                                            </h1>
                                        </div>
                                    </form>
                                </field>
                            </page>
                            <page string="Signature">
                                <label for="digital_signature" string="Signature" class="oe_edit_only"/>
                                <h2>
                                    <field name="digital_signature" widget="signature"/>
                                </h2>
                            </page>
                        </notebook>
                        <field name="obs" placeholder="Observations..."/>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="bim_checklis_view_tree" model="ir.ui.view">
            <field name="name">bim.checklist.view.tree</field>
            <field name="model">bim.checklist</field>
            <field name="arch" type="xml">
                <list>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="user_id"/>
                    <field name="company_id"/>
                    <field name="state_id"/>
                </list>
            </field>
        </record>

        <record id="bim_checklist_action" model="ir.actions.act_window">
            <field name="name">BIM Checklist</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">bim.checklist</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create a new Checklist!
                </p>
            </field>
        </record>

    </data>
</odoo>
