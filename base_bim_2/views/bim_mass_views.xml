<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_form_bim_mass" model="ir.ui.view">
        <field name="name">view.form.bim.mass</field>
        <field name="model">bim.mass</field>
        <field name="arch" type="xml">
            <form string="masss">

                <header>
                        <button class="oe_highlight"
                                invisible="state not in ['draft']"
                                name="to_done" string="To Done" type="object"/>


                        <field name="state"  widget="statusbar"/>
                    </header>

                <sheet>
                    <group>
                         <group>
                             <field name="name" readonly="1"/>
                             <field name="type" readonly="state != 'draft'"/>
                         </group>
                         <group>
                              <field name="user_id" readonly="1"/>
                              <field name="company_id" readonly="1"/>
                         </group>
                </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    <record id="view_tree_bim_mass" model="ir.ui.view">
        <field name="name">view.tree.bim.mass</field>
        <field name="model">bim.mass</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="type"/>
                <field name="user_id"/>
                <field name="company_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_bim_mass" model="ir.actions.act_window">
        <field name="name">mass</field>
        <field name="res_model">bim.mass</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new Mass!
            </p>
        </field>
    </record>


</odoo>
