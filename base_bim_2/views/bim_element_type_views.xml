<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_form_bim_element_type" model="ir.ui.view">
            <field name="name">view.form.bim.element.type</field>
            <field name="model">bim.element.type</field>
            <field name="arch" type="xml">
                <form string="Bim Element Type">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                                <field name="company_id"/>
                            <group>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tree_bim_element_type" model="ir.ui.view">
            <field name="name">view.tree.bim.element.type</field>
            <field name="model">bim.element.type</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="company_id"/>
                </list>
            </field>
        </record>

        <record id="action_bim_element_type" model="ir.actions.act_window">
            <field name="name">Element Type</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">bim.element.type</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_tree_bim_element_type"/>
        </record>
    </data>
</odoo>