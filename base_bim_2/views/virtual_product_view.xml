<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="virtual_product_view_tree" model="ir.ui.view">
        <field name="name">_view_tree</field>
        <field name="model">virtual.product</field>
        <field name="arch" type="xml">
            <list string="Virtual Product">
                <field name="reference"/>
                <field name="name"/>
                <field name="categ_id" optional="show"/>
                <field name="sub_categ_id" optional="hide"/>
                <field name="barcode" optional="hide"/>
                <field name="origin" optional="show"/>
                <field name="sales_price" optional="hide"/>
                <field name="purchase_price" optional="hide"/>
                <field name="convert_pt" optional="hide"/>
                <field name="convert_pp" optional="hide"/>
                <field name="product_id" optional="hide" widget="many2one"/>
                <field name="product_tmpl_id" optional="hide" widget="many2one"/>
                <field name="user_id" optional="hide"/>
                <field name="create_date" optional="hide"/>
            </list></field>
    </record>
    <record id="virtual_product_view_form" model="ir.ui.view">
        <field name="name">virtual_product_view_form</field>
        <field name="model">virtual.product</field>
        <field name="arch" type="xml">
            <form string="Virtual Product">
                <sheet>
                    <group>
                        <group>
                            <field name="reference"/>
                            <field name="name" required="1"/>
                            <field name="origin"/>
                        </group>
                        <group>
                            <field name="sales_price"/>
                            <field name="purchase_price"/>
                            <field name="categ_id"/>
                            <field domain="[('parent_id', '=', categ_id)]" name="sub_categ_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="lines_ids" nolabel="1">
                                <list editable="bottom" order="name">
                                    <field name="name" optional="show"/>
                                    <field domain="[('attribute_id', '=', name)]" name="value_id" optional="show" options="{'no_create_edit': True}"/>
                                    <field name="sequence" optional="hide"/>
                                </list></field>
                        </page>
                        <page id="other" name="other" string="Other">
                            <group>
                                <group>
                                    <field name="barcode"/>
                                    <field name="user_id" readonly="1"/>
                                    <field name="create_date" readonly="1"/>
                                </group>
                                <group>
                                    <field invisible="convert_pp == False" name="product_id"/>
                                    <field invisible="convert_pt == False" name="product_tmpl_id"/>
                                    <field invisible="convert_pp == True" name="convert_pt"/>
                                    <field invisible="convert_pt == True" name="convert_pp"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form></field>
    </record>
    <!-- views  ir.actions.act_window -->
    <record id="virtual_product_action_window" model="ir.actions.act_window">
        <field name="name">Virtual Product List</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">virtual.product</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
