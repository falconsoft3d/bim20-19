<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_form_bim_part" model="ir.ui.view">
            <field name="name">view.form.bim.part</field>
            <field name="model">bim.part</field>
            <field name="arch" type="xml">
                <form delete="0" string="Report">
                    <header>
                        <button class="btn-primary" invisible="state not in ['draft']" name="action_validate" string="Validate" type="object"/>
                        <button invisible="state not in ['draft','validated']" name="action_cancel" string="Cancel" type="object"/>
                        <button invisible="all_lines_purchase == True or state != 'validated'" name="create_purchase_order" string="Create Purchase Order" type="object"/>
                        <button invisible="state not in ['validated','cancel']" name="action_draft" string="Draft" type="object"/>
                        <!-- <button name="action_invoice" states="validated" string="Generar Factura" class="btn-primary o_sale_confirm" type="object" />     -->
                        <field name="state" statusbar_visible="draft,validated" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" icon="fa-check" name="action_view_purchase_order" type="object">
                                <div class="o_form_field o_stat_info">
                                    <span class="o_stat_value">
                                        <field name="purchase_count" nolabel="1" widget="statinfo"/>
                                    </span>
                                    <span class="o_stat_text">
                                        Purchase Orders
                                    </span>
                                </div>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field invisible="True" name="all_lines_purchase"/>
                                <field name="type" widget="radio"/>
                                <field invisible="True" name="elements_readonly"/>
                                <field name="project_id" options='{"no_create": 1, "no_open": True}' readonly="elements_readonly == True"/>
                                <field name="budget_id" options='{"no_create": 1, "no_open": True}' readonly="elements_readonly == True"/>
                                <field domain="[('budget_id','=',budget_id),('type','=','departure')]" name="concept_id" options='{"no_create": 1, "no_open": True}' readonly="elements_readonly == True"/>
                                <field invisible="type == 'per_lines'" name="partner_id" options='{"no_create": 1, "no_open": True}' readonly="state != 'draft'" required="type != 'per_lines'"/>
                            </group>
                            <group>
                                <field name="date"/>
                                <field domain="[('budget_id','=',budget_id)]" name="space_id" options='{"no_create": 1, "no_open": 1}'/>
                                <field name="user_id" options='{"no_create": 1, "no_open": 1}'/>
                                <field groups="base.group_multi_company" name="company_id"/>
                                <field invisible="True" name="company_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Lines">
                                <field name="lines_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field invisible="True" name="filter_type"/>
                                        <field invisible="True" name="product_uom_category_id"/>
                                        <field force_save="1" name="partner_id" options='{"no_create": 1}' readonly="filter_type == 'doc'" required="filter_type == 'line'"/>
                                        <field domain="[('resource_type', 'in', ['H','Q']),('type', 'in', ['service'])]" name="name" options='{"no_create": 1}' required="1"/>
                                        <field force_save="1" name="resource_type" readonly="1"/>
                                        <field name="description"/>
                                        <field name="product_uom" options='{"no_create": 1}' required="1"/>
                                        <field name="product_uom_qty" required="1" sum="sum"/>
                                        <field name="price_unit" required="1"/>
                                        <field name="price_subtotal" sum="sum"/>
                                        <field name="purchase" optional="hide" readonly="1"/>
                                    </list></field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form></field>
        </record>
        <record id="view_tree_bim_part" model="ir.ui.view">
            <field name="name">view.tree.bim.part</field>
            <field name="model">bim.part</field>
            <field name="arch" type="xml">
                <list decoration-info="state in ('validated')" decoration-muted="state=='cancel'" delete="0">
                    <field name="name"/>
                    <field name="user_id"/>
                    <field name="date"/>
                    <field name="space_id"/>
                    <field name="concept_id"/>
                    <field name="project_id"/>
                    <field name="state"/>
                </list></field>
        </record>
        <record id="action_bim_part" model="ir.actions.act_window">
            <field name="name">Report</field>
            <field name="res_model">bim.part</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create a new Project Report!
                </p></field>
        </record>
    </data>
</odoo>
