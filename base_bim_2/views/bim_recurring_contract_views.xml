<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_form_bim_recurring_contract" model="ir.ui.view">
            <field name="name">view.form.bim.recurring.contract</field>
            <field name="model">bim.recurring.contract</field>
            <field name="arch" type="xml">
                <form string="Recurring Contract">
                    <header>
                        <button class="oe_highlight" icon="fa-check-square-o" invisible="state not in ['draft']" name="action_confirm" string="Confirm" type="object"/>
                        <button class="oe_highlight" icon="fa-flag-checkered" invisible="state not in ['confirmed']" name="action_finish" string="Finish" type="object"/>
                        <button icon="fa-play" invisible="state not in ['confirmed']" name="action_execute" string="Execute" type="object"/>
                        <button class="oe_highlight" icon="fa-undo" invisible="state not in ['finished','cancel']" name="action_draft" string="Draft" type="object"/>
                        <button invisible="state not in ['draft']" name="action_cancel" string="Cancel" type="object"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" icon="fa-money" name="action_view_invoice" string="Invoices" type="object">
                                <div class="o_form_field o_stat_info">
                                    <span class="o_stat_value">
                                        <field name="invoice_count" nolabel="1" widget="statinfo"/>
                                    </span>
                                    <span class="o_stat_text">
                                        Invoice
                                    </span>
                                </div>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="bim_project_id" readonly="state not in ['draft']" required="1"/>
                                <field name="partner_id" readonly="state not in ['draft']" required="1"/>
                                <field name="contact_ids" readonly="state not in ['draft']" required="1" widget="many2many_tags"/>
                                <field name="date_start" readonly="state not in ['draft']" required="1"/>
                                <field name="date_end" readonly="state not in ['draft']" required="1"/>
                                <field name="sale_order_id" readonly="state not in ['draft']" required="1"/>
                                <field name="amount" readonly="state not in ['draft']" required="1"/>
                            </group>
                            <group>
                                <field name="time_unit" readonly="state not in ['draft']" required="1"/>
                                <field name="frequency" readonly="state not in ['draft']" required="1"/>
                                <field name="day_invoice" readonly="state not in ['draft']" required="1"/>
                                <field name="company_id" radonly="1" readonly="state not in ['draft']"/>
                                <field name="currency_id" readonly="state not in ['draft']" required="1"/>
                                <field name="state_invoice" readonly="state not in ['draft']" required="1"/>
                                <field name="active" required="1"/>
                            </group>
                        </group>
                        <field name="desc" readonly="state not in ['draft']"/>
                    </sheet>
                    <chatter/>
                </form></field>
        </record>
        <record id="view_tree_bim_recurring_contract" model="ir.ui.view">
            <field name="name">view.tree.bim.recurring.contract</field>
            <field name="model">bim.recurring.contract</field>
            <field name="arch" type="xml">
                <list decoration-danger="state == 'draft'" decoration-muted="state == 'cancel'" decoration-success="state == 'finished'" delete="0">
                    <field name="name"/>
                    <field name="bim_project_id" optional="show"/>
                    <field name="partner_id" optional="show"/>
                    <field name="company_id" optional="show"/>
                    <field name="frequency" optional="show"/>
                    <field name="time_unit" optional="show"/>
                    <field name="date_start" optional="show"/>
                    <field name="date_end" optional="show"/>
                    <field name="amount" sum="sum"/>
                    <field name="state" optional="show"/>
                </list></field>
        </record>
        <record id="action_bim_recurring_contract" model="ir.actions.act_window">
            <field name="name">Recurring Contract</field>
            <field name="res_model">bim.recurring.contract</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create a new document!
                </p></field>
        </record>
        <menuitem action="action_bim_recurring_contract" id="menu_bim_recurring" name="Recurring Contract" parent="menu_bim_documentation_categ" sequence="20"/>
    </data>
</odoo>
