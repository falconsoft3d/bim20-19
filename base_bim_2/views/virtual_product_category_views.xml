<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_form_virtual_product_category" model="ir.ui.view">
        <field name="name">view.form.bim.virtual.product.category</field>
        <field name="model">virtual.product.category</field>
        <field name="arch" type="xml">
            <form string="order">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="parent_id"/>
                        </group>
                        <group>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tree_virtual_product_category" model="ir.ui.view">
        <field name="name">view.tree.bim.virtual.product.category</field>
        <field name="model">virtual.product.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="parent_id"/>
            </list>
        </field>
    </record>

    <record id="action_virtual_product_category" model="ir.actions.act_window">
        <field name="name">Virtual Product Category</field>
        <field name="res_model">virtual.product.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new Virtual Product Category
            </p>
        </field>
    </record>

</odoo>