<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="view_form_revit_budget_import" model="ir.ui.view">
            <field name="name">view.form.revit.budget.import</field>
            <field name="model">revit.budget.import</field>
            <field name="arch" type="xml">
                <form string="Revit Budget Import">
                    <header>
                         <button class="oe_highlight"
                                name="load_data" string="Load Data"
                                invisible="state != 'draft'"
                                type="object"/>

                         <button class="oe_highlight"
                                name="insert" string="Insert Data"
                                invisible="state != 'loaded'"
                                type="object"/>

                        <button
                                name="to_draft" string="To Draft"
                                invisible="state == 'draft'"
                                type="object"/>

                         <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>



                    <div class="oe_title">
                       <h1>
                           <field name="name" readonly="1"/>
                       </h1>
                    </div>
                        <group>
                            <group>
                                <field name="file_type" readonly="state != 'draft'"/>
                                <field name="type_action" readonly="state != 'draft'"/>
                                <field name="file" filename="file_name" readonly="state != 'draft'"/>
                                <field name="file_name" invisible="1" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="budget_id" readonly="state != 'draft'"/>
                                <field name="bim_massive_certification_by_line_id"
                                       readonly="state != 'draft'"
                                       domain="[('budget_id','=',budget_id)]"/>
                            </group>
                        </group>

                        <notebook>
                          <page name="lines" string="Lines">
                                <field name="line_ids" widget="line_ids">
                                    <list editable="bottom">
                                        <field name="code"/>
                                        <field name="decription"/>
                                        <field name="count" sum="sum"/>
                                        <field name="area" sum="sum"/>
                                        <field name="volume" sum="sum"/>
                                        <field name="length" sum="sum"/>
                                        <field name="advance" sum="sum" string="Avance"/>
                                        <field name="bim_concept_template_id"/>
                                        <field name="bim_uom"/>
                                    </list>
                                </field>
                            </page>
                            <page name="other" string="Other Information">
                                <group>
                                </group>
                                <group>
                                    <field name="user_id"/>
                                    <field name="company_id"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tree_revit_budget_import" model="ir.ui.view">
            <field name="name">view.tree.revit.budget.import</field>
            <field name="model">revit.budget.import</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="file_type"/>
                    <field name="type_action"/>
                    <field name="budget_id"/>
                    <field name="bim_massive_certification_by_line_id"/>
                    <field name="user_id"/>
                    <field name="company_id"/>
                </list>
            </field>
        </record>

        <record id="action_revit_budget_import" model="ir.actions.act_window">
            <field name="name">Revit Budget Import</field>
            <field name="res_model">revit.budget.import</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create a new Revit Budget Import!
                </p>
            </field>
        </record>

    </data>
</odoo>