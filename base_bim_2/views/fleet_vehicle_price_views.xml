<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_form_fleet_vehicle_price" model="ir.ui.view">
        <field name="name">view.form.bim.fleet.vehicle.price</field>
        <field name="model">fleet.vehicle.price</field>
        <field name="arch" type="xml">
            <form string="order">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="price"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tree_fleet_vehicle_price" model="ir.ui.view">
        <field name="name">view.tree.bim.fleet.vehicle.price</field>
        <field name="model">fleet.vehicle.price</field>
        <field name="arch" type="xml">
            <list delete="1">
                <field name="name"/>
                <field name="price" optional="show"/>
            </list>
        </field>
    </record>

    <record id="action_fleet_vehicle_price" model="ir.actions.act_window">
        <field name="name">Fleet Vehicle Price</field>
        <field name="res_model">fleet.vehicle.price</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new fleet vehicle price
            </p>
        </field>
    </record>

</odoo>