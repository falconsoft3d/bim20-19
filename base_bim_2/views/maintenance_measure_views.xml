<?xml version="1.0" encoding="UTF-8"?>
 <odoo>
      <record id="view_form_maintenance_measure" model="ir.ui.view">
         <field name="name">view.form.maintenance.measure</field>
         <field name="model">maintenance.measure</field>
         <field name="arch" type="xml">
            <form>
                <header>
                    <button class="btn btn-primary"
                               invisible="state not in ['draft']"
                               name="action_to_done" string="To Done" type="object"/>
                    <button
                               invisible="state in ['draft']"
                               confirm="Are you sure you want to draft this task?"
                               name="to_draft" string="To Draft" type="object"/>
                        <field name="state" widget="statusbar"/>
                    </header>
              <sheet>
                    <group>
                        <group>
                            <field name="name" required="1"/>
                            <field name="maintenance_asset_id" readonly="state not in ['draft']"/>
                            <field name="date" readonly="state not in ['draft']"/>
                            <field name="value" readonly="state not in ['draft']"/>
                        </group>
                        <group>
                            <field name="note" readonly="state not in ['draft']"/>
                            <field name="user_id" readonly="state not in ['draft']"/>
                            <field name="company_id" readonly="state not in ['draft']"/>
                        </group>
                    </group>
               </sheet>
            </form>
        </field>
    </record>

    <record id="view_tree_maintenance_measure" model="ir.ui.view">
         <field name="name">view.tree.maintenance.measure</field>
         <field name="model">maintenance.measure</field>
         <field name="arch" type="xml">
             <list>
                <field name="name" required="1"/>
                <field name="maintenance_asset_id"/>
                <field name="date"/>
                <field name="value" sum="sum"/>
                <field name="user_id"/>
                <field name="company_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>


    <record id="maintenance_measure_view_pivot" model="ir.ui.view">
        <field name="name">maintenance.measure.view.pivot</field>
        <field name="model">maintenance.measure</field>
        <field name="arch" type="xml">
            <pivot string="Maintenance Measure">
                <field name="maintenance_asset_id" type="row"/>
                <field interval="day" name="date"  type="col"/>
                <field name="value" type="measure"/>
            </pivot></field>
    </record>


    <record id="action_maintenance_measure" model="ir.actions.act_window">
        <field name="name">measures</field>
        <field name="res_model">maintenance.measure</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>
</odoo>