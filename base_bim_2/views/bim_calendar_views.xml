<?xml version="1.0" encoding="UTF-8"?>
 <odoo>
      <record id="view_form_bim_calendar" model="ir.ui.view">
         <field name="name">view.form.bim.calendar</field>
         <field name="model">bim.calendar</field>
         <field name="arch" type="xml">
            <form>
              <sheet>
                    <group>
                        <group>
                            <field name="name" required="1"/>
                            <field name="company_id" required="1"/>
                        </group>
                        <group>
                            <field name="monday"/>
                            <field name="tuesday"/>
                            <field name="wednesday"/>
                            <field name="thursday"/>
                            <field name="friday"/>
                            <field name="saturday"/>
                            <field name="sunday"/>
                        </group>
                    </group>
               </sheet>
            </form>
        </field>
    </record>

    <record id="view_tree_bim_calendar" model="ir.ui.view">
         <field name="name">view.tree.bim.calendar</field>
         <field name="model">bim.calendar</field>
         <field name="arch" type="xml">
             <list>
                 <field name="name"/>
                 <field name="company_id"/>
                 <field name="monday"/>
                 <field name="tuesday"/>
                 <field name="wednesday"/>
                 <field name="thursday"/>
                 <field name="friday"/>
                 <field name="saturday"/>
                 <field name="sunday"/>
            </list>
        </field>
    </record>

    <record id="action_bim_calendar" model="ir.actions.act_window">
        <field name="name">Calendario</field>
        <field name="res_model">bim.calendar</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>