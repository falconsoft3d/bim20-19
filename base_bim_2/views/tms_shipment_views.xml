<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_form_bim_tms_shipment" model="ir.ui.view">
        <field name="name">view.form.bim.tms.shipment</field>
        <field name="model">tms.shipment</field>
        <field name="arch" type="xml">
            <form string="order" delete="0">
                <header>
                     <button class="oe_highlight"  invisible="state not in ['draft']" name="exe_confirm" string="Confirm" type="object"/>
                     <button class="oe_highlight"  invisible="state not in ['confirmed','cancelled']"
                             name="exe_draft" string="To Draft" type="object"/>
                     <button  invisible="state not in ['draft']" name="exe_cancel" string="Cancel" type="object"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                       <h1>
                           <field name="name" readonly="1"
                                  class="oe_inline" colspan="1"/>
                       </h1>
                    </div>
                    <group>
                        <group>
                            <field name="bim_transport_equipment_id"
                                   readonly="state not in ['draft']"
                                   options="{'no_create': True}"/>

                             <field name="driver_id"
                                    readonly="state not in ['draft']"
                                   options="{'no_create': True}"/>



                            <field name="bim_project_origin_id"
                                   readonly="state not in ['draft']"
                                      options="{'no_create': True}"/>

                            <field name="bim_project_destination_id"
                                   readonly="state not in ['draft']"
                                      options="{'no_create': True}"/>

                            <field name="begin_kilometers"
                                  readonly="state not in ['draft']"
                            />
                            <field name="end_kilometers"
                                   readonly="state not in ['draft']"
                            />

                        </group>
                        <group groups="base_bim_2.group_bim_admin_trips">
                            <field name="price"
                                   widget="monetary" options="{'currency_field': 'currency_id'}"
                                   readonly="state not in ['draft']"/>
                            <field name="qty" readonly="state not in ['draft']"/>
                            <field name="total"
                                   widget="monetary" options="{'currency_field': 'currency_id'}"
                                   readonly="state not in ['draft']"/>
                            <field name="currency_id" readonly="state not in ['draft']"/>
                            <field name="date"/>
                             <field name="company_id" readonly="1"/>
                            <field name="fleet_vehicle_odometer_id"
                                   invisible="fleet_vehicle_odometer_id == False"
                                   readonly="state not in ['draft']"
                            />
                        </group>
                    </group>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tree_bim_tms_shipment" model="ir.ui.view">
        <field name="name">view.tree.bim.tms.shipment</field>
        <field name="model">tms.shipment</field>
        <field name="arch" type="xml">
            <list delete="1"
                  decoration-danger="state == 'draft'"
                  decoration-info="state == 'cancel'"
                  decoration-muted="state == 'confirmed'">
                <field name="name"/>
                <field name="bim_transport_equipment_id" optional="show"/>
                <field name="bim_project_origin_id" optional="show"/>
                <field name="bim_project_destination_id" optional="show"/>

                <field name="driver_id" optional="show"/>

                <field name="begin_kilometers" optional="show"/>
                <field name="end_kilometers" optional="show"/>

                <field name="currency_id" optional="hide"/>

                <field name="price" optional="show"
                       groups="base_bim_2.group_bim_admin_trips"
                       widget="monetary" options="{'currency_field': 'currency_id'}"
                />
                <field name="qty" sum="sum" optional="show"/>
                <field name="total"
                       groups="base_bim_2.group_bim_admin_trips"
                       widget="monetary" options="{'currency_field': 'currency_id'}"
                       sum="sum" optional="show"/>
                <field name="date" optional="show"/>
                <field name="create_date" optional="hide"/>
                <field name="company_id" optional="show"/>
                <field name="state" optional="show"/>
            </list>
        </field>
    </record>


    <record id="action_bim_tms_shipment" model="ir.actions.act_window">
        <field name="name">Bim tms shipment</field>
        <field name="res_model">tms.shipment</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new shipment
            </p>
        </field>
    </record>

    <record id="confirm_tms_shipment" model="ir.actions.server">
            <field name="name">Confirmar</field>
            <field name="model_id" ref="base_bim_2.model_tms_shipment"/>
            <field name="binding_model_id" ref="base_bim_2.model_tms_shipment"/>
            <field name="binding_view_types">list,form</field>
            <field name="state">code</field>
            <field name="code">
            if records:
                res = records.action_confirm_tms_shipment()
            </field>
        </record>

</odoo>