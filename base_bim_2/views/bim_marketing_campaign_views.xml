<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_form_bim_marketing_campaign" model="ir.ui.view">
            <field name="name">view.form.bim.marketing.campaign</field>
            <field name="model">bim.marketing.campaign</field>
            <field name="arch" type="xml">
                <form string="Bim Marketing Campaign">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" required="1"/>
                                <field name="type"/>
                                <field name="text_contact"/>
                                <field name="company_id"/>
                                <field name="bim_project_id"/>
                                <field invisible="type == 'ticket'" name="utm_campaign_id"/>
                            </group>
                            <group>
                                <field name="url" readonly="1" widget="url"/>
                                <field name="user_id" required="1"/>
                                <field name="partner_id"/>
                                <field name="key"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form></field>
        </record>
        <record id="view_tree_bim_marketing_campaign" model="ir.ui.view">
            <field name="name">view.tree.bim.marketing.campaign</field>
            <field name="model">bim.marketing.campaign</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="type"/>
                    <field name="url" widget="url"/>
                    <field name="user_id"/>
                    <field name="partner_id"/>
                    <field name="utm_campaign_id"/>
                    <field name="active"/>
                </list></field>
        </record>
        <record id="action_bim_marketing_campaign" model="ir.actions.act_window">
            <field name="name">Bim Marketing Campaign</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">bim.marketing.campaign</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_tree_bim_marketing_campaign"/>
        </record>
    </data>
</odoo>
