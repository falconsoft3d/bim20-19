<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_form_project_estimate" model="ir.ui.view">
        <field name="name">view.form.project.estimate</field>
        <field name="model">project.estimate</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button class="oe_highlight" invisible="state != 'draft'" name="exe_load" string="To Load" type="object"/>
                    <button class="oe_highlight" invisible="state != 'loaded'" name="exe_validate" string="To Validate" type="object"/>
                    <button class="oe_highlight" invisible="state != 'validated'" name="exe_load_2" string="To Load" type="object"/>
                    <button invisible="state != 'loaded'" name="exe_draft" string="To Draft" type="object"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" readonly="state in ('validated', 'cancelled')" required="1"/>
                            <field domain="[('project_id', '=', project_id)]" name="budget_id" readonly="state != 'draft'" required="1"/>
                            <field domain="[('budget_id', '=', budget_id)]" name="bim_budget_stage_id" readonly="state != 'draft'" required="1"/>
                            <field name="amount_total" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="include_bim"/>
                            <field name="type" readonly="state != 'draft'" required="1"/>
                            <field name="type_search" readonly="state != 'draft'" required="1"/>
                            <field name="user_id" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                            <field name="date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="Lista" string="Lista">
                            <field name="line_ids" readonly="state in ('validated', 'cancelled')">
                                <list create="0" decoration-muted="quantity == 0" delete="0" editable="bottom" string="Lines">
                                    <field name="project_id" optional="hide" readonly="1"/>
                                    <field name="budget_id" optional="hide" readonly="1"/>
                                    <field name="date" optional="hide" readonly="1"/>
                                    <field name="concept_id" optional="show" readonly="1"/>
                                    <field name="productc_id" optional="show" readonly="1"/>
                                    <field name="budget_amount" optional="show" options="{'currency_field': 'currency_id'}" readonly="1" sum="sum" widget="monetary"/>
                                    <field name="quantity_budget" optional="show" readonly="1" sum="sum"/>
                                    <field name="quantity_acu" optional="show" readonly="1" sum="sum"/>
                                    <field force_save="1" name="quantity" optional="show" sum="sum"/>
                                    <field name="price_unit" optional="show" options="{'currency_field': 'currency_id'}" widget="monetary"/>
                                    <field invisible="True" name="currency_id"/>
                                    <field name="amount" optional="show" options="{'currency_field': 'currency_id'}" sum="sum" widget="monetary"/>
                                </list></field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form></field>
    </record>
    <record id="view_tree_project_estimate" model="ir.ui.view">
        <field name="name">view.tree.project.estimate</field>
        <field name="model">project.estimate</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'draft'" decoration-muted="state == 'cancel'" decoration-primary="state=='loaded'" delete="0">
                <field name="name"/>
                <field name="project_id"/>
                <field name="budget_id"/>
                <field name="date"/>
                <field name="type"/>
                <field name="user_id"/>
                <field name="company_id"/>
                <field name="create_date"/>
                <field name="amount_total" options="{'currency_field': 'currency_id'}" sum="sum" widget="monetary"/>
                <field invisible="True" name="currency_id"/>
                <field name="state"/>
            </list></field>
    </record>
    <record id="action_project_estimate" model="ir.actions.act_window">
        <field name="name">Project Estimate</field>
        <field name="res_model">project.estimate</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem action="action_project_estimate" id="bim_project_estimate" name="Project Estimate"
              parent="submenu_bim_certification" sequence="90"/>
    <record id="view_tree_project_estimate_line" model="ir.ui.view">
        <field name="name">view.tree.project.estimate.line</field>
        <field name="model">project.estimate.line</field>
        <field name="arch" type="xml">
            <list create="0" decoration-danger="state == 'draft'" decoration-muted="state == 'cancel'" decoration-primary="state=='loaded'" delete="0" edit="0">
                <field name="id"/>
                <field name="project_estimate_id"/>
                <field name="project_id"/>
                <field name="budget_id"/>
                <field name="date"/>
                <field name="company_id"/>
                <field name="create_date"/>
                <field name="amount" options="{'currency_field': 'currency_id'}" sum="sum" widget="monetary"/>
                <field invisible="True" name="currency_id"/>
                <field name="state"/>
            </list></field>
    </record>
    <record id="action_project_estimate_line" model="ir.actions.act_window">
        <field name="name">Project Estimate Line</field>
        <field name="res_model">project.estimate.line</field>
        <field name="view_mode">list</field>
    </record>
    <menuitem action="action_project_estimate_line" id="bim_project_estimate_line" name="Project Estimate Line" parent="submenu_bim_certification" sequence="90"/>
</odoo>
