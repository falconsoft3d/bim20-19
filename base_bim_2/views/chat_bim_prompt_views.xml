<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="chat_bim_prompt_view_tree" model="ir.ui.view">
            <field name="name">chat.bim.prompt.view.tree</field>
            <field name="model">chat.bim.prompt</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="chat_bim_prompt_view_form" model="ir.ui.view">
            <field name="name">chat.bim.prompt.view.form</field>
            <field name="model">chat.bim.prompt</field>
            <field name="arch" type="xml">
                <form string="Chat BIM Prompt">
                    <sheet>
                     <group>
                            <group>
                                <field name="name" required="1"/>
                                <field name="prompt"
                                       widget="code"
                                       required="1"/>
                            </group>
                     </group>
                    </sheet>

                    <chatter/>
                </form>
            </field>
        </record>

        <record id="chat_bim_prompt_action" model="ir.actions.act_window">
            <field name="name">Chat BIM Prompt</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">chat.bim.prompt</field>
            <field name="view_mode">list,form</field>
        </record>


    </data>
</odoo>