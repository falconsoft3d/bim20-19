<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_tree_bim_concept_template_group" model="ir.ui.view">
        <field name="name">view.tree.bim.concept.template.group</field>
        <field name="model">bim.concept.template.group</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="parent_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- bim.concept.template search view -->
    <record id="bim_concept_template_group_view_search" model="ir.ui.view">
        <field name="name">bim.concept.template.view.search</field>
        <field name="model">bim.concept.template.group</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="view_form_bim_concept_template_group" model="ir.ui.view">
        <field name="name">view.form.bim.concept.template</field>
        <field name="model">bim.concept.template.group</field>
        <field name="arch" type="xml">
            <form string="Concepts">
                <sheet>
                    <div>
                        <h1>
                            <field name="code" placeholder="Code"  class="oe_inline" required="True"/> -
                            <field name="name" placeholder="Description" class="oe_inline"/>
                        </h1>
                    </div>

                    <group name="budget_concept_template_group">
                      <group>
                            <field name="parent_id" options="{'no_create': True}"/>
                      </group>

                      <group name="calculations">
                           <field name="user_id"/>
                           <field name="company_id" groups="base.group_multi_company"/>
                      </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_bim_concept_template_group" model="ir.actions.act_window">
        <field name="name">Concept Template Group</field>
        <field name="res_model">bim.concept.template.group</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new Concept Template Group!
            </p>
        </field>
    </record>

    <menuitem
        id="submenu_bim_concept_template_groups"
        name="Concept Template Group"
        parent="base_bim_2.menu_bim_concept_templates"
        action="action_bim_concept_template_group"
        sequence="2"/>


</odoo>
