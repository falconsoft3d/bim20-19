<?xml version="1.0" encoding="utf-8"?>
<odoo>




    <record id="update_retention" model="ir.actions.server">
            <field name="name">Actualizar Retención</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
            if records:
                res = records.action_update_retention()
            </field>
        </record>


    <record id="bim_move_tree" model="ir.ui.view">
        <field name="name">bim.base.move.tree</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <field name="invoice_date" position="before">
                <field name="include_for_bim" optional="hide" widget="boolean_toggle"/>
                <field name="retention" optional="hide"/>
                <field name="project_id" optional="show"/>
                <field name="bim_recurring_contract_id" optional="hide"/>
                <field name="cost_settlement_id" optional="hide"/>
            </field>

            <field name="amount_total_in_currency_signed" position="after">
                <field name="total_pay_retention" optional="hide"/>
            </field>

            </field>
    </record>


    <record id="bim_move_form" model="ir.ui.view">
        <field name="name">bim.base.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <notebook position="inside">
                <page string="BIM" name="bim">
                  <group>
                    <group>
                        <field name="certification_now_origin" />
                        <field name="certification_now_last" />
                    </group>
                    <group>
                        <field name="bim_massive_certification_by_line_id"
                               options='{"no_create": 1}'
                               />
                    </group>
                   </group>
                    <group>
                    <group>
                        <button name="create_purchase_valuation" string="Crear Valorización" type="object" class="oe_highlight"/>
                    </group>
                    <group>
                    </group>
                   </group>
                </page>
            </notebook>


            <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/div[1]" position="after">
                <field name="include_for_bim" widget="boolean_toggle" string="Include for Bim"/>
                <field name="project_id" options='{"no_create": 1}' readonly="state != 'draft'"/>
                <field invisible="include_for_bim" name="date_include_for_bim"/>
            </xpath>

            <!--
            <field name="partner_id" position="after">
                <field name="include_for_bim" widget="boolean_toggle" string="Include for Bim"/>
                <field name="project_id" options="{&quot;no_create&quot;: 1}" readonly="state != 'draft'"/>
                <field invisible="include_for_bim" name="date_include_for_bim"/>
           </field>
           -->

            <field name="invoice_date" position="after">
                <field name="retention_percentage" readonly="state != 'draft'"/>
                <field name="retention" readonly="state != 'draft'"/>
                <field invisible="move_type in ['in_invoice','in_refund','out_invoice','out_refund']" name="bim_classification" readonly="state != 'draft'"/>
                <field name="workorder_id"
                       invisible="workorder_id == False"
                       options='{"no_create": 1}'/>
            </field>

            <group name="accounting_info_group" position="inside">
                <field name="bim_recurring_contract_id"/>
            </group>

            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='analytic_distribution']" position="attributes">
                <attribute name="force_save">
                    True</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='quantity']" position="before">
                <field optional="hide" name="bim_multi_project"/>
                <field optional="hide" name="budget_ids" widget="many2many_tags"/>
                <field name="project_id" optional="hide"/>
                <field name="budget_id" optional="hide" options='{"no_create": 1, "no_open": 1}'/>
                <field name="concept_id" optional="hide"/>
                <field name="concept_phase_id" optional="hide"/>
            </xpath></field>
    </record>
</odoo>
