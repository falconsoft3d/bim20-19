<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_form_bim_project_employee_timesheet_summary" model="ir.ui.view">
        <field name="name">view.form.bim.project.employee.timesheet.summary</field>
        <field name="model">bim.project.employee.timesheet.summary</field>
        <field name="arch" type="xml">
            <form delete="0" string="Report">
                <header>
                    <button class="oe_highlight" confirm="Are you sure you want to set to done?" invisible="state not in ['draft']" name="action_load" string="Load" type="object"/>
                    <button confirm="Are you sure you want to clear lines?" invisible="state not in ['draft']" name="action_clear" string="Clear Lines" type="object"/>
                    <button confirm="Are you sure you want to set to draft?" invisible="state not in ['cancel']" name="action_draft" string="Set to Draft" type="object"/>
                    <button class="oe_highlight" confirm="Are you sure you want to set to approve?" invisible="state not in ['done']" name="action_approve" string="Set to approved" type="object"/>
                    <button class="oe_highlight" confirm="Are you sure you want to create invoice?" invisible="state not in ['approved']" name="action_create_invoice" string="Create invoice" type="object"/>
                    <button invisible="state not in ['draft','done','approved']" name="action_email_send" string="Send by Email" type="object"/>
                    <button confirm="Are you sure you want to cancel?" invisible="state not in ['draft','done','approved']" name="action_cancel" string="Cancel" type="object"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="customer_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="invoice_id" options="{'no_create': True}"/>
                            <field name="date_create" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_hours" readonly="1"/>
                            <field name="total_cost" readonly="1"/>
                            <field name="total_price" readonly="1"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="timesheet_lines" string="Timesheet Lines">
                            <field name="timesheet_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="bim_project_employee_timesheet"/>
                                    <field name="project_id"/>
                                    <field name="budget_id"/>
                                    <field name="concept_id"/>
                                    <field name="task_id"/>
                                    <field name="bim_extra_hour"/>
                                    <field name="date"/>
                                    <field name="total_hours" sum="sum"/>
                                    <field name="work_cost" sum="sum"/>
                                    <field name="work_price" sum="sum"/>

                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form></field>
    </record>
    <record id="view_tree_bim_project_employee_timesheet_summary" model="ir.ui.view">
        <field name="name">view.tree.bim.project.employee.timesheet.summary</field>
        <field name="model">bim.project.employee.timesheet.summary</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'draft'" decoration-muted="state == 'cancel'" decoration-primary="state=='approved'">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="date_create"/>
                <field name="invoice_id"/>
                <field name="total_hours" sum="sum"/>
                <field name="total_cost" sum="sum"/>
                <field name="total_price" sum="sum"/>
                <field name="company_id"/>
                <field name="state"/>
            </list></field>
    </record>
    <record id="action_bim_project_employee_timesheet_summary" model="ir.actions.act_window">
        <field name="name">Timesheet summary</field>
        <field name="res_model">bim.project.employee.timesheet.summary</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new attendance timesheet summary!
            </p></field>
    </record>

</odoo>
