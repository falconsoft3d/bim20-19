                    <field name="concept_id" options='{"no_create": 1, "no_open": 1}' groups="base_bim_2.group_budget_concept_documents"/></field>-->
                <div name="button_box" position="inside">
                    <button class="oe_stat_button" groups="base_bim_2.group_user_bim" icon="fa-money" invisible="budget_count == 0" name="action_view_budgets" string="Budgets" type="object">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_value">
                                <field name="budget_count" nolabel="1" widget="statinfo"/>
                            </span>
                            <span class="o_stat_text">
                                Budgets
                            </span>
                        </div>
                    </button>
                </div></field>
        </record>
