<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_form_cost_date" model="ir.ui.view">
        <field name="name">view.form.cost.date</field>
        <field name="model">cost.date</field>
        <field name="arch" type="xml">
            <form string="order">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="cost"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="begin_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tree_cost_date" model="ir.ui.view">
        <field name="name">view.tree.cost.date</field>
        <field name="model">cost.date</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="begin_date"/>
                <field name="end_date"/>
                <field name="cost" sum="sum" />
                <field name="company_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="action_cost_date" model="ir.actions.act_window">
        <field name="name">Cost Date</field>
        <field name="res_model">cost.date</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new Cost Date
            </p>
        </field>
    </record>

</odoo>