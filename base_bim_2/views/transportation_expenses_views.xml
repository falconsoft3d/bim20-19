<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_form_bim_transportation_expenses" model="ir.ui.view">
        <field name="name">view.form.bim.transportation.expenses</field>
        <field name="model">transportation.expenses</field>
        <field name="arch" type="xml">
            <form string="order">
                <sheet>
                    <div class="oe_title">
                       <h1>
                           <field name="name" readonly="1"
                                  class="oe_inline" colspan="1"/>
                       </h1>
                    </div>
                    <group>
                        <group>
                            <field name="description"
                                   options="{'no_create': True}"/>

                             <field name="product_id"
                                   options="{'no_create': True}"/>

                            <field name="account_analytic_account_id"
                                      options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="type"/>
                            <field name="price"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tree_bim_transportation_expenses" model="ir.ui.view">
        <field name="name">view.tree.bim.transportation.expenses</field>
        <field name="model">transportation.expenses</field>
        <field name="arch" type="xml">
            <list delete="1">
                <field name="name"/>
                <field name="description"/>
                <field name="product_id" optional="show"/>
                <field name="account_analytic_account_id" optional="show"/>
                <field name="type" optional="show"/>
                <field name="price" optional="show"/>
                <field name="company_id" optional="show"/>
            </list>
        </field>
    </record>

    <record id="action_bim_transportation_expenses" model="ir.actions.act_window">
        <field name="name">Bim Transportation Expenses</field>
        <field name="res_model">transportation.expenses</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new transportation expenses
            </p>
        </field>
    </record>

</odoo>