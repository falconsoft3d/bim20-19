<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_bim_product_group" model="ir.ui.view">
        <field name="name">view.form.product.group</field>
        <field name="model">bim.product.group</field>
        <field name="arch" type="xml">
            <form string="Product Group">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="name"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tree_bim_ite" model="ir.ui.view">
        <field name="name">view.tree.bim.ite</field>
        <field name="model">bim.product.group</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_bim_product_group" model="ir.actions.act_window">
        <field name="name">BIM Product Group</field>
        <field name="res_model">bim.product.group</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new Entry!
            </p>
        </field>
    </record>


    </data>

</odoo>
