<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_inherit_template_product_form" model="ir.ui.view">
        <field name="name">view.inherit.template.product.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button invisible="default_code == False" name="%(action_update_product_from_master)d" string="Update From Master" type="action" class="oe_stat_button" icon="fa-refresh"/>
            </div>
            <xpath expr="//div[@name='options']" position="after">
                <div name="tool_ok">
                    <field name="tool_ok"/>
                    <label for="tool_ok"/>
                </div>
            </xpath>
            <xpath expr="//field[@name='taxes_id']" position="after">
                <field invisible="tool_ok == False" name="deprecation_days" style="width:30%;"/>
            </xpath>
            <xpath expr="//field[@name='barcode']" position="after">

                <field name="resource_type" required="1"/>
                <field invisible="True" name="last_sec"/>
                <field name="id_bim"/>

                <field invisible="type != 'service'" name="sub_contract"/>
                <field invisible="resource_type != 'Q'" name="depreciation"/>
                <field invisible="resource_type != 'H'" name="bonus"/>

            </xpath>
            <notebook>
                <page string="Bim">
                    <group>
                        <group>
                            <field name="bim_check_uom"/>
                            <field name="bim_group_id"/>
                            <field name="ite_id"/>
                            <field invisible="virtual_product_id == False" name="virtual_product_id"/>
                        </group>
                        <group>
                            <field name="rubro_id" options='{"no_create": 1}' widget="many2one"/>
                            <field name="srubro_id" options='{"no_create": 1}' widget="many2one" dmomain="[('parent_id','=',rubro_id)]"/>
                        </group>
                    </group>
                </page>
                <page string="Docs">
                    <field name="document_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="name" required="1"/>
                            <field invisible="True" name="comprobante_01_name"/>
                            <!--  class="oe_read_only" -->
                            <field filename="comprobante_01_name" name="comprobante_01" widget="binary"/>
                            <!--  class="oe_edit_only" -->
                            <field name="entry_date" readonly="1"/>
                            <field name="user_id" readonly="1" sum="T"/>
                        </list></field>
                </page>
                <page string="Spare parts">
                    <field name="change_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="code_id" options='{"no_create": 1}' required="1" string="Spare product code"/>
                            <field name="product_id" options='{"no_create": 1}' required="1" string="Spare product name"/>
                            <field name="qty" required="1" string="Quantity"/>
                            <field name="position" required="1" string="Position"/>
                        </list></field>
                </page>
                <page string="P. History">
                    <field name="bim_purchase_ids" nolabel="1" readonly="1">
                        <list editable="bottom">
                            <field name="product_id"/>
                            <field name="purchase_id"/>
                            <field name="supplier_id"/>
                            <field name="project_id"/>
                            <field name="quantity"/>
                            <field name="purchase_price"/>
                            <field name="date"/>
                        </list>
                    </field>
                </page>
            </notebook></field>
    </record>



    <!-- Variant form -->
    <record id="view_inherit_product_variant_form" model="ir.ui.view">
        <field name="name">view.inherit.product.variant.form</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="bim_group_id"/>
                <field name="resource_type" required="1"/>
                <field invisible="True" name="last_sec"/>
            </xpath>

            <div name="button_box" position="inside">
                   <button class="oe_stat_button" icon="fa-cogs"
                                name="action_view_maintenance_assets"
                                string="Assets" type="object">
                            <field name="count_maintenance_assets" string="Assets" widget="statinfo"/>
                   </button>
            </div>
        </field>



    </record>
    <record id="view_inherit_product_template_tree" model="ir.ui.view">
        <field name="name">view.inherit.product.template.tree</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="after">
                <field name="bim_group_id" optional="hide"/>
                <field name="virtual_product_id" optional="hide" widget="many2one"/>
            </xpath>
            <field name="standard_price" position="after">
                <field name="cost_usd"  optional="hide"/>
                <field name="rubro_id"
                       widget="many2one"
                       optional="hide"/>
                <field name="srubro_id"
                       widget="many2one"
                       optional="hide"/>
            </field>
        </field>
    </record>

    <record id="product_template_hr_deliver_products" model="ir.ui.view">
        <field name="name">product.template.hr.deliver.products</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="is_activo"/>
                <field name="expiration_days"/>
                <field name="cost_usd" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
