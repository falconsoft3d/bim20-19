<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="view_form_budget_category" model="ir.ui.view">
            <field name="name">view.form.budget.category</field>
            <field name="model">budget.category</field>
            <field name="arch" type="xml">
                <form string="Budget Category">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" required="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tree_budget_category" model="ir.ui.view">
            <field name="name">view.tree.budget.category</field>
            <field name="model">budget.category</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="action_budget_category" model="ir.actions.act_window">
            <field name="name">category</field>
            <field name="res_model">budget.category</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create a new Category!
                </p>
            </field>
        </record>

    </data>
</odoo>