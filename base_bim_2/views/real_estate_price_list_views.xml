<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_real_estate_price_list" model="ir.ui.view">
        <field name="name">view.form.real.estate.price.list</field>
        <field name="model">real.estate.price.list</field>
        <field name="arch" type="xml">
            <form string="State">
                <sheet>
                    <div class="oe_title">
                       <h1>
                           <field name="name"/>
                       </h1>
                    </div>
                    <group>
                         <group>
                             <field name="number_quotas"/>
                             <field name="initial_payment"/>
                             <field name="initial_percentage"/>
                             <field name="type_price"/>
                        </group>
                        <group>
                            <field name="price"/>
                            <field name="company_id"/>
                            <field name="currency_id"/>
                            <field name="user_id"/>
                        </group>
                    </group>
                 </sheet>
            </form>
        </field>
    </record>

    <record id="view_tree_real_estate_price_list" model="ir.ui.view">
        <field name="name">view.tree.real.estate.price.list</field>
        <field name="model">real.estate.price.list</field>
        <field name="arch" type="xml">
            <list>
                 <field name="name"/>
                 <field name="number_quotas"/>
                 <field name="type_price"/>
                 <field name="initial_payment"/>
                 <field name="initial_percentage"/>
                 <field name="price" sum="sum"/>
                 <field name="company_id"/>
                 <field name="currency_id"/>
                 <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="action_real_estate_price_list" model="ir.actions.act_window">
        <field name="name">Price List</field>
        <field name="res_model">real.estate.price.list</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new state!
            </p>
        </field>
    </record>

    </data>


</odoo>