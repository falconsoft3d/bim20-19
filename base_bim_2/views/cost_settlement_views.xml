<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="cost_settlement_view_tree" model="ir.ui.view">
            <field name="name">cost.settlement.view.tree</field>
            <field name="model">cost.settlement</field>
            <field name="arch" type="xml">
                <list decoration-danger="state == 'draft'" decoration-muted="state == 'cancel'">
                    <field name="name"/>
                    <field name="user_id" optional="show"/>
                    <field name="begin_date" optional="show"/>
                    <field name="end_date" optional="show"/>
                    <field name="project_id" optional="show"/>
                    <field name="budget_id" optional="show"/>
                    <field name="create_date" optional="show"/>
                    <field name="company_id" optional="show"/>
                    <field name="stage_id" optional="show"/>
                    <field name="bim_massive_certification_by_line_id" optional="show"/>
                    <field name="state" optional="show"/>
                </list></field>
        </record>

        <record id="cost_settlement_view_form" model="ir.ui.view">
            <field name="name">cost.settlement.view.form</field>
            <field name="model">cost.settlement</field>
            <field name="arch" type="xml">
                <form string="Cost Settlement">
                    <header>
                        <button class="oe_highlight" invisible="state not in ['draft']" name="action_read" string="Read" type="object"/>
                        <button confirm="Are you sure you want to set this survey to draft?"
                                invisible="state in ['draft']"
                                name="action_draft" string="Draft" type="object"/>
                         <button class="oe_highlight" invisible="state not in ['read']" name="action_done" string="To Done" type="object"/>
                         <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="project_id"
                                       options='{"no_create": 1, "no_open": 1}' readonly="state not in 'draft'"
                                       widget="many2one"/>
                                <field domain="[('project_id','=',project_id)]"
                                       name="budget_id" options='{"no_create": 1, "no_open": 1}'
                                       readonly="state not in 'draft'"
                                       widget="many2one"/>
                                <field name="begin_date"
                                       readonly="state not in 'draft'"
                                       required="1"/>
                                <field name="end_date"
                                       readonly="state not in 'draft'"
                                       required="1"/>
                            </group>
                            <group>
                                <field name="user_id" readonly="state not in 'draft'"/>
                                <field name="create_date" readonly="state not in 'draft'"/>
                                <field name="company_id" readonly="state not in 'draft'"/>
                                <field name="stage_id"
                                       readonly="state not in 'draft'"
                                       domain="[('budget_id','=',budget_id)]"/>
                                <field name="bim_massive_certification_by_line_id" readonly="state not in 'draft'"/>
                            </group>
                        </group>

                        <notebook>
                            <page name="lines" string="Lines">
                                <field name="line_ids" nolabel="1" readonly="1">
                                    <list editable="bottom">
                                        <field name="account_id" optional="show"/>
                                        <field name="concept_id" optional="show"/>
                                        <field name="product_id" optional="show"/>
                                        <field name="quantity" optional="show" sum="sum"/>
                                        <field name="price_unit" optional="show"/>
                                        <field name="total" optional="show" sum="sum"/>

                                        <field name="qty_departure" optional="show" sum="sum"/>
                                        <field name="qty_certification" optional="show" sum="sum"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form></field>
        </record>

        <record id="cost_settlement_action" model="ir.actions.act_window">
            <field name="name">Cost Settlement</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">cost.settlement</field>
            <field name="view_mode">list,form</field>
        </record>



    </data>
</odoo>