<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_bim_rq" model="ir.ui.view">
        <field name="name">view.form.bim.rq</field>
        <field name="model">bim.rq</field>
        <field name="arch" type="xml">
            <form string="Bim rq" delete="0">
                <header>

                     <button class="oe_highlight"
                            name="action_to_review" string="To Review" type="object" invisible="state != 'draft'"/>

                        <button class="oe_highlight"
                            name="action_approve" string="Approve" type="object" invisible="state != 'review'"/>

                      <button
                            name="action_reject" string="Reject" type="object" invisible="state != 'review'"/>

                        <button name="action_set_to_draft" string="Set to Draft" type="object"
                            invisible="state in ('draft')"/>

                        <button class="oe_highlight"
                            name="action_set_to_done" string="Set to Done" type="object"
                            invisible="state not in ('approved')"/>

                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                       <h1>
                           <field name="name" readonly="state != 'done'"/>
                       </h1>
                    </div>
                    <group>
                         <group>
                            <field name="user_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True, 'no_edit': True}"/>

                             <field name="partner_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True, 'no_edit': True}"/>

                             <field name="purchase_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True, 'no_edit': True}"/>
                        </group>
                        <group>
                            <field name="date" readonly="1"/>
                            <field name="date_required" options="{'no_create': True, 'no_edit': True}"/>

                            <field name="currency_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True, 'no_edit': True}"/>


                            <field name="project_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True, 'no_edit': True}"/>

                        </group>
                    </group>
                     <notebook>

                         <page name="lines" string="Lines">
                             <field name="line_ids"
                                    readonly="state != 'draft'"
                                    widget="one2many_list">
                                <list editable="bottom">
                                     <field name="project_id" optional="show"  options="{'no_create': True, 'no_edit': True}"/>
                                     <field name="budget_id" optional="show"
                                            domain="[('project_id','=',project_id)]"
                                            widget="many2onebutton" options='{"no_create": true}'/>
                                     <field name="product_id" optional="show"
                                            widget="many2onebutton" options='{"no_create": true}'/>
                                    <field name="description" optional="hide"/>
                                    <field name="qty" optional="show"/>
                                    <field name="unit_price" optional="show"/>
                                </list>
                            </field>
                        </page>
                         <page name="description" string="Description">
                              <field name="description"
                                     readonly="state != 'draft'"
                                     widget="html"/>
                          </page>
                         <page name="other-info" string="Other Information">
                             <group>
                                 <group>
                                    <field name="company_id" readonly="1" options="{'no_create': True, 'no_edit': True}"/>
                                 </group>
                             </group>
                          </page>
                     </notebook>

                 </sheet>

                <chatter/>

            </form>
        </field>
    </record>

    <record id="view_tree_bim_rq" model="ir.ui.view">
        <field name="name">view.tree.bim.rq</field>
        <field name="model">bim.rq</field>
        <field name="arch" type="xml">
            <list   delete="0"
                    decoration-danger="state == 'draft'"
                    decoration-info="state == 'review'"
                    decoration-success="state == 'done'"
                    decoration-warning="state == 'rejected'">
                <field name="name"/>
                <field name="user_id" optional="show"/>
                <field name="company_id" optional="show"/>
                <field name="date" optional="show"/>
                <field name="state"
                        decoration-danger="state == 'draft'"
                        decoration-success="state == 'done'"
                        widget="badge" optional="show"/>
            </list>
        </field>
    </record>

    <record id="action_bim_rq" model="ir.actions.act_window">
        <field name="name">Bim Rq</field>
        <field name="res_model">bim.rq</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new Bim RQ!
            </p>
        </field>
    </record>
    </data>
</odoo>