<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <record id="view_form_bim_checklist_state" model="ir.ui.view">
        <field name="name">view.form.bim.checklist.state</field>
        <field name="model">bim.checklist.state</field>
        <field name="arch" type="xml">
            <form string="Report" delete="0" >
                <sheet>                    
                    <div class="oe_title">
                       <h1>
                           <field name="name"/>
                       </h1>
                    </div>
                    <group>
                        <field name="sequence"  invisible="True"/>
                        <field name="notify"/>
                        <field name="user_ids" widget="many2many_tags" required="notify"/>
                    </group>
                 </sheet>
            </form>
        </field>
    </record>

    <record id="view_tree_bim_checklist_state" model="ir.ui.view">
        <field name="name">view.tree.bim.checklist.state</field>
        <field name="model">bim.checklist.state</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle" />
                <field name="name"/>
                <field name="is_new" invisible="True"/>
                <field name="is_done" invisible="True"/>
            </list>
        </field>
    </record>

    <record id="action_bim_checklist_state" model="ir.actions.act_window">
        <field name="name">Checklist states</field>
        <field name="res_model">bim.checklist.state</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new checklist state!
            </p>
        </field>
    </record>

    <menuitem id="submenu_bim_checklist_state"
        name="Checklist States"
        parent="base_bim_2.menu_bim_project_state"
        action="action_bim_checklist_state"
        sequence="3" />
    </data>

</odoo>
