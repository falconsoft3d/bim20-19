<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="bim_resource_template_form" model="ir.ui.view">
        <field name="name">bim.resource.template.form</field>
        <field name="model">bim.resource.template</field>
        <field name="arch" type="xml">
            <form string="Template Assets and Discounts">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="product_id" options='{"no_create": true}'/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="hr_employee_id" options='{"no_create": true}'/>
                            <field name="employee_shift_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="employee_location_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="superintendent_hr_employee_id" options="{'no_open': True, 'no_create': True}"/>
                        </group>
                        <group>
                            <field name="is_active"
                                   widget="boolean_toggle"
                            />
                            <field name="sup_hr_employee_id" options='{"no_create": true}'/>
                            <field name="employee_discipline_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="employee_area_id" options="{'no_open': True, 'no_create': True}"/>
                            <field name="bim_pcp_ids" widget="many2many_tags" options="{'no_open': True, 'no_create': True}"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Resources" name="resources">
                            <field name="line_ids" context="{'default_template_id': id}" copy="True">
                                <list editable="bottom">
                                    <field name="sequence" optional="hide"/>
                                    <field name="resource_type" optional="hide"/>
                                    <field name="product_id" optional="show" options='{"no_create": true}'/>
                                    <field name="hr_employee_id" optional="show"/>
                                    <field name="quantity" sum="sum" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Data" name="data">
                            <group>
                                <group>
                                    <field name="categories_ids" widget="many2many_tags"/>
                                    <field name="product_ids" widget="many2many_tags"/>
                                </group>
                                <group>
                                    <field name="company_id" options='{"no_create": true}'/>
                                    <field name="desc"/>
                                    <field name="active" invisible="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Other" name="other">
                            <group>
                                <group>
                                    <field name="name"/>
                                </group>
                                <group>
                                </group>
                            </group>
                        </page>

                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="bim_resource_template_tree" model="ir.ui.view">
        <field name="name">bim.resource.template.tree</field>
        <field name="model">bim.resource.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="product_id" optional="hide"/>
                <field name="hr_employee_id"/>
                <field name="sup_hr_employee_id"/>
                <field name="employee_discipline_id" optional="hide"/>
                <field name="desc" optional="show"/>
                <field name="company_id" optional="show"/>
                <field name="is_active" />
            </list>
        </field>
    </record>

    <record id="bim_resource_template_action" model="ir.actions.act_window">
        <field name="name">Resource Template</field>
        <field name="res_model">bim.resource.template</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="bim_resource_template_tree"/>
    </record>
</odoo>
