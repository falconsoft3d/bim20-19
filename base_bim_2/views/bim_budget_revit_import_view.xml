<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--Odoo tree vie-->
    <record id="view_tree_bim_budget_revit_import" model="ir.ui.view">
        <field name="name">tree.bim.budget.revit.import</field>
        <field name="model">bim.budget.revit.import</field>
        <field name="arch" type="xml">
            <list create="0" delete="0">
                <field name="name"/>
                <field name="budget_id"/>
                <field name="project_id"/>
                <field name="create_uid" optional="show"/>
                <field name="create_date" optional="show"/>
                <field name="file_name" invisible="True"/>
                <field name="file" filename="file_name" widget="binary" class="oe_inline"/>
                <field name="log" optional="show"/>
                <field name="company_id" invisible="True"/>
            </list>
        </field>
    </record>

    <record id="action_bim_budget_revit_import" model="ir.actions.act_window">
        <field name="name">Budget Revit Import</field>
        <field name="res_model">bim.budget.revit.import</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_bim_budget_import_log"
        name="Budget import log"
        action="action_bim_budget_revit_import"
        parent="menu_bim_import_bim"
        sequence="120" />

</odoo>
