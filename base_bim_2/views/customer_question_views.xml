<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="customer_question_view_tree" model="ir.ui.view">
            <field name="name">customer.question.view.tree</field>
            <field name="model">customer.question</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="long"/>
                    <field name="company_id"/>
                </list>
            </field>
        </record>

        <record id="customer_question_view_form" model="ir.ui.view">
            <field name="name">customer.question.view.form</field>
            <field name="model">customer.question</field>
            <field name="arch" type="xml">
                <form string="Customer Question">
                    <sheet>
                     <group>
                            <group>
                                <field name="name"/>
                                <field name="long"/>
                            </group>
                            <group>
                                <field name="company_id"/>
                             </group>
                     </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="customer_question_action" model="ir.actions.act_window">
            <field name="name">Customer Question</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">customer.question</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_customer_evaluation"
            name="Customer Evaluation"
            parent="menu_bim_documentation_categ"
            sequence="10" >

                <menuitem id="menu_bim_customer_question"
                name="Customer Question"
                action="customer_question_action"
                sequence="10" />

        </menuitem>


    </data>
</odoo>