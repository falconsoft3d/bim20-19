<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="base_bim_2.budget_resource">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="o">
        <t t-call="base_bim_2.bim_header_external_layout">
          <div class="page">
            <style  type="text/css">
                  th, td {
                    vertical-align: middle !important;
                  }
            </style>
            <h3 class="text-center">RESOURCES LIST</h3>

            <table class="table table-sm" style="width:100%;">
                <tr>
                    <th class="text-center" style="border:1px solid black;width:40%;">PROJECT</th>
                    <th class="text-center text-uppercase" style="border:1px solid black;width:40%;"><span t-field="o.budget_id.name"/></th>
                    <th t-if="o.filter_categ" class="text-center" style="border:1px solid black;">CATEGORY</th>
                    <th class="text-center" style="border:1px solid black;width:20%;">PRINTING DATE</th>
                </tr>
                <tr>
                    <td class="text-center"><span t-field="o.budget_id.project_id"/></td>
                    <td class="text-center"><span t-field="o.budget_id.display_name"/></td>
                    <td t-if="o.filter_categ" class="text-center"><span t-field="o.category_id.name"/></td>
                    <td class="text-center"><span t-esc="datetime.datetime.now().strftime('%d/%m/%Y')"/></td>
                </tr>
            </table>
            <br/>
            <div class="row">
                 <t t-set="total_material" t-value="0"/>
                 <t t-set="total_labor" t-value="0"/>
                 <t t-set="total_equipment" t-value="0"/>
                 <t t-set="total_aux" t-value="0"/>
                 <t t-set="total_subcontract" t-value="0"/>

                <t t-set="resources" t-value="o.get_resources(o.material,o.labor,o.equipment,o.subcontract)"/>
                <t t-set="functions" t-value="o.get_function(o.aux)"/>
                <t t-set="subcontracts" t-value="o.get_sucontract()"/>

                <table class="table table-sm main_table" style="font-size:10px;">
                    <thead>
                        <tr class="active">
                            <th>CODE</th>
                            <th>RESOURCE</th>
                            <th>TYPE</th>
                            <th>UNIT</th>
                            <th class="text-right">QUANTITY</th>
                            <th class="text-right">WEIGHT</th>
                            <th class="text-right">COST</th>
                        </tr>
                    </thead>

                    <tbody>


                      <tr t-foreach="resources" t-as="res">
                        <t t-set="weight" t-value="round(o.get_weight(res.id),2)"/>
                        <td><span t-field="res.code" /></td>
                        <td><span t-field="res.name" /></td>
                        <td><span t-field="res.resource_type"/></td>
                        <td><span t-field="res.uom_id"/></td>
                        <td class="text-right"><span t-esc="round(o.get_quantity(res.id,o.subcontract),3)"/></td>
                        <td class="text-right"><span t-if="weight &gt; 0" t-esc="weight" /><span t-if="weight &lt;= 0" t-esc="'-'" /></td>
                        <td class="text-right"><span t-esc="o.get_total(res.id,o.subcontract)" t-options="{'widget': 'monetary', 'display_currency': o.budget_id.currency_id}"/></td>

                        <t t-if="res.resource_type == 'M'">
                          <t t-set="total_material" t-value="total_material + o.get_total(res.id,o.subcontract)"/>
                        </t>

                        <t t-if="res.resource_type == 'H'">
                          <t t-set="total_labor" t-value="total_labor + o.get_total(res.id,o.subcontract)"/>
                        </t>

                        <t t-if="res.resource_type == 'Q'">
                          <t t-set="total_equipment" t-value="total_equipment + o.get_total(res.id,o.subcontract)"/>
                        </t>

                        <t t-if="res.resource_type == 'aux'">
                          <t t-set="total_aux" t-value="total_aux + o.get_total(res.id,o.subcontract)"/>
                        </t>

                        <t t-if="res.resource_type == 'S'">
                          <t t-set="total_subcontract" t-value="total_subcontract + o.get_total(res.id,o.subcontract)"/>
                        </t>


                      </tr>

                      <tr t-if="functions" t-foreach="functions" t-as="aux">
                        <td><span t-field="aux.code" /></td>
                        <td><span t-field="aux.name" /></td>
                        <td><span t-field="aux.type"/></td>
                        <td><span t-field="aux.uom_id" /></td>
                        <td class="text-right"><span t-esc="aux.amount_compute" /></td>
                        <td class="text-right">-</td>
                        <td class="text-right"><span t-esc="o.get_total_aux(aux)" t-options="{'widget': 'monetary', 'display_currency': o.budget_id.currency_id}"/></td>
                      </tr>

                      <t t-if="o.subcontract == 'separe'">
                          <tr>
                            <td><i><strong>Subcontratos</strong></i></td><td></td><td></td><td></td><td></td><td></td><td></td>
                          </tr>
                          <tr t-foreach="subcontracts" t-as="sub">
                            <td><span t-field="sub.code" /></td>
                            <td><span t-field="sub.name" /></td>
                            <td><span t-field="sub.type"/></td>
                            <td><span t-field="sub.uom_id" /></td>
                            <td class="text-right"><span t-esc="round(sub.quantity,3)" /></td>
                            <td class="text-right">-</td>
                            <td class="text-right"><span t-esc="sub.balance" t-options="{'widget': 'monetary', 'display_currency': o.budget_id.currency_id}"/></td>
                          </tr>
                      </t>
                    </tbody>
                </table>
            </div>

              <t t-if="o.show_footer">
                  <div class="col-12">
                    <table class="pull-right" style="width:40%;align:right">
                      <t t-set="totals" t-value="o.get_resources_total(o.material,o.labor,o.equipment,o.aux,o.subcontract, total_material, total_labor, total_equipment, total_aux, total_subcontract)"/>
                      <t t-foreach="totals" t-as="t">
                          <!-- if t > 0 -->
                          <t t-if="t['amount'] > 0">
                              <tr class="border-black o_subtotal">
                                <td class="text-left" colspan="3"><strong></strong></td>
                                <td class="text-left" colspan="3" style="padding:5px"><strong><span t-esc="t['name']"/></strong></td>
                                <td class="text-right" colspan="1" style="padding:5px"><strong><span t-esc="t['amount']" t-options="{'widget': 'monetary', 'display_currency': o.budget_id.currency_id}"/></strong></td>
                              </tr>
                          </t>
                      </t>
                    </table>
                </div>
            </t>


          </div>
        </t>
      </t>
    </t>
  </template>
</odoo>
