<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
         <template id="base_bim_2.certification_by_line_report">
            <t t-call="web.html_container">
              <t t-foreach="docs" t-as="o">
                <t t-call="base_bim_2.bim_header_external_layout">
                  <div class="page">
                    <style  type="text/css">
                      th, td {
                        vertical-align: middle !important;
                      }
                    </style>
                    <h3 class="text-center">REPORTE DE CERTIFICACIÓN POR LÍNEAS</h3>
                    <t t-set="budget" t-value="o.budget_id"/>
                    <table class="table table-sm" style="width:100%;">
                        <tr>
                            <th class="text-center" style="border:1px solid black;width:40%;">OBRA</th>
                            <th class="text-center text-uppercase" style="border:1px solid black;width:40%;">PRESUSPUESTO</th>
                            <th class="text-center" style="border:1px solid black;width:20%;">FECHA IMPRESIÓN</th>
                        </tr>
                        <tr>
                            <td class="text-center"><span t-field="budget.project_id"/></td>
                            <td class="text-center"><span t-field="budget.display_name"/></td>
                            <td class="text-center"><span t-esc="datetime.datetime.now().strftime('%d/%m/%Y')"/></td>
                        </tr>
                    </table>
                      <!--
                      <t t-if="o.text">
                     <div class="row pt-1 pb-auto" >
                       <div class="col-12 text-justify">
                          <span t-raw="budget.header_notes"/>
                       </div>
                    </div>
                    </t>
                      -->
                    <div class="row">
                        <table class="table table-sm main_table" style="font-size:10px;width:100%;">
                            <thead>
                                <tr>
                                    <th colspan="5" class="text-center">
                                        <t t-if="o.type == 'current_stage'">
                                            <h5>Certificación por etapas [ <span t-field="o.certification_stage_ids[0].stage_id.name"/> ] </h5>
                                        </t>
                                        <t t-else="">
                                            <h5>Certificación manual</h5>
                                        </t>
                                    </th>
                                </tr>
                                <tr>
                                    <th style="width:15%;">CÓDIGO</th>
                                    <th>PARTIDA</th>
                                    <th class="text-center">CANTIDAD</th>
                                    <th class="text-right">%</th>
                                    <th class="text-right">IMPORTE</th>
                                </tr>
                            </thead>
                        <tbody>
                            <t t-set="total" t-value="0"/>
                            <t t-if="o.type == 'current_stage'">
                                <t t-set="lines" t-value="o.certification_stage_ids"/>
                                <t t-foreach="lines" t-as="line" class="active">

                                    <t t-if="line.amount_certif > 0">

                                        <tr class="parent_row">
                                            <td class="text-left">
                                                <i t-attf-class="fa fa-{{'th-list text-warning'}} mr-2 float-left"/><em> <span t-field="line.concept_id.code"/></em>
                                            </td>
                                            <td class="text-left"><em><strong><span t-field="line.concept_id.name"/></strong></em></td>
                                            <td class="text-center"><em><span t-esc="round(line.quantity_to_cert,2)"/></em></td>
                                            <td class="text-center"><em><span t-field="line.certif_percent"/></em></td>
                                            <td class="text-end o_price_total">
                                                <em><strong t-field="line.amount_certif" t-options='{"widget": "monetary", "display_currency": budget.currency_id}'/></em>
                                            </td>
                                        </tr>

                                    </t>

                                    <t t-set="total" t-value="total+line.amount_certif"/>
                                </t>
                            </t>
                             <t t-else="">
                                <t t-set="lines" t-value="o.concept_ids"/>
                                 <t t-foreach="lines" t-as="line" class="active">

                                      <t t-if="line.amount_certif > 0">

                                         <tr class="parent_row">
                                            <td class="text-left">
                                                <i t-attf-class="fa fa-{{'th-list text-warning'}} mr-2 float-left"/><em> <span t-field="line.concept_id.code"/></em>
                                            </td>
                                            <td class="text-left"><em><strong><span t-field="line.concept_id.name"/></strong></em></td>
                                            <td class="text-center"><em><span t-esc="round(line.quantity_to_cert,2)"/></em></td>
                                            <td class="text-center"><em><span t-field="line.percent_cert"/></em></td>
                                            <td class="text-end o_price_total">
                                                <em><strong t-field="line.amount_certif" t-options='{"widget": "monetary", "display_currency": budget.currency_id}'/></em>
                                            </td>
                                        </tr>

                                      </t>


                                    <t t-set="total" t-value="total+line.amount_certif"/>
                                </t>
                            </t>



                            <tr style="font-size: 12px;">
                                <td colspan="1" style="text-align:center;"><strong>TOTAL</strong></td>
                                <td colspan="3"></td>
                                <td colspan="1" style="text-align:right;"><strong><span t-esc="total" t-options="{'widget': 'monetary', 'display_currency': budget.currency_id}"/></strong></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
              </div>
            </t>
          </t>
        </t>
    </template>
    </data>
</odoo>