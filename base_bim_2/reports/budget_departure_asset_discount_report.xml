                                        </t>
                                    </div>
                                    <div class="col-1">
                                        SUBTOTAL C...
                                    </div>
                                    <div class="col-1">
                                         <span t-esc="round(departure.apu_financing,2)"
                                          t-options="{'widget': 'monetary', 'display_currency': departure.budget_id.currency_id}"/>
