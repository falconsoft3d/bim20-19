<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="departure_details_template">
            <t t-if="concepts != []">
                <t t-set="concept_count" t-value="len(concepts)"/>
                <t t-foreach="concepts" t-as="concept">
                  <t t-set="concept_count" t-value="concept_count - 1"/>
                     <tr class="resource_row" style="font-style: italic; font-size: 10px;max-height: 11px !important;">
                        <t t-if="concept_count == 0">
                          <td class="text-left" style="width:10%; border-left:1px solid black;border-right:1px solid black;border-bottom:1px solid black;min-height: 10px !important;max-height: 10px !important;"><span t-esc="concept.code"/></td>
                          <td class="text-left" style="width:50%; border-left:1px solid black;border-right:1px solid black;border-bottom:1px solid black;min-height: 10px !important;max-height: 10px !important;"><span t-esc="concept.name"/></td>
                          <td class="text-left" style="width:10%; border-left:1px solid black;border-right:1px solid black;border-bottom:1px solid black;min-height: 10px !important;max-height: 10px !important;"><t t-if="concept.uom_id"><span t-esc="concept.uom_id.name"/></t></td>
                          <td class="text-right" style="width:10%; border-left:1px solid black;border-right:1px solid black;border-bottom:1px solid black;min-height: 10px !important;max-height: 10px !important;"><span t-esc="concept.quantity"/></td>
                          <td class="text-right" style="width:10%; border-left:1px solid black;border-right:1px solid black;border-bottom:1px solid black;min-height: 10px !important;max-height: 10px !important;"><span t-esc="concept.amount_fixed" t-options="{'widget': 'monetary', 'display_currency': concept.budget_id.currency_id}"/></td>
                          <td class="text-right" style="width:10%; border-left:1px solid black;border-right:1px solid black;border-bottom:1px solid black;min-height: 10px !important;max-height: 10px !important;"><span t-esc="concept.balance" t-options="{'widget': 'monetary', 'display_currency': concept.budget_id.currency_id}"/></td>
                        </t>
                        <t t-else="">
                          <td class="text-left" style="width:10%; border-left:1px solid black;border-right:1px solid black;"><span t-esc="concept.code"/></td>
                          <td class="text-left" style="width:50%; border-left:1px solid black;border-right:1px solid black;"><span t-esc="concept.name"/></td>
                          <td class="text-left" style="width:10%; border-left:1px solid black;border-right:1px solid black;"><t t-if="concept.uom_id"><span t-esc="concept.uom_id.name"/></t></td>
                          <td class="text-right" style="width:10%; border-left:1px solid black;border-right:1px solid black;"><span t-esc="concept.quantity"/></td>
                          <td class="text-right" style="width:10%; border-left:1px solid black;border-right:1px solid black;"><span t-esc="concept.amount_fixed" t-options="{'widget': 'monetary', 'display_currency': concept.budget_id.currency_id}"/></td>
                          <td class="text-right" style="width:10%; border-left:1px solid black;border-right:1px solid black;"><span t-esc="concept.balance" t-options="{'widget': 'monetary', 'display_currency': concept.budget_id.currency_id}"/></td>
                        </t>

                     </tr>
                </t>

            </t>
            <t t-else="">
                <tr class="resource_row" style="font-style: italic; font-size: 11px;">
                    <td class="text-left" style="border:1px solid black;width:10%;"/>
                    <td class="text-left" style="border:1px solid black;width:50%;"/>
                    <td class="text-left" style="border:1px solid black;width:10%;"/>
                    <td class="text-left" style="border:1px solid black;width:10%;"/>
                    <td class="text-left" style="border:1px solid black;width:10%;"/>
                    <td class="text-left" style="border:1px solid black;width:10%;"/>
                </tr>
            </t>
    </template>

