    <template id="base_bim_2.budget_departure_asset_discount">
         <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <!--
                <t t-set="budget_departures" t-value="o.budget_id.concept_ids.filtered(lambda x: x.type == 'departure')"/>
                -->
                <t t-set="budget_departures" t-value="o.bim_concepts_ids"/>
                <t t-set="departure_count" t-value="0"/>
                <t t-foreach="budget_departures" t-as="departure">
                    <t t-call="base_bim_2.bim_header_external_layout_departure_discount_assets">
                        <div class="page">
                            <style type="text/css">
                                th, td {
                                vertical-align: middle !important;
                                }
                            </style>
                            <h3 class="text-center">ANÁLISIS DE PRECIOS UNITARIOS [ <span t-esc="o.budget_id.code"/> ]</h3>
                            <t t-set="productivity_rrhh" t-value="departure.get_departure_total(self, domain=[('type','=','labor'),('asset_type','=',False)], mapped_field='quantity')"/>


                            <t t-set="administration_percentage" t-value="departure.get_departure_budget_asset_percent([('asset_id.desc','in',('Administration','Administracion','Administración'))])"/>


                            <t t-set="utility_percentage" t-value="departure.get_departure_budget_asset_percent([('asset_id.desc','in',('Utility','Utilidad'))])"/>

                            <t t-set="financing_percentage" t-value="departure.get_departure_budget_asset_percent([('asset_id.desc','in',('FINANCIAMIENTO','FINANCIAMIENTO','financing'))])"/>


                            <table class="table table-sm" style="border:1px solid black !important;">
                                <tr style="font-size: 12px;max-height: 13px !important;">
                                    <td>
                                        <strong>PARTIDA: </strong> # <span t-esc="departure.code"/>
                                    </td>
                                    <td>
                                        <strong class="ml-3">CODIGO:</strong> <span t-esc="departure.code"/>
                                    </td>
                                    <td>
                                        <strong class="ml-3">UND:</strong> <t t-if="departure.uom_id"> <span t-esc="departure.uom_id.name"/></t>
                                    </td>
                                    <td>
                                        <strong class="ml-3">H/HOMBRE:</strong> <span t-esc="round(departure.apu_men_hours,2)"/>
                                    </td>
                                    <td>
                                        <strong class="ml-3">CANT. PARTIDA:</strong> <span t-esc="departure.quantity"/>
                                    </td>

                                </tr>
                                <tr style="font-size: 12px;max-height: 13px !important;">
                                    <td colspan="2">
                                        <strong>NOMBRE:</strong> <span t-esc="departure.name"/>
                                    </td>
                                    <td colspan="2">
                                        <strong>PRODUCTIVIDAD(HM/UNID):</strong>
                                        <span t-esc="round(productivity_rrhh,2)"/>
                                    </td>
                                    <td>
                                        <strong>RENDIMIENTO:</strong> <span t-esc="departure.performance"/>
                                    </td>

                                </tr>
                                <tr style="font-size: 12px;max-height: 13px !important;">
                                    <td colspan="5">
                                        <strong>OBRA:</strong> <span t-esc="departure.project_id.nombre"/>
                                    </td>
                                </tr>
                            </table>
                            <br/>



                            <!--materials-->
                            <t t-if="departure.apu_total_materials != 0">
                             <table class="table table-sm" style="width:1xx%;">
                                <tr>
                                    <td class="text-left" style="border:1px solid black; background-color: #B8B9B8;
                                                                 font-size: 12px;max-height: 13px !important;" colspan="6">
                                        <strong>1- MATERIALES</strong>
                                    </td>
                                </tr>
                                <tr style="font-size: 12px;max-height: 13px !important;">
                                    <td class="text-left" style="border:1px solid black;width:10%;">COD.</td>
                                    <td class="text-left" style="border:1px solid black;width:50%;">DESCRIPCION</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">UNID</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">CANTIDAD</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">COSTO</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">TOTAL</td>
                                </tr>
                                <t t-call="base_bim_2.departure_details_template">
                                    <t t-set="concepts" t-value="departure.child_ids.filtered(lambda x: x.type == 'material' and x.asset_type is False)"/>
                                    <t t-set="table_label" t-value="MATERIALS"/>
                                </t>
                            </table>
                            <div class="row pt-0" style="font-style: italic; font-size: 10px;">
                                <div class="col-9"/>
                                <div class="col-1 text-right">Total</div>
                                <div class="col-1 text-right">% Costo</div>
                                <div class="col-1 text-right">% P.Unit</div>
                            </div>
                            <div class="row pt-0" style="font-style: italic; font-size: 10px;">
                                <div class="col-7"/>
                                <div class="col-2">Total Materiales.........................</div>
                                <div class="col-1 text-right">
                                    <span t-esc="round(departure.apu_total_materials,2)"/>
                                </div>


                                <div class="col-1 text-right"><t t-if="departure.apu_direct_cost >0 "><span t-esc="round(departure.apu_total_materials/departure.apu_direct_cost*100,2)"/></t> </div>
                                <div class="col-1 text-right"><t t-if="departure.apu_total >0 "><span t-esc="round(departure.apu_total_materials/departure.apu_total*100,2)"/></t> </div>

                            </div>
                            <div class="row" style="font-style: italic; font-size: 10px;">
                                <div class="col-7"/>
                                <div class="col-2">Costo Materiales por Unidad...</div>
                                <div class="col-2"/>
                                <div class="col-1 text-right">
                                    <span t-esc="round(departure.apu_total_materials,2)"/>
                                </div>
                            </div>
                            </t>


                            <t t-if="departure.apu_total_transport >0 ">
                            <!--transport-->
                            <table class="table table-sm" style="width:1xx%;">
                                <tr>
                                    <td class="text-left" style="border:1px solid black; background-color: #B8B9B8; ;
                                                                 font-size: 12px;max-height: 13px !important;" colspan="6">
                                        <strong>2- TRANSPORTE</strong></td>
                                </tr>
                                <tr style="font-size: 12px;max-height: 13px !important;">
                                    <td class="text-left" style="border:1px solid black;width:10%;">COD.</td>
                                    <td class="text-left" style="border:1px solid black;width:50%;">DESCRIPCION</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">UNID</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">CANTIDAD</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">COSTO</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">TOTAL</td>
                                </tr>
                                <t t-call="base_bim_2.departure_details_template">
                                    <t t-set="concepts" t-value="departure.child_ids.filtered(lambda x: x.asset_type == 'transport')"/>
                                    <t t-set="table_label" t-value="TRANSPORT"/>
                                </t>
                            </table>

                            <div class="row pt-0" style="font-style: italic; font-size: 10px;">
                                <div class="col-9"/>
                                <div class="col-1 text-right">Total</div>
                                <div class="col-1 text-right">% Costo</div>
                                <div class="col-1 text-right">% P.Unit</div>
                            </div>
                            <div class="row pt-0" style="font-style: italic; font-size: 10px;">
                                <div class="col-7"/>
                                <div class="col-2">Total Transporte..........................</div>
                                <div class="col-1 text-right">
                                    <span t-esc="round(departure.apu_total_transport)" t-options="{'widget': 'monetary', 'display_currency': departure.budget_id.currency_id}"/>
                                </div>

                                <div class="col-1 text-right"><t t-if="departure.apu_direct_cost >0 "><span t-esc="round(departure.apu_total_transport/departure.apu_direct_cost*100,2)"/></t> </div>
                                <div class="col-1 text-right"><t t-if="departure.apu_total >0 "><span t-esc="round(departure.apu_total_transport/departure.apu_total*100,2)"/></t> </div>
                            </div>
                            <div class="row" style="font-style: italic; font-size: 10px;">
                                <div class="col-7"/>
                                <div class="col-2">Costo Transporte por Unidad...</div>
                                <div class="col-2"/>
                                <div class="col-1 text-right">
                                    <span t-esc="round(departure.apu_total_transport)" t-options="{'widget': 'monetary', 'display_currency': departure.budget_id.currency_id}"/>
                                </div>
                            </div>
                            </t>


                            <!--equipments-->
                            <t t-if="departure.apu_total_equipment != 0">
                            <table class="table table-sm" style="width:1xx%;">
                                <tr>
                                    <td class="text-left" style="border:1px solid black; background-color: #B8B9B8; ;
                                                                 font-size: 12px;max-height: 13px !important;" colspan="6"><strong>3- EQUIPOS</strong></td>
                                </tr>
                                <tr style="font-size: 12px;max-height: 13px !important;">
                                    <td class="text-left" style="border:1px solid black;width:10%;">COD.</td>
                                    <td class="text-left" style="border:1px solid black;width:50%;">DESCRIPCION</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">CANTIDAD</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">COSTO</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">DEP.ALQ</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">TOTAL</td>
                                </tr>
                                <t t-call="base_bim_2.departure_details_template_equipment">
                                    <t t-set="concepts" t-value="departure.child_ids.filtered(lambda x: x.type == 'equip' and x.asset_type is False)"/>
                                    <t t-set="table_label" t-value="EQUIPMENTS"/>
                                </t>
                            </table>
                            <div class="row pt-0" style="font-style: italic; font-size: 10px;">
                                <div class="col-9"/>
                                <div class="col-1 text-right">Total</div>
                                <div class="col-1 text-right">% Costo</div>
                                <div class="col-1 text-right">% P.Unit</div>
                            </div>
                            <div class="row pt-0" style="font-style: italic; font-size: 10px;">
                                <div class="col-7"/>
                                <div class="col-2">Total Equipos...........................</div>
                                <div class="col-1 text-right">
                                    <span t-esc="round(departure.apu_total_equipment,2)" t-options="{'widget': 'monetary', 'display_currency': departure.budget_id.currency_id}"/>
                                </div>

                                <div class="col-1 text-right"><t t-if="departure.apu_direct_cost >0 "><span t-esc="round(departure.apu_total_equipment/departure.apu_direct_cost*100,2)"/></t> </div>
                                <div class="col-1 text-right"><t t-if="departure.apu_total >0 "><span t-esc="round(departure.apu_total_equipment/departure.apu_total*100,2)"/></t> </div>

                            </div>
                            <div class="row" style="font-style: italic; font-size: 10px;">
                                <div class="col-7"/>
                                <div class="col-2">Costo Equipos por Unidad....</div>
                                <div class="col-2"/>
                                <div class="col-1 text-right">
                                    <t t-if="departure.performance != 0">
                                        <span t-esc="round(departure.apu_total_equipment/departure.performance,2)" t-options="{'widget': 'monetary', 'display_currency': departure.budget_id.currency_id}"/>
                                    </t>
                                    <t t-else="">
                                        <span t-esc="round(departure.apu_total_equipment,2)" t-options="{'widget': 'monetary', 'display_currency': departure.budget_id.currency_id}"/>
                                    </t>
                                </div>
                            </div>
                            </t>




                            <!--labor-->
                            <t t-if="departure.apu_total_labor != 0">
                            <table class="table table-sm" style="width:1xx%;">
                                <tr>
                                    <td class="text-left" style="border:1px solid black;background-color: #B8B9B8; ;
                                                                 font-size: 12px;max-height: 13px !important;" colspan="6"><strong>4- MANO DE OBRA</strong></td>
                                </tr>
                                <tr style="font-size: 12px;max-height: 13px !important;">
                                    <td class="text-left" style="border:1px solid black;width:10%;">COD.</td>
                                    <td class="text-left" style="border:1px solid black;width:50%;">DESCRIPCION</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">CANTIDAD.</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">SALARIO</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">BONO</td>
                                    <td class="text-left" style="border:1px solid black;width:10%;">TOTAL</td>
                                </tr>
                                <t t-call="base_bim_2.departure_details_template_labor">
                                    <t t-set="concepts" t-value="departure.child_ids.filtered(lambda x: x.type == 'labor' and x.asset_type is False)"/>
                                    <t t-set="table_label" t-value="EQUIPMENTS"/>
                                </t>
                            </table>
                            <div class="row pt-0" style="font-style: italic; font-size: 10px;">
                                <div class="col-10 text-right">Total</div>
                                <div class="col-2 text-right"/>
                            </div>
                            <div class="row pt-0" style="font-style: italic; font-size: 10px;">
                                <div class="col-8"/>
                                <div class="col-2">Totales...........................</div>
                                <div class="col-1 text-right">
                                    <span t-esc="round(departure.apu_total_bonus,2)"
                                          t-options="{'widget': 'monetary', 'display_currency': departure.budget_id.currency_id}"/>
                                </div>
                                <div class="col-1 text-right">
                                    <span t-esc="round(departure.apu_total_labor)"
                                          t-options="{'widget': 'monetary', 'display_currency': departure.budget_id.currency_id}"/>
                                </div>

                            </div>
                            </t>

                            <div class="row pt-3" style="font-style: italic; font-size: 10px;">
                                <div class="col-4">
                                    <table class="table table-sm" style="width:1xx%;border:1px solid black !important;">
                                        <tr><td>CANTIDAD</td><td>*</td><td>PRECIO UNITARIO </td><td>=</td><td>TOTAL</td></tr>
                                        <tr><td colspan="2"><span t-esc="departure.quantity"/></td><td colspan="2">
